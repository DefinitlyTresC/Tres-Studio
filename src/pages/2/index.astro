---
// Site 2 — "the floating one." T R E S . adrift in white space; everything
// on this site hangs weightless. Replaces the dead stripes stub entirely.
import { MV_CLIENT } from '../../lib/multiverse';

// Hand-placed composition (vw/vh units): glyph, x, y, size rem-ish factor,
// depth (parallax factor — bigger = closer = moves more).
const LETTERS = [
  { g: 'T', x: 30, y: 22, s: 1.0, d: 0.9, t: 17 },
  { g: 'R', x: 72, y: 18, s: 0.72, d: 1.4, t: 23 },
  { g: 'E', x: 14, y: 52, s: 0.86, d: 1.1, t: 19 },
  { g: 'S', x: 55, y: 58, s: 1.18, d: 0.7, t: 26 },
  { g: '.', x: 82, y: 74, s: 1.3, d: 1.8, t: 15 },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FAFAF7" />
    <title>T R E S .</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;700;800&family=Space+Mono&display=swap" rel="stylesheet" />
    <script is:inline set:html={MV_CLIENT(2)} />
  </head>
  <body>
    <header class="space" aria-label="Tres">
      {LETTERS.map((l, i) => (
        <span
          class="glyph"
          style={`--x:${l.x}vw; --y:${l.y}svh; --s:${l.s}; --d:${l.d}; --t:${l.t}s; --ph:${i * 1.7}s;`}
          aria-hidden="true"
        >{l.g}</span>
      ))}
      <p class="cue">scroll</p>
    </header>

    <nav class="menu" aria-label="Sections">
      <a href="/2/work" style="--off:6vw">Work</a>
      <a href="/2/archive" style="--off:26vw">Archive</a>
      <a href="/lab" style="--off:12vw">Lab</a>
      <a href="/2/about" style="--off:34vw">About</a>
    </nav>

    <footer id="mv-info" class="info">
      <div class="i-cols">
        <div class="i-col">
          <span class="lbl">Location</span>
          Seagrove · 30A<br />Florida, USA
        </div>
        <div class="i-col">
          <span class="lbl">Contact</span>
          <a href="mailto:tres@tres.studio">tres@tres.studio</a><br />
          <a href="https://instagram.com/tres.studio" target="_blank" rel="noopener">IG</a>
        </div>
        <div class="i-col">
          <span class="lbl">Sections</span>
          <a href="/2/work">Work</a><br />
          <a href="/2/archive">Archive</a><br />
          <a href="/lab">Lab</a><br />
          <a href="/2/about">About</a>
        </div>
      </div>
      <div class="i-meta">
        <span>© 2026 Tres Carter</span>
        <span id="mv-ticker-slot"></span>
        <a href="/privacy">Privacy</a>
      </div>
    </footer>

    <style is:inline>
      :root {
        --mvt-card: #ffffff; --mvt-ink: #101010; --mvt-line: rgba(0,0,0,0.25);
        --mvt-label: rgba(0,0,0,0.5); --mvt-accent: #101010; --mvt-confetti: #101010,#9a9a9a,#ffffff;
      }
      * { margin: 0; box-sizing: border-box; }
      html, body { overflow-x: hidden; }
      html { background: #FAFAF7; }
      body { font-family: 'Hanken Grotesk', system-ui, sans-serif; color: #101010; -webkit-font-smoothing: antialiased; }
      ::selection { background: #101010; color: #FAFAF7; }
      a { color: inherit; text-decoration: none; }

      .space { position: relative; height: 120svh; }
      .glyph {
        position: absolute; left: var(--x); top: var(--y);
        font-weight: 800; font-size: calc(clamp(64px, 11vw, 150px) * var(--s));
        line-height: 1;
        translate: var(--px, 0) calc(var(--py, 0) + var(--scroll, 0));
        animation: drift var(--t) ease-in-out var(--ph) infinite alternate;
        will-change: translate;
      }
      @keyframes drift {
        from { margin-top: 0; margin-left: 0; }
        to { margin-top: 2.2vh; margin-left: -1.1vw; }
      }
      .cue {
        position: absolute; bottom: 12svh; left: 50%; translate: -50% 0;
        font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
        color: rgba(16, 16, 16, 0.45);
      }

      .menu { min-height: 100svh; display: grid; align-content: center; gap: 7svh; padding: 0 6vw; }
      .menu a {
        display: block; margin-left: var(--off, 0);
        font-weight: 700; font-size: clamp(34px, 6.8vw, 84px); line-height: 1;
        letter-spacing: -0.01em;
      }
      @media (max-width: 640px) { .menu a { margin-left: calc(var(--off, 0) * 0.4); } }
      @media (hover: hover) and (pointer: fine) {
        .menu a { transition: letter-spacing 300ms cubic-bezier(0.23, 1, 0.32, 1); }
        .menu a:hover { letter-spacing: 0.04em; }
      }

      .info { min-height: 70svh; display: grid; align-content: end; gap: 7svh; position: relative; padding: 10svh 6vw 4svh; }
      .i-cols {
        display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px;
        padding-right: clamp(100px, 24vw, 240px);
        font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.05em;
        text-transform: uppercase; line-height: 1.9;
      }
      @media (max-width: 640px) { .i-cols { grid-template-columns: 1fr; } }
      .lbl { display: block; color: rgba(16,16,16,0.45); margin-bottom: 6px; }
      .i-meta {
        display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap;
        border-top: 1px solid rgba(0,0,0,0.14); padding-top: 16px;
        font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase;
      }
      @media (hover: hover) and (pointer: fine) {
        .info a:hover { text-decoration: underline; text-underline-offset: 4px; }
      }

      @media (prefers-reduced-motion: reduce) {
        .glyph { animation: none; translate: 0 0; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
      import('/mv/ring.js');
    </script>
    <script is:inline>
      (function () {
        'use strict';
        var reduce = false, fine = false;
        try {
          reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
          fine = matchMedia('(hover: hover) and (pointer: fine)').matches;
        } catch (e) {}
        if (reduce) return;
        var glyphs = Array.prototype.slice.call(document.querySelectorAll('.glyph'));
        var depths = glyphs.map(function (g) { return parseFloat(g.style.getPropertyValue('--d')) || 1; });

        /* scroll: letters rise at their own rates — depth */
        var ticking = false;
        function onScroll() {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(function () {
            ticking = false;
            var y = scrollY;
            for (var i = 0; i < glyphs.length; i++) {
              glyphs[i].style.setProperty('--scroll', (-y * 0.18 * depths[i]).toFixed(1) + 'px');
            }
          });
        }
        addEventListener('scroll', onScroll, { passive: true });

        /* desktop: pointer parallax, lerped */
        if (fine) {
          var tx = 0, ty = 0, cx = 0, cy = 0, raf = null;
          function frame() {
            cx += (tx - cx) * 0.06; cy += (ty - cy) * 0.06;
            for (var i = 0; i < glyphs.length; i++) {
              glyphs[i].style.setProperty('--px', (cx * depths[i]).toFixed(1) + 'px');
              glyphs[i].style.setProperty('--py', (cy * depths[i]).toFixed(1) + 'px');
            }
            if (Math.abs(tx - cx) > 0.2 || Math.abs(ty - cy) > 0.2) raf = requestAnimationFrame(frame);
            else raf = null;
          }
          addEventListener('pointermove', function (e) {
            tx = (e.clientX / innerWidth - 0.5) * -26;
            ty = (e.clientY / innerHeight - 0.5) * -18;
            if (!raf) raf = requestAnimationFrame(frame);
          }, { passive: true });
        }
      })();
    </script>
    <script is:inline defer src="/mv/ticker.js"></script>
  </body>
</html>
