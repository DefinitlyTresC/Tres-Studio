---
// Site 2 — about. Same facts, loud voice.
import { MV_CLIENT } from '../../lib/multiverse';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#ffffff" />
    <title>ABOUT — TRES 02</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Space+Mono&display=swap" rel="stylesheet" />
    <script is:inline set:html={MV_CLIENT(2)} />
  </head>
  <body>
    <a class="back" href="/2/">← BACK</a>

    <main class="about">
      <h1 class="name">TRES CARTER</h1>
      <p class="lede">ARCHITECTURAL DESIGNER — 30A, FLORIDA</p>
      <div class="acts">
        <a href="mailto:tres@tres.studio">TRES@TRES.STUDIO</a>
        <a href="https://instagram.com/tres.studio" target="_blank" rel="noopener">IG</a>
      </div>
    </main>

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }
      html, body { overflow-x: hidden; }
      html { background: #fff; }
      body { font-family: 'Anton', system-ui, sans-serif; color: #0a0a0a; -webkit-font-smoothing: antialiased; }
      ::selection { background: #0a0a0a; color: #fff; }
      a { color: inherit; text-decoration: none; }
      .back { position: fixed; top: 16px; left: 5vw; font-family: 'Space Mono', monospace; font-size: 12px; padding: 12px 0; }
      .about { padding: clamp(140px, 26vh, 320px) 5vw 14svh; }
      .name { font-size: clamp(64px, 14vw, 200px); line-height: 0.95; }
      .lede { font-family: 'Space Mono', monospace; font-size: 13px; letter-spacing: 0.12em; background: #0a0a0a; color: #fff; display: inline-block; padding: 8px 14px; margin-top: 20px; }
      .acts { display: flex; gap: 28px; margin-top: 44px; font-family: 'Space Mono', monospace; font-size: 13px; }
      @media (hover: hover) and (pointer: fine) {
        a:hover { text-decoration: underline; text-underline-offset: 4px; }
      }
    </style>
  </body>
</html>
