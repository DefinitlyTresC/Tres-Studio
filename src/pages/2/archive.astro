---
// Site 2 — archive. Everything else, weightless.
import { MV_CLIENT } from '../../lib/multiverse';
import { getCollection } from 'astro:content';

const WORK = ['z07', 'ee13', 'flatwood', 'tucker', 'thesis'];
const all = (await getCollection('projects')).map((e) => e.data);
const rows = all.filter((p) => !WORK.includes(p.slug));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FAFAF7" />
    <title>Archive — T R E S .</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;700;800&family=Space+Mono&display=swap" rel="stylesheet" />
    <script is:inline set:html={MV_CLIENT(2)} />
    <!-- tracking: one bootstrap for the whole site (Umami + Clarity + visitor id + self-exclusion) - public/ts.js -->
    <script is:inline defer src="/ts.js"></script>
  </head>
  <body>
    <a class="back" id="back" href="/2/">← index</a>

    <main class="arch">
      <header class="head">
        <p class="spec">archive · {String(rows.length).padStart(2, '0')}</p>
        <h1 class="name">E v e r y t h i n g&ensp;e l s e</h1>
      </header>
      <div class="list" data-zg-room>
        {rows.map((p) => (
          <a class="row" data-zg data-zg-slim href={`/2/project/${p.slug}`}>
            <span class="r-no">{String(p.id ?? '').padStart(2, '0')}</span>
            <span class="r-name">{p.name}</span>
            <span class="r-meta">{p.category}</span>
            <span class="r-meta r-year">{p.year}</span>
          </a>
        ))}
      </div>
    </main>

    <footer class="foot">
      <span>© 2026 Tres Carter</span>
      <a href="/privacy">Privacy</a>
    </footer>

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }
      html { background: #FAFAF7; }
      body { font-family: 'Hanken Grotesk', system-ui, sans-serif; color: #101010; -webkit-font-smoothing: antialiased; }
      ::selection { background: #101010; color: #FAFAF7; }
      a { color: inherit; text-decoration: none; }
      .back { position: fixed; z-index: 10; top: var(--y, 14px); left: 6vw; font-family: 'Space Mono', monospace; font-size: 12px; padding: 12px 0; transition: transform 140ms cubic-bezier(0.23,1,0.32,1); }
      .back:active { transform: scale(0.96); }
      @media (hover: hover) and (pointer: fine) { .back:hover { text-decoration: underline; text-underline-offset: 4px; } }
      .back:focus-visible { outline: 2px solid #101010; outline-offset: 3px; }

      .arch { max-width: 1100px; margin: 0 auto; padding: 0 6vw 12svh; }
      .head { padding: clamp(110px, 22vh, 260px) 0 7svh; }
      .spec { font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(16,16,16,0.45); }
      .name { font-weight: 800; font-size: clamp(34px, 6.2vw, 76px); line-height: 1.04; margin-top: 10px; }

      .list { border-top: 1px solid rgba(0,0,0,0.14); }
      .row {
        display: grid; grid-template-columns: 3ch minmax(0, 1fr) auto auto; gap: 18px; align-items: baseline;
        padding: 16px 0; border-bottom: 1px solid rgba(0,0,0,0.14);
      }
      .r-no, .r-meta { font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.05em; text-transform: uppercase; color: rgba(16,16,16,0.45); }
      .r-name { font-weight: 700; font-size: clamp(16px, 2.2vw, 22px); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .r-year { text-align: right; min-width: 4ch; }
      @media (max-width: 560px) { .r-meta:not(.r-year) { display: none; } .row { grid-template-columns: 3ch minmax(0, 1fr) auto; } }
      @media (hover: hover) and (pointer: fine) {
        .r-name { transition: letter-spacing 300ms cubic-bezier(0.23,1,0.32,1); }
        .row:hover .r-name { letter-spacing: 0.03em; }
        .sim .row { cursor: grab; }
        .sim .row:active { cursor: grabbing; }
      }

      .foot { display: flex; justify-content: space-between; max-width: 1100px; margin: 0 auto; padding: 3svh 6vw 4svh; border-top: 1px solid rgba(0,0,0,0.14); font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; }
    </style>

    <style is:inline>
      @media (prefers-reduced-motion: reduce) {
        .back, .r-name { transition: none; }
        .back:active { transform: none; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
    </script>
    <script is:inline>
      (function () {
        var reduce = false, fine = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; fine = matchMedia('(hover: hover) and (pointer: fine)').matches; } catch (e) {}
        if (!fine || reduce) return;
        var back = document.getElementById('back');
        var target = null, cur = null, raf = null;
        function frame() {
          cur += (target - cur) * 0.09;
          back.style.setProperty('--y', cur.toFixed(1) + 'px');
          if (Math.abs(target - cur) > 0.4) raf = requestAnimationFrame(frame); else raf = null;
        }
        addEventListener('pointermove', function (e) {
          if (e.pointerType === 'touch') return; /* hybrids: taps must not move it */
          var h = back.offsetHeight;
          target = Math.min(innerHeight - h - 12, Math.max(12, e.clientY - h / 2));
          if (cur === null) cur = target;
          if (!raf) raf = requestAnimationFrame(frame);
        }, { passive: true });
      })();
    </script>
    <script is:inline defer src="/mv/zerog.js"></script>
  </body>
</html>
