---
// [cat].astro — data-driven category listing.
//
// Phase 3 port of category.html's inline <script>. The v1 page shipped an
// empty <main> and built the DOM client-side after fetching the sheet; here we
// render that exact DOM at BUILD time, one static page per category.
//
// getStaticPaths generates ONLY 'architecture' and 'personal'. /lab is a
// separate hardcoded page (lab.astro, owned elsewhere) — NOT built here, even
// though a 'lab' category exists in the sheet.
//
// Parity notes (matched against category.html verbatim):
//   - CATEGORY_NUM: architecture 01, personal 02, lab 03.
//   - catLabel = capitalized category.
//   - Tile links point at the NEW clean path /project/<slug> (v1 used
//     project.html?id=<slug>).
//   - Empty-category branch reproduces the <section class="empty-cat"> markup.
//   - Tiles use p.name (Project.name <- 'Display Name') and heroUrlThumb, with
//     the same class names / lazy attrs / onerror hide the v1 script emitted.
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { heroUrlThumb } from '../lib/cloudinary';
import type { Project } from '../lib/sheet';

// Category display numbers — kept in sync with the homepage genre index
// (verbatim from category.html's CATEGORY_NUM).
const CATEGORY_NUM: Record<string, string> = {
  architecture: '01',
  personal: '02',
  lab: '03',
};

// Only architecture + personal get static pages here; /lab is its own page.
const BUILT_CATEGORIES = ['architecture', 'personal'] as const;

export async function getStaticPaths() {
  const all = await getCollection('projects');

  return ['architecture', 'personal'].map((cat) => {
    // Entries already come slug-keyed, filtered (no Hidden), and Order-sorted
    // by the loader (parseProjects). Just narrow to this category.
    const projects = all
      .filter((e) => e.data.category === cat)
      .map((e) => e.data)
      .sort((a, b) => a.order - b.order);

    return { params: { cat }, props: { projects } };
  });
}

interface Props {
  projects: Project[];
}

const { cat } = Astro.params;
const { projects } = Astro.props;

const catLabel = cat.charAt(0).toUpperCase() + cat.slice(1);
const num = CATEGORY_NUM[cat] || '·';

// Head metadata — verbatim strings from category.html's setMeta calls.
const title = `${catLabel} — Tres.`;
const description = `${catLabel} work by Tres Carter.`;
---

<Base title={title} description={description}>
  <main id="content">
    {projects.length === 0 ? (
      <section class="empty-cat">
        <div class="empty-cat-tag">— Category · {num}</div>
        <h1 class="empty-cat-name">{catLabel}</h1>
        <p class="empty-cat-msg">No projects in {catLabel.toLowerCase()} yet.</p>
        <a class="empty-cat-back" href="/">← Back to studio</a>
      </section>
    ) : (
      <>
        <section class="cat-intro">
          <div class="reveal">
            <div class="cat-intro-tag">— Category · {num}</div>
            <h1 class="cat-intro-name">{catLabel}</h1>
          </div>
          <div class="cat-intro-meta reveal">
            <strong>{String(projects.length).padStart(2, '0')} projects</strong>
            2023 — 2026
          </div>
        </section>

        <section class="proj-list">
          {projects.map((p) => (
            <a class="proj-item reveal" href={`/project/${p.slug}`}>
              <div class="proj-img">
                <img
                  src={heroUrlThumb(p) || ''}
                  alt={p.name}
                  loading="lazy"
                  decoding="async"
                  onerror="this.style.display='none'"
                />
              </div>
              <div class="proj-meta">
                <span class="name">{p.name}</span>
                <span class="info">{[p.location, p.year].filter(Boolean).join(' · ')}</span>
              </div>
            </a>
          ))}
        </section>
      </>
    )}
  </main>
</Base>
