    <style is:inline>
      :root {
        /* the site's brand — the multiverse's skin 02, now permanent */
        --paper: #FAFAF7; --ink: #101010; --accent: #9A9A9A;
        --soft: rgba(16,16,16,0.5); --hair: rgba(16,16,16,0.16);
        --disp: 'Hanken Grotesk', system-ui, sans-serif; --mono: 'Space Mono', ui-monospace, monospace;
        --bw: 1px; --rule: solid; --arch: 999px; --door-bg: var(--paper);
        --wt: 800; --tt-name: none; --tt-mono: uppercase; --mark-ls: -0.01em;
      }

      * { margin: 0; box-sizing: border-box; }
      html { background: var(--paper); }
      body { font-family: var(--disp); color: var(--ink); -webkit-font-smoothing: antialiased; }
      ::selection { background: var(--ink); color: var(--paper); }
      a { color: inherit; text-decoration: none; }

      .back {
        position: fixed; z-index: 10; top: var(--y, 14px); left: 5vw;
        font-family: var(--mono); font-size: 12px; letter-spacing: 0.1em; text-transform: var(--tt-mono);
        padding: 14px 8px 14px 0;
        transition: transform 140ms cubic-bezier(0.23,1,0.32,1);
      }
      .back:active { transform: scale(0.96); }
      @media (hover: hover) and (pointer: fine) {
        .back:hover { text-decoration: underline; text-underline-offset: 4px; }
      }
      .back:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }

      .hero {
        min-height: 52svh; display: grid; place-content: center; justify-items: center;
        text-align: center; padding: clamp(90px, 16svh, 180px) 5vw 6svh; gap: 14px;
      }
      .spec {
        font-family: var(--mono); font-size: 12px; letter-spacing: 0.12em;
        text-transform: var(--tt-mono); color: var(--soft);
      }
      .mark {
        font-weight: var(--wt); font-size: clamp(72px, 18vw, 240px); line-height: 0.9;
        letter-spacing: var(--mark-ls); text-transform: var(--tt-name);
      }
      .dot { color: var(--accent); }

      /* ── the shelf: a zero-g room, doors parked at percent homes ───────── */
      /* margin (not padding) keeps clearance outside the room box: the
         bottom-row doors overhang the hall edge a little when parked */
      .hall {
        position: relative; /* the doors park against the hall, engine or no engine */
        width: 100%; max-width: 1240px; margin: 0 auto 14svh;
        /* floor = closest row pair (30 percent apart) clearing a full parked
           door height (391px at the 230px cap) even on short laptops */
        height: max(1310px, 118svh);
      }
      /* parking = the engine's homes, in CSS: same percents, so the page is
         pixel-identical whether physics booted or not */
      .door {
        position: absolute; left: calc(var(--hx) * 1%); top: calc(var(--hy) * 1%);
        translate: -50% -50%;
        width: clamp(150px, 21vw, 230px); aspect-ratio: 10 / 17;
        display: block;
      }
      @media (max-width: 640px) {
        .hall { height: 1950px; }
        .door { left: calc(var(--hxn) * 1%); top: calc(var(--hyn) * 1%); }
      }
      /* the engine owns the outer transform, inline, every frame — the slot
         collapses to 0,0 and ALL cosmetics move to .din */
      .sim .door { left: 0; top: 0; translate: none; will-change: transform; }
      .door:focus-visible { outline: 2px solid var(--ink); outline-offset: 4px; }

      .din {
        position: relative; width: 100%; height: 100%;
        display: flex; flex-direction: column; justify-content: flex-end;
        border: var(--bw) var(--rule) var(--ink);
        border-radius: var(--arch) var(--arch) 0 0;
        background: var(--door-bg);
        overflow: hidden;
        transition: transform 260ms cubic-bezier(0.23,1,0.32,1);
      }
      .door:active .din { transform: scale(0.96); }
      .win { position: absolute; inset: 0; }
      .win svg {
        display: block; width: 100%; height: 100%;
        opacity: 0.5;
        transition: opacity 300ms cubic-bezier(0.23,1,0.32,1);
      }
      .plate {
        position: relative; display: grid; gap: 5px;
        padding: 14px 14px 18px; text-align: center;
        background: var(--door-bg);
        border-top: var(--bw) var(--rule) var(--hair);
      }
      .name {
        font-weight: var(--wt); font-size: 19px; line-height: 1.1;
        text-transform: var(--tt-name);
      }
      .tag {
        font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em; line-height: 1.5;
        text-transform: var(--tt-mono); color: var(--soft);
      }
      /* the keeper row — which universe held this piece in the multiverse */
      .keeper {
        display: flex; align-items: center; justify-content: center; gap: 6px;
        font-family: var(--mono); font-size: 9px; letter-spacing: 0.14em;
        text-transform: var(--tt-mono); color: var(--soft);
      }
      .sw {
        width: 7px; height: 7px; border-radius: 50%;
        background: var(--sw, var(--soft)); display: inline-block;
      }
      @media (hover: hover) and (pointer: fine) {
        .door:hover .din { transform: scale(1.035); }
        .door:hover .win svg { opacity: 1; }
        .sim .door { cursor: grab; }
        .sim .door:active { cursor: grabbing; }
      }

      /* entrance: doors rise into place, staggered — on .din, never the body */
      @media (prefers-reduced-motion: no-preference) {
        .din {
          animation: rise 620ms cubic-bezier(0.23,1,0.32,1) both;
          animation-delay: calc(var(--i, 0) * 70ms);
        }
        @keyframes rise { from { opacity: 0; transform: translateY(22px); } }
      }

      /* ── the living patterns (transform/opacity only) ──────────────────── */
      .w1 { animation: waveX 7s linear infinite; }
      .w2 { animation: waveX 5.2s linear infinite; }
      .w3 { animation: waveX 9s linear infinite; }
      @keyframes waveX { to { transform: translateX(-50px); } }

      .ant { animation: antwalk 6.4s cubic-bezier(0.23,1,0.32,1) infinite; }
      @keyframes antwalk {
        0%, 10.5%    { transform: translate(0, 0); }
        12.5%, 23%   { transform: translate(0, -28px); }
        25%, 35.5%   { transform: translate(28px, -28px); }
        37.5%, 48%   { transform: translate(28px, -56px); }
        50%, 60.5%   { transform: translate(56px, -56px); }
        62.5%, 73%   { transform: translate(56px, -28px); }
        75%, 85.5%   { transform: translate(28px, -28px); }
        87.5%, 98%   { transform: translate(28px, 0); }
        100%         { transform: translate(0, 0); }
      }

      .f1 { animation: fly 14s linear infinite; animation-delay: -6s; }
      .f2 { animation: fly 10s linear infinite; animation-delay: -3s; }
      @keyframes fly { from { transform: translateX(-110px); } to { transform: translateX(310px); } }

      .echo-c {
        animation: ripple 4.2s cubic-bezier(0.215,0.61,0.355,1) infinite;
        transform-box: fill-box; transform-origin: center;
      }
      @keyframes ripple {
        from { transform: scale(0.12); opacity: 0.95; }
        to { transform: scale(3.4); opacity: 0; }
      }

      .pulse-c {
        animation: pulseout 3.4s cubic-bezier(0.215,0.61,0.355,1) infinite;
        transform-box: fill-box; transform-origin: center;
      }
      @keyframes pulseout {
        from { transform: scale(0.3); opacity: 0.95; }
        to { transform: scale(1.35); opacity: 0; }
      }

      .dot-p {
        animation: dotpulse 2.6s cubic-bezier(0.23,1,0.32,1) infinite;
        transform-box: fill-box; transform-origin: center;
      }
      @keyframes dotpulse {
        0%, 100% { transform: scale(1); opacity: 0.9; }
        50% { transform: scale(1.7); opacity: 0.45; }
      }

      .ht1 { animation: htbreathe 3.8s ease-in-out infinite; transform-box: fill-box; transform-origin: center; }
      .ht2 { animation: htbreathe 3.8s ease-in-out infinite; animation-delay: -1.3s; transform-box: fill-box; transform-origin: center; }
      .ht3 { animation: htbreathe 3.8s ease-in-out infinite; animation-delay: -2.6s; transform-box: fill-box; transform-origin: center; }
      @keyframes htbreathe {
        0%, 100% { transform: scale(0.55); }
        50% { transform: scale(1.15); }
      }

      .parcel {
        animation: parceldrop 5.2s cubic-bezier(0.23,1,0.32,1) infinite;
        transform-box: fill-box; transform-origin: 50% 100%;
      }
      @keyframes parceldrop {
        0%, 8%   { transform: translateY(-90px); opacity: 0; }
        14%      { opacity: 1; }
        30%      { transform: translateY(0) scaleY(1); }
        36%      { transform: translateY(0) scaleY(0.86); }
        44%, 86% { transform: translateY(0) scaleY(1); opacity: 1; }
        94%, 100% { transform: translateY(0); opacity: 0; }
      }

      .foot {
        display: flex; justify-content: space-between; padding: 3svh 5vw 4svh;
        border-top: var(--bw) var(--rule) var(--hair);
        font-family: var(--mono); font-size: 10px; letter-spacing: 0.06em; text-transform: var(--tt-mono);
      }
      @media (hover: hover) and (pointer: fine) {
        .foot a:hover { text-decoration: underline; text-underline-offset: 4px; }
      }
      .foot a:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }

      /* reduced motion: everything rests, composed and legible */
      @media (prefers-reduced-motion: reduce) {
        .back, .din, .win svg { transition: none; }
        .back:active { transform: none; }
        .door:active .din { transform: none; }
        .win svg * { animation: none !important; }
        .win svg { opacity: 0.6; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal, cover } from '/mv/curtain.js';
      autoReveal();

      /* doors open through the ink — document level, AFTER the engine's own
         element-level click listener, so its drag suppression is respected */
      let reduce = false;
      try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}
      let leaving = false;
      addEventListener('pageshow', (e) => {
        if (e.persisted) leaving = false; /* bfcache Back restores the latched heap */
      });
      document.addEventListener('click', async (e) => {
        const a = e.target.closest && e.target.closest('a.door');
        if (!a) return;
        if (e.defaultPrevented) return;               /* zerog suppressed a drag-click */
        /* modified/aux clicks keep their native meaning (new tab etc.) */
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button > 0) return;
        if (reduce) return;                            /* plain navigation */
        /* mid-cover: swallow repeat clicks so they can't navigate natively */
        if (leaving) { e.preventDefault(); return; }
        e.preventDefault();
        leaving = true;
        const r = a.getBoundingClientRect();
        await cover({ x: e.clientX || r.left + r.width / 2, y: e.clientY || r.top + r.height / 2, color: '#101010' });
        /* all seven sims are self-contained pages with no autoReveal —
           clear the flag so the NEXT site page doesn't peel a ghost */
        try { sessionStorage.removeItem('mv:covered'); } catch (err) {}
        location.href = a.getAttribute('href');
      });
    </script>
    <script is:inline>
      /* back link rides the cursor — the site-wide pattern */
      (function () {
        'use strict';
        var reduce = false, fine = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; fine = matchMedia('(hover: hover) and (pointer: fine)').matches; } catch (e) {}
        if (!fine || reduce) return;
        var back = document.getElementById('back');
        var target = null, cur = null, raf = null;
        function frame() {
          cur += (target - cur) * 0.09;
          back.style.setProperty('--y', cur.toFixed(1) + 'px');
          if (Math.abs(target - cur) > 0.4) raf = requestAnimationFrame(frame); else raf = null;
