---
// SATISFACTORY — stub door behind /lab. The real factory visualizer +
// downloader is being wired in a separate chat; until it docks, this page is
// one quiet composition: a conveyor running under a short mono line. No fake
// UI, no dead buttons — nothing here may promise a feature that doesn't
// exist yet.
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FAFAF7" />
    <title>SATISFACTORY — TRES.</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <!-- tracking: one bootstrap for the whole site (Umami + Clarity + visitor id + self-exclusion) - public/ts.js -->
    <script is:inline defer src="/ts.js"></script>
  </head>
  <body>
    <a class="back" id="back" href="/lab">← lab</a>

    <main id="content">
      <!-- STUB BODY: the Satisfactory visualizer chat replaces everything
           inside <main>. Keep the shell around it (head, .back, .foot,
           reveal + back scripts) as-is. -->
      <header class="hero">
        <p class="spec">the factory, visualized — docking soon</p>
        <h1 class="mark">SATISFACTORY<span class="dot">.</span></h1>
      </header>

      <section class="bay" aria-label="Status">
        <svg class="belt" viewBox="0 0 520 120" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M30 72 H490 M30 66 V72 M490 66 V72" fill="none" stroke="var(--ink)" stroke-width="2" />
          <g fill="var(--ink)" opacity="0.35">
            <circle cx="54" cy="84" r="3" /><circle cx="100" cy="84" r="3" /><circle cx="146" cy="84" r="3" />
            <circle cx="192" cy="84" r="3" /><circle cx="238" cy="84" r="3" /><circle cx="284" cy="84" r="3" />
            <circle cx="330" cy="84" r="3" /><circle cx="376" cy="84" r="3" /><circle cx="422" cy="84" r="3" />
            <circle cx="466" cy="84" r="3" />
          </g>
          <!-- markup x = resting spot, so the reduced-motion frame composes -->
          <rect class="p1" x="118" y="46" width="36" height="26" fill="none" stroke="var(--ink)" stroke-width="2" />
          <rect class="p2" x="300" y="44" width="30" height="28" fill="none" stroke="var(--accent)" stroke-width="2" />
        </svg>
        <p class="note">the visualizer is being assembled in another workshop. it docks here.</p>
      </section>
    </main>

    <footer class="foot">
      <span>© 2026 Tres Carter</span>
      <a href="/privacy">Privacy</a>
    </footer>

    <style is:inline>
      :root {
        --paper: #FAFAF7; --ink: #101010; --accent: #9A9A9A;
        --soft: rgba(16,16,16,0.5); --hair: rgba(16,16,16,0.16);
        --disp: 'Hanken Grotesk', system-ui, sans-serif; --mono: 'Space Mono', ui-monospace, monospace;
      }

      * { margin: 0; box-sizing: border-box; }
      html { background: var(--paper); }
      body { font-family: var(--disp); color: var(--ink); -webkit-font-smoothing: antialiased; }
      ::selection { background: var(--ink); color: var(--paper); }
      a { color: inherit; text-decoration: none; }

      .back { position: fixed; z-index: 10; top: var(--y, 14px); left: 6vw; font-family: var(--mono); font-size: 12px; padding: 12px 0; transition: transform 140ms cubic-bezier(0.23,1,0.32,1); }
      .back:active { transform: scale(0.96); }
      @media (hover: hover) and (pointer: fine) { .back:hover { text-decoration: underline; text-underline-offset: 4px; } }
      .back:focus-visible { outline: 2px solid #101010; outline-offset: 3px; }

      .hero {
        min-height: 52svh; display: grid; place-content: center; justify-items: center;
        text-align: center; padding: clamp(90px, 16svh, 180px) 5vw 4svh; gap: 14px;
      }
      .spec { font-family: var(--mono); font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--soft); }
      /* the long word sets the clamp — SATISFACTORY. must hold one line at 320px */
      .mark { font-weight: 800; font-size: clamp(34px, 10.5vw, 132px); line-height: 0.9; letter-spacing: -0.01em; }
      .dot { color: var(--accent); }

      .bay { display: grid; justify-items: center; gap: 22px; padding: 4svh 6vw 18svh; text-align: center; }
      .belt { display: block; width: min(520px, 88vw); height: auto; }
      .note { font-family: var(--mono); font-size: 12px; letter-spacing: 0.08em; line-height: 1.8; color: var(--soft); max-width: 46ch; }

      /* each parcel's cycle spans off-left → off-right of its own resting x,
         so the loop seam lands outside the viewBox; equal 556px travel keeps
         both at one belt speed, the -3.5s phase keeps them half a belt apart */
      .p1 { animation: haul1 7s linear infinite; }
      .p2 { animation: haul2 7s linear infinite; animation-delay: -3.5s; }
      @keyframes haul1 { from { transform: translateX(-154px); } to { transform: translateX(402px); } }
      @keyframes haul2 { from { transform: translateX(-336px); } to { transform: translateX(220px); } }

      .foot { display: flex; justify-content: space-between; padding: 3svh 6vw 4svh; border-top: 1px solid rgba(0,0,0,0.14); font-family: var(--mono); font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; }
      .foot a:focus-visible { outline: 2px solid #101010; outline-offset: 3px; }
    </style>

    <style is:inline>
      @media (prefers-reduced-motion: reduce) {
        .back { transition: none; }
        .back:active { transform: none; }
        .p1, .p2 { animation: none; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
    </script>
    <script is:inline>
      (function () {
        var reduce = false, fine = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; fine = matchMedia('(hover: hover) and (pointer: fine)').matches; } catch (e) {}
        if (!fine || reduce) return;
        var back = document.getElementById('back');
        var target = null, cur = null, raf = null;
        function frame() {
          cur += (target - cur) * 0.09;
          back.style.setProperty('--y', cur.toFixed(1) + 'px');
          if (Math.abs(target - cur) > 0.4) raf = requestAnimationFrame(frame); else raf = null;
        }
        addEventListener('pointermove', function (e) {
          if (e.pointerType === 'touch') return; /* hybrids: taps must not move it */
          var h = back.offsetHeight;
          target = Math.min(innerHeight - h - 12, Math.max(12, e.clientY - h / 2));
          if (cur === null) cur = target;
          if (!raf) raf = requestAnimationFrame(frame);
        }, { passive: true });
      })();
    </script>
  </body>
</html>
