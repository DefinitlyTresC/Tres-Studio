---
// Roadmap — the site's history + future as one growing, branching drawing.
// Everything below is baked at build time from the ROADMAP array; the client
// gets hand-tuned SVG and two small scripts (reveal + era chips), no data
// fetch, no libraries.

// — append here; the drawing grows with the data
// { date: 'YYYY-MM-DD' | 'ahead', title, note ('' = the title carries the row), branch?, status }
// status: 'era' | 'shipped' | 'superseded' | 'live' | 'next'
// Trunk = no branch. Branches stem from the nearest trunk node by date.
// Dates are grounded in REBRAND.md + git history — never invented.
const ROADMAP = [
  { date: '2026-05-15', title: 'the first site', note: 'hand-built html/css/js — no framework, no build', status: 'era' },
  { date: '2026-05-31', title: 'the react rebuild', note: '', branch: 'react', status: 'superseded' },
  { date: '2026-05-31', title: 'the dot cloud', note: '', branch: 'particles', status: 'superseded' },
  { date: '2026-06-01', title: 'the 80k proto', note: '', branch: 'particles', status: 'superseded' },
  { date: '2026-07-03', title: 'astro + the multiverse', note: 'sheet baked at build; one random front door', status: 'era' },
  { date: '2026-07-03', title: 'seven universes', note: '', branch: 'universes', status: 'superseded' },
  { date: '2026-07-11', title: 'universe 08 + epoch 2', note: '', status: 'shipped' },
  { date: '2026-07-12', title: 'lab, multiverse edition', note: '', status: 'shipped' },
  { date: '2026-07-12', title: 'seven sims, rebuilt', note: '', branch: 'lab', status: 'shipped' },
  { date: '2026-07-20', title: 'v3.0 — the collapse', note: 'one site — zero gravity', status: 'live' },
  { date: '2026-07-20', title: 'lab v3 — six doors', note: '', branch: 'lab', status: 'shipped' },
  { date: '2026-07-20', title: 'the satisfactory dock', note: '', branch: 'lab', status: 'shipped' },
  { date: 'ahead', title: 'the plugin shelf, stocked', note: '', status: 'next' },
  { date: 'ahead', title: 'slot six — unnamed', note: '', status: 'next' },
];

// The three eras, one chip each, anchored to the trunk node that opened the
// era. Chips are HTML riding the svg, so the copy stays selectable and the
// card can be a real tooltip.
const ERAS = [
  { id: 'V1', at: 'the first site', text: 'the hand-built site — one page, no framework, content from a sheet.' },
  { id: 'V2', at: 'astro + the multiverse', text: 'the astro rebuild — seven complete sites behind one randomizing front door.' },
  { id: 'V3', at: 'v3.0 — the collapse', text: 'one zero-g site. the universes retire to the lab as exhibits and toys.' },
];

// A branch that returns: its strand folds back into the trunk node at this date.
const MERGES = { universes: '2026-07-20' };

const r1 = (v) => Math.round(v * 10) / 10;
const esc = (s) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
// Every joint keeps vertical tangents, so chained segments stay C1-smooth —
// the trunk reads as one continuous swaying stroke even though each segment
// is its own path (the reveal animation needs them separate).
const seg = (a, b) => {
  const k = (b.y - a.y) * 0.5;
  return `C ${a.x} ${r1(a.y + k)} ${b.x} ${r1(b.y - k)} ${b.x} ${b.y}`;
};

function draw(cfg) {
  const { W, railX, sway, lane, sides, hugSides, pull, hug, rowH, top, pad, gapT, gapB, narrow } = cfg;
  // One row per node, in authored (chronological) order — appending a node
  // stretches the drawing; nothing else needs retuning.
  const nodes = ROADMAP.map((n, i) => ({ ...n, row: i, y: top + i * rowH }));
  const trunk = nodes.filter((n) => !n.branch);
  trunk.forEach((n, ti) => { n.ti = ti; n.x = railX + sway[ti % sway.length]; });
  const H = top + (nodes.length - 1) * rowH + pad;
  const trunkAtRow = {};
  trunk.forEach((n) => { trunkAtRow[n.row] = n; });
  const key = (d) => (d === 'ahead' ? '9999-99-99' : d);
  const stemFor = (d) => { let s = trunk[0]; for (const t of trunk) if (key(t.date) <= key(d)) s = t; return s; };
  const lastRow = {};
  for (const n of nodes) if (n.branch) lastRow[n.branch] = n.row;

  // Superseded rows keep the reduced-opacity hierarchy (.sup) — no tag line;
  // an empty note emits nothing, never an empty <text>.
  const label = (n, x, anchor) => {
    const sup = n.status === 'superseded';
    let t = `<g class="lb${sup ? ' sup' : ''}">`;
    t += `<text class="l-date" x="${x}" y="${r1(n.y - 16)}" text-anchor="${anchor}">${n.date === 'ahead' ? 'ahead' : n.date}</text>`;
    t += `<text class="l-title" x="${x}" y="${r1(n.y + 5)}" text-anchor="${anchor}">${esc(n.title)}</text>`;
    if (n.note) t += `<text class="l-note" x="${x}" y="${r1(n.y + 23)}" text-anchor="${anchor}">${esc(n.note)}</text>`;
    return t + '</g>';
  };
  // Monochrome everywhere; the one color on the page is the live node's ring.
  // No fills baked in — the CSS classes carry every color, so the drawing
  // rethemes with the vars.
  const dot = (n, x) => {
    if (n.status === 'live') return `<circle class="nd ring" cx="${x}" cy="${n.y}" r="10"/><circle class="nd" cx="${x}" cy="${n.y}" r="5.5"/>`;
    if (n.status === 'next') return `<circle class="nd hollow" cx="${x}" cy="${n.y}" r="5"/>`;
    if (n.status === 'era') return `<circle class="nd" cx="${x}" cy="${n.y}" r="6"/>`;
    if (n.status === 'superseded') return `<circle class="nd sup" cx="${x}" cy="${n.y}" r="4"/>`;
    return `<circle class="nd" cx="${x}" cy="${n.y}" r="4.5"/>`;
  };

  const labelSideAt = (r) => (narrow ? 1 : trunkAtRow[r].ti % 2 === 0 ? 1 : -1);
  const band = narrow ? 50 : 48; // clears a full label block: date top ≈ y-26 … note foot ≈ y+27, with margin
  // Thread a strand from → to, pulling in beside the trunk (|offset| < |gapT|)
  // at every trunk row crossed. Rows whose label sits on the strand's side get
  // a straight vertical run past the whole label band; the run is clamped to
  // 45% of the gap to the neighboring point so adjacent rows never kink the
  // curve. Vertical tangents at every joint keep the whole strand C1-smooth.
  const thread = (from, to, xAt, side) => {
    let d = `M ${from.x} ${from.y}`;
    let p = from;
    const vias = [];
    for (let r = from.row + 1; r < to.row; r++) {
      if (trunkAtRow[r]) vias.push({ x: r1(xAt(trunkAtRow[r])), y: trunkAtRow[r].y, pad: labelSideAt(r) === side });
    }
    vias.forEach((v, i) => {
      if (v.pad) {
        const nextY = i + 1 < vias.length ? vias[i + 1].y : to.y;
        const a = { x: v.x, y: r1(v.y - Math.min(band, (v.y - p.y) * 0.45)) };
        const b = { x: v.x, y: r1(v.y + Math.min(band, (nextY - v.y) * 0.45)) };
        d += ' ' + seg(p, a) + ` L ${b.x} ${b.y}`;
        p = b;
      } else {
        const q = { x: v.x, y: v.y };
        d += ' ' + seg(p, q);
        p = q;
      }
    });
    return d + ' ' + seg(p, to);
  };

  const units = [];
  const tipOf = {}; // branch name → last drawn point
  for (const n of nodes) {
    if (!n.branch) {
      const prev = n.ti > 0 ? trunk[n.ti - 1] : null;
      const dash = n.status === 'next';
      const side = narrow ? 1 : n.ti % 2 === 0 ? 1 : -1;
      let g = '';
      if (prev) g += `<path class="ln${dash ? ' dash' : ''}" d="M ${prev.x} ${prev.y} ${seg(prev, n)}" pathLength="1"/>`;
      g += dot(n, n.x) + label(n, n.x + side * gapT, side > 0 ? 'start' : 'end');
      units.push(`<g class="seg">${g}</g>`);
      continue;
    }
    const side = narrow ? 1 : sides[n.branch];
    const sup = n.status === 'superseded';
    const tip = { x: railX + side * lane, y: n.y, row: n.row };
    const from = tipOf[n.branch] || stemFor(n.date);
    const d = thread(from, tip, (t) => t.x + side * pull, side);
    units.push(`<g class="seg"><path class="ln${sup ? ' sup' : ''}" d="${d}" pathLength="1"/>${dot(n, tip.x)}${label(n, tip.x + side * gapB, side > 0 ? 'start' : 'end')}</g>`);
    tipOf[n.branch] = tip;
    if (MERGES[n.branch] && lastRow[n.branch] === n.row) {
      // The fold-back strand hugs the trunk (hug < pull) and lands on the
      // merge node's exact point — the trunk dot paints over the joint.
      const m = trunk.find((t) => t.date === MERGES[n.branch]);
      const hs = hugSides[n.branch] || side;
      const d2 = thread(tip, m, (t) => t.x + hs * hug, hs);
      units.push(`<g class="seg"><path class="ln long${sup ? ' sup' : ''}" d="${d2}" pathLength="1"/></g>`);
    }
  }
  // Era chip anchors as % of the viewBox — the svg scales proportionally, so
  // percentage-positioned HTML tracks its node at any container width.
  // side = where the CHIP sits: always opposite the node's label side.
  const eras = ERAS.map((e) => {
    const t = trunk.find((n) => n.title === e.at);
    return { ...e, x: r1((t.x / W) * 100), y: r1((t.y / H) * 100), side: -labelSideAt(t.row) };
  });
  return {
    svg: `<svg class="tl ${narrow ? 'n' : 'w'}" viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMin meet">${units.join('')}</svg>`,
    eras,
  };
}

// Two bakes of the same data: wide alternates label sides around a center
// rail; narrow is a single left rail, every label to the right (so every
// chip hangs left). CSS swaps the bakes at 640px.
const bakeWide = draw({
  W: 1000, railX: 500,
  sway: [16, -26, 24, -18, 26, -22, 12, -24],
  lane: 150,
  sides: { react: -1, particles: 1, universes: -1, lab: 1 },
  hugSides: { universes: -1 },
  pull: 16, hug: 16, rowH: 100, top: 54, pad: 66, gapT: 26, gapB: 14,
  narrow: false,
});
const bakeNarrow = draw({
  W: 420, railX: 52,
  sway: [8, -6, 10, -8, 6, -10, 8, -6],
  lane: 70,
  sides: {},
  hugSides: { universes: -1 },
  pull: 13, hug: 9, rowH: 106, top: 50, pad: 62, gapT: 20, gapB: 13,
  narrow: true,
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#101010" />
    <title>Roadmap — T R E S .</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- sync, pre-paint: sets data-theme before any stylesheet lands -->
    <script is:inline src="/theme.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/cursor.css" />
    <!-- tracking: one bootstrap for the whole site (Umami + Clarity + visitor id + self-exclusion) - public/ts.js -->
    <script is:inline defer src="/ts.js"></script>
    <script is:inline>
      /* html.js gates the hidden-at-rest styles: no JS (or PRM) = fully drawn */
      (function () {
        var reduce = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}
        if (!reduce) document.documentElement.classList.add('js');
      })();
    </script>
  </head>
  <body>
    <a class="back" id="back" href="/lab">← lab</a>

    <main class="arch">
      <header class="head">
        <p class="spec">where this has been · where it's going</p>
        <h1 class="name">ROADMAP<span class="ad">.</span></h1>
      </header>
      <div class="map">
        <div class="bake w">
          <Fragment set:html={bakeWide.svg} />
          {bakeWide.eras.map((e) => (
            <div class={`era-w ${e.side < 0 ? 'l' : 'r'}`} style={`left:${e.x}%; top:${e.y}%`}>
              <button class="era" type="button" aria-expanded="false" aria-describedby={`era-w-${e.id}`}>
                <span class="e-pill">{e.id}</span>
              </button>
              <div class="e-card" role="tooltip" id={`era-w-${e.id}`}>{e.text}</div>
            </div>
          ))}
        </div>
        <div class="bake n">
          <Fragment set:html={bakeNarrow.svg} />
          {bakeNarrow.eras.map((e) => (
            <div class={`era-w ${e.side < 0 ? 'l' : 'r'}`} style={`left:${e.x}%; top:${e.y}%`}>
              <button class="era" type="button" aria-expanded="false" aria-describedby={`era-n-${e.id}`}>
                <span class="e-pill">{e.id}</span>
              </button>
              <div class="e-card" role="tooltip" id={`era-n-${e.id}`}>{e.text}</div>
            </div>
          ))}
        </div>
      </div>
    </main>

    <footer class="foot">
      <span>© 2026 Tres Carter</span>
      <a href="/privacy">Privacy</a>
    </footer>

    <style is:inline>
      :root {
        --paper: #FAFAF7; --ink: #101010;
        --soft: rgba(16,16,16,0.5);      /* secondary text */
        --faint: rgba(16,16,16,0.45);    /* labels, meta   */
        --hair: rgba(0,0,0,0.14);        /* hairlines      */
        --tint: rgba(16,16,16,0.04);     /* image wells    */
      }
      html[data-theme="dark"] {
        --paper: #101010; --ink: #FAFAF7;
        --soft: rgba(250,250,247,0.55);
        --faint: rgba(250,250,247,0.45);
        --hair: rgba(255,255,255,0.16);
        --tint: rgba(250,250,247,0.05);
      }
      html[data-theme="red"] {
        --paper: #E0301F; --ink: #0A0A0A;
        --soft: rgba(10,10,10,0.6);
        --faint: rgba(10,10,10,0.5);
        --hair: rgba(0,0,0,0.25);
        --tint: rgba(0,0,0,0.06);
      }
      html { background: var(--paper); }
      body { color: var(--ink); }
      ::selection { background: var(--ink); color: var(--paper); }

      * { margin: 0; box-sizing: border-box; }
      body { font-family: 'Hanken Grotesk', system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
      a { color: inherit; text-decoration: none; }
      .back { position: fixed; z-index: 10; top: var(--y, 14px); left: 6vw; font-family: 'Space Mono', monospace; font-size: 12px; padding: 12px 0; transition: transform 140ms cubic-bezier(0.23,1,0.32,1); }
      .back:active { transform: scale(0.96); }
      @media (hover: hover) and (pointer: fine) { .back:hover { text-decoration: underline; text-underline-offset: 4px; } }
      .back:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }

      .arch { padding: 0 6vw 12svh; }
      .head { padding: clamp(110px, 22vh, 260px) 0 8svh; }
      .spec { font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--faint); }
      .name { font-weight: 800; font-size: clamp(44px, 9vw, 110px); line-height: 1; margin-top: 10px; }
      .ad { color: #FF4D00; }

      .map { max-width: 1000px; margin: 0 auto; padding-top: 2svh; }
      /* each bake hugs its svg, so the era chips' % coords resolve against
         the same box the viewBox scales into */
      .bake { position: relative; }
      .bake.n { display: none; }
      @media (max-width: 640px) { .bake.w { display: none; } .bake.n { display: block; } }
      .tl { display: block; width: 100%; height: auto; }

      .tl .ln { fill: none; stroke: var(--ink); stroke-width: 1.5; stroke-linecap: round; }
      .tl.n .ln { stroke-width: 1.4; }
      /* pathLength="1" on every stroke: dash math is normalized, so neither
         the dashed future segments nor the draw-on reveal ever needs a
         measured length */
      .tl .ln.dash { stroke-dasharray: 0.045 0.038; }
      /* the drawing's colors live here, not in the baked markup — vars retheme it */
      .tl .nd { fill: var(--ink); }
      .tl .nd.ring { fill: none; stroke: #FF4D00; stroke-width: 2; } /* the page's one color — reads on both papers */
      .tl .nd.hollow { fill: var(--paper); stroke: var(--ink); stroke-width: 1.5; }
      .tl text { font-family: 'Hanken Grotesk', system-ui, sans-serif; }
      .tl .l-date { font-family: 'Space Mono', monospace; font-size: 10.5px; letter-spacing: 0.12em; fill: var(--faint); }
      .tl .l-title { font-size: 15px; font-weight: 800; fill: var(--ink); }
      .tl .l-note { font-size: 12.5px; fill: var(--soft); }
      .tl.n .l-date { font-size: 10px; }
      .tl.n .l-title { font-size: 14px; }
      .tl.n .l-note { font-size: 11.5px; }
      .tl .sup { opacity: 0.55; --lo: 0.55; }

      /* era chips — HTML riding the svg. The wrapper is a 0×0 anchor pinned
         to the trunk node; chip and card hang off it on the side opposite
         that node's label */
      .era-w { position: absolute; width: 0; height: 0; z-index: 5; font-family: 'Space Mono', monospace; }
      /* transparent padding lifts the 24px pill to a 44px hit target */
      .era { position: absolute; top: 0; translate: 0 -50%; display: block; background: none; border: 0; margin: 0; padding: 10px 8px; cursor: pointer; color: inherit; font: inherit; }
      .era-w.l .era { right: 10px; }
      .era-w.r .era { left: 10px; }
      .e-pill { display: block; font-family: 'Space Mono', monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.08em; line-height: 1; padding: 6px 10px; border: 1px solid var(--ink); border-radius: 999px; background: var(--paper); transition: background 120ms ease, color 120ms ease; }
      .era[aria-expanded="true"] .e-pill { background: var(--ink); color: var(--paper); }
      @media (hover: hover) and (pointer: fine) { .era:hover .e-pill { background: var(--ink); color: var(--paper); } }
      .era:focus-visible { outline: none; }
      .era:focus-visible .e-pill { outline: 2px solid var(--ink); outline-offset: 3px; }
      .e-card { position: absolute; top: 22px; width: max-content; max-width: 30ch; font-size: 11px; line-height: 1.6; background: var(--paper); border: 1px solid var(--ink); border-radius: 10px; padding: 10px 12px; opacity: 0; visibility: hidden; transition: opacity 120ms ease, visibility 120ms; z-index: 6; }
      /* the card opens below the chip, extending AWAY from the drawing —
         both bakes keep >60px of slack to the viewport edge at every width
         their media query serves */
      .era-w.l .e-card { right: 10px; }
      .era-w.r .e-card { left: 10px; }
      /* narrow: every chip hangs left of the rail, so the card must open
         rightward below the chip or it leaves the viewport */
      .bake.n .e-card { left: -4px; right: auto; }
      .era:focus-visible + .e-card,
      .era[aria-expanded="true"] + .e-card { opacity: 1; visibility: visible; }
      @media (hover: hover) { .era-w:hover .e-card { opacity: 1; visibility: visible; } }

      .foot { display: flex; justify-content: space-between; padding: 3svh 6vw 4svh; border-top: 1px solid var(--hair); font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; }
    </style>

    <style is:inline>
      /* Draw-on: hidden-at-rest lives ONLY under html.js + no-preference —
         PRM and no-JS both land on the fully drawn page with zero motion */
      @media (prefers-reduced-motion: no-preference) {
        html.js .seg .ln { stroke-dasharray: 1; stroke-dashoffset: 1; transition: stroke-dashoffset 950ms cubic-bezier(0.23,1,0.32,1); }
        html.js .seg .ln.long { transition-duration: 1500ms; }
        html.js .seg .ln.dash { stroke-dasharray: 0.045 0.038; stroke-dashoffset: 0; opacity: 0; transition: opacity 700ms ease 150ms; }
        html.js .seg .lb, html.js .seg .nd { opacity: 0; transform: translateY(8px); transition: opacity 600ms ease 260ms, transform 600ms cubic-bezier(0.23,1,0.32,1) 260ms; }
        html.js .seg.on .ln { stroke-dashoffset: 0; }
        html.js .seg.on .ln.dash { opacity: 1; }
        html.js .seg.on .lb, html.js .seg.on .nd { opacity: var(--lo, 1); transform: none; }
      }
      @media (prefers-reduced-motion: reduce) {
        .back { transition: none; }
        .back:active { transform: none; }
        .e-pill, .e-card { transition: none; } /* era cards show/hide instantly */
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
    </script>
    <script is:inline>
      (function () {
        var reduce = false, fine = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; fine = matchMedia('(hover: hover) and (pointer: fine)').matches; } catch (e) {}
        if (!fine || reduce) return;
        var back = document.getElementById('back');
        var target = null, cur = null, raf = null;
        function frame() {
          cur += (target - cur) * 0.09;
          back.style.setProperty('--y', cur.toFixed(1) + 'px');
          if (Math.abs(target - cur) > 0.4) raf = requestAnimationFrame(frame); else raf = null;
        }
        addEventListener('pointermove', function (e) {
          if (e.pointerType === 'touch') return; /* hybrids: taps must not move it */
          var h = back.offsetHeight;
          target = Math.min(innerHeight - h - 12, Math.max(12, e.clientY - h / 2));
          if (cur === null) cur = target;
          if (!raf) raf = requestAnimationFrame(frame);
        }, { passive: true });
      })();
    </script>
    <script is:inline>
      (function () {
        if (!document.documentElement.classList.contains('js')) return;
        /* Draw-on-scroll WITHOUT IntersectionObserver: the segs are SVG <g>
           elements, and iOS Safari never fires IO for those (empty target
           rects — a 0.2 threshold that can't be crossed — a timeline that
           stays invisible). getBoundingClientRect works everywhere, and its
           failure mode is the right way round: an empty rect reveals the
           seg immediately instead of never. The display:none bake's segs
           read as 0-rects and reveal "instantly" — so a mid-session
           viewport swap shows a fully drawn timeline, which beats a blank. */
        var left = [];
        var segs = document.querySelectorAll('.seg');
        for (var i = 0; i < segs.length; i++) left.push(segs[i]);
        var raf = null;
        function check() {
          raf = null;
          var limit = innerHeight * 0.92;
          for (var i = left.length - 1; i >= 0; i--) {
            if (left[i].getBoundingClientRect().top < limit) {
              left[i].classList.add('on');
              left.splice(i, 1);
            }
          }
          if (!left.length) {
            removeEventListener('scroll', queue);
            removeEventListener('resize', queue);
          }
        }
        function queue() { if (!raf) raf = requestAnimationFrame(check); }
        addEventListener('scroll', queue, { passive: true });
        addEventListener('resize', queue, { passive: true });
        check();
      })();
    </script>
    <script is:inline>
      (function () {
        /* touch has no hover: a tap toggles the chip's card (aria-expanded
           drives the CSS); outside click or Escape closes whatever is open */
        var chips = document.querySelectorAll('.era');
        function closeAll(except) {
          for (var i = 0; i < chips.length; i++) if (chips[i] !== except) chips[i].setAttribute('aria-expanded', 'false');
        }
        for (var i = 0; i < chips.length; i++) {
          chips[i].addEventListener('click', function () {
            var open = this.getAttribute('aria-expanded') === 'true';
            closeAll(this);
            this.setAttribute('aria-expanded', open ? 'false' : 'true');
          });
        }
        document.addEventListener('click', function (e) {
          if (e.target.closest && e.target.closest('.era-w')) return;
          closeAll(null);
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') closeAll(null);
        });
      })();
    </script>
  </body>
</html>
