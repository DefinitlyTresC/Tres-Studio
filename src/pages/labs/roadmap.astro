---
// Roadmap — the site's history + future as one growing, branching drawing.
// Everything below is baked at build time from the ROADMAP array; the client
// gets hand-tuned SVG and one small reveal script, no data fetch, no libraries.

// — append here; the drawing grows with the data
// { date: 'YYYY-MM-DD' | 'ahead', title, note (one line), branch?, status }
// status: 'era' | 'shipped' | 'superseded' | 'live' | 'next'
// Trunk = no branch. Branches stem from the nearest trunk node by date.
// Dates are grounded in REBRAND.md + git history — never invented.
const ROADMAP = [
  { date: '2026-05-15', title: 'the first site', note: 'hand-built html/css/js — no framework, no build', status: 'era' },
  { date: '2026-05-31', title: 'the react rebuild', note: 'react three fiber — built, judged, shelved', branch: 'react', status: 'superseded' },
  { date: '2026-05-31', title: 'the dot cloud', note: 'one cloud of dots re-forms the site on scroll', branch: 'particles', status: 'superseded' },
  { date: '2026-06-01', title: 'the 80k proto', note: 'three.js — now hangs at /alternates/dot/', branch: 'particles', status: 'superseded' },
  { date: '2026-07-03', title: 'astro + the multiverse', note: 'sheet baked at build; one random front door', status: 'era' },
  { date: '2026-07-03', title: 'seven universes', note: 'six at the cutover — the drop makes seven', branch: 'universes', status: 'superseded' },
  { date: '2026-07-11', title: 'universe 08 + epoch 2', note: 'the drop joins the roll; the counter resets', status: 'shipped' },
  { date: '2026-07-12', title: 'lab, multiverse edition', note: 'every experiment adopted by a universe', status: 'shipped' },
  { date: '2026-07-12', title: 'seven sims, rebuilt', note: "ground-up, in the adopted universe's brand", branch: 'lab', status: 'shipped' },
  { date: '2026-07-20', title: 'v3.0 — the collapse', note: 'one site — zero gravity', status: 'live' },
  { date: '2026-07-20', title: 'lab v3 — six doors', note: 'the hall goes zero-g; every door floats', branch: 'lab', status: 'shipped' },
  { date: 'ahead', title: 'the plugin shelf, stocked', note: 'pyrevit extensions, listed from a folder', status: 'next' },
  { date: 'ahead', title: 'the satisfactory dock', note: 'the factory, visualized', status: 'next' },
  { date: 'ahead', title: 'slot six — unnamed', note: 'a door with no name on it yet', status: 'next' },
];

// A branch that returns: its strand folds back into the trunk node at this date.
const MERGES = { universes: '2026-07-20' };

const ZG = ['#FF4D00', '#2431FF', '#00934D', '#E62E8A', '#7A1FE0', '#F0A400'];
const INK = '#101010';
const PAPER = '#FAFAF7';

const r1 = (v) => Math.round(v * 10) / 10;
const esc = (s) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
// Every joint keeps vertical tangents, so chained segments stay C1-smooth —
// the trunk reads as one continuous swaying stroke even though each segment
// is its own path (the reveal animation needs them separate).
const seg = (a, b) => {
  const k = (b.y - a.y) * 0.5;
  return `C ${a.x} ${r1(a.y + k)} ${b.x} ${r1(b.y - k)} ${b.x} ${b.y}`;
};

function draw(cfg) {
  const { W, railX, sway, lane, sides, hugSides, pull, hug, rowH, top, pad, gapT, gapB, narrow } = cfg;
  // One row per node, in authored (chronological) order — appending a node
  // stretches the drawing; nothing else needs retuning.
  const nodes = ROADMAP.map((n, i) => ({ ...n, row: i, y: top + i * rowH }));
  const trunk = nodes.filter((n) => !n.branch);
  trunk.forEach((n, ti) => { n.ti = ti; n.x = railX + sway[ti % sway.length]; });
  const H = top + (nodes.length - 1) * rowH + pad;
  const trunkAtRow = {};
  trunk.forEach((n) => { trunkAtRow[n.row] = n; });
  const key = (d) => (d === 'ahead' ? '9999-99-99' : d);
  const stemFor = (d) => { let s = trunk[0]; for (const t of trunk) if (key(t.date) <= key(d)) s = t; return s; };
  const lastRow = {};
  for (const n of nodes) if (n.branch) lastRow[n.branch] = n.row;

  const label = (n, x, anchor) => {
    const sup = n.status === 'superseded';
    let t = `<g class="lb${sup ? ' sup' : ''}">`;
    t += `<text class="l-date" x="${x}" y="${r1(n.y - 16)}" text-anchor="${anchor}">${n.date === 'ahead' ? 'ahead' : n.date}</text>`;
    t += `<text class="l-title" x="${x}" y="${r1(n.y + 5)}" text-anchor="${anchor}">${esc(n.title)}</text>`;
    t += `<text class="l-note" x="${x}" y="${r1(n.y + 23)}" text-anchor="${anchor}">${esc(n.note)}</text>`;
    if (sup) t += `<text class="l-tag" x="${x}" y="${r1(n.y + 40)}" text-anchor="${anchor}">superseded</text>`;
    return t + '</g>';
  };
  // Monochrome everywhere; the one color on the page is the live node's ring.
  const dot = (n, x) => {
    if (n.status === 'live') return `<circle class="nd" cx="${x}" cy="${n.y}" r="10" fill="none" stroke="${ZG[0]}" stroke-width="2"/><circle class="nd" cx="${x}" cy="${n.y}" r="5.5" fill="${INK}"/>`;
    if (n.status === 'next') return `<circle class="nd" cx="${x}" cy="${n.y}" r="5" fill="${PAPER}" stroke="${INK}" stroke-width="1.5"/>`;
    if (n.status === 'era') return `<circle class="nd" cx="${x}" cy="${n.y}" r="6" fill="${INK}"/>`;
    if (n.status === 'superseded') return `<circle class="nd sup" cx="${x}" cy="${n.y}" r="4" fill="${INK}"/>`;
    return `<circle class="nd" cx="${x}" cy="${n.y}" r="4.5" fill="${INK}"/>`;
  };

  const labelSideAt = (r) => (narrow ? 1 : trunkAtRow[r].ti % 2 === 0 ? 1 : -1);
  const band = narrow ? 50 : 48; // label block: date top ≈ y-26 … tag foot ≈ y+44
  // Thread a strand from → to, pulling in beside the trunk (|offset| < |gapT|)
  // at every trunk row crossed. Rows whose label sits on the strand's side get
  // a straight vertical run past the whole label band; the run is clamped to
  // 45% of the gap to the neighboring point so adjacent rows never kink the
  // curve. Vertical tangents at every joint keep the whole strand C1-smooth.
  const thread = (from, to, xAt, side) => {
    let d = `M ${from.x} ${from.y}`;
    let p = from;
    const vias = [];
    for (let r = from.row + 1; r < to.row; r++) {
      if (trunkAtRow[r]) vias.push({ x: r1(xAt(trunkAtRow[r])), y: trunkAtRow[r].y, pad: labelSideAt(r) === side });
    }
    vias.forEach((v, i) => {
      if (v.pad) {
        const nextY = i + 1 < vias.length ? vias[i + 1].y : to.y;
        const a = { x: v.x, y: r1(v.y - Math.min(band, (v.y - p.y) * 0.45)) };
        const b = { x: v.x, y: r1(v.y + Math.min(band, (nextY - v.y) * 0.45)) };
        d += ' ' + seg(p, a) + ` L ${b.x} ${b.y}`;
        p = b;
      } else {
        const q = { x: v.x, y: v.y };
        d += ' ' + seg(p, q);
        p = q;
      }
    });
    return d + ' ' + seg(p, to);
  };

  const units = [];
  const tipOf = {}; // branch name → last drawn point
  for (const n of nodes) {
    if (!n.branch) {
      const prev = n.ti > 0 ? trunk[n.ti - 1] : null;
      const dash = n.status === 'next';
      const side = narrow ? 1 : n.ti % 2 === 0 ? 1 : -1;
      let g = '';
      if (prev) g += `<path class="ln${dash ? ' dash' : ''}" d="M ${prev.x} ${prev.y} ${seg(prev, n)}" pathLength="1"/>`;
      g += dot(n, n.x) + label(n, n.x + side * gapT, side > 0 ? 'start' : 'end');
      units.push(`<g class="seg">${g}</g>`);
      continue;
    }
    const side = narrow ? 1 : sides[n.branch];
    const sup = n.status === 'superseded';
    const tip = { x: railX + side * lane, y: n.y, row: n.row };
    const from = tipOf[n.branch] || stemFor(n.date);
    const d = thread(from, tip, (t) => t.x + side * pull, side);
    units.push(`<g class="seg"><path class="ln${sup ? ' sup' : ''}" d="${d}" pathLength="1"/>${dot(n, tip.x)}${label(n, tip.x + side * gapB, side > 0 ? 'start' : 'end')}</g>`);
    tipOf[n.branch] = tip;
    if (MERGES[n.branch] && lastRow[n.branch] === n.row) {
      // The fold-back strand hugs the trunk (hug < pull) and lands on the
      // merge node's exact point — the trunk dot paints over the joint.
      const m = trunk.find((t) => t.date === MERGES[n.branch]);
      const hs = hugSides[n.branch] || side;
      const d2 = thread(tip, m, (t) => t.x + hs * hug, hs);
      units.push(`<g class="seg"><path class="ln long${sup ? ' sup' : ''}" d="${d2}" pathLength="1"/></g>`);
    }
  }
  return `<svg class="tl ${narrow ? 'n' : 'w'}" viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMin meet">${units.join('')}</svg>`;
}

// Two bakes of the same data: wide alternates label sides around a center
// rail; narrow is a single left rail, every label to the right. CSS swaps
// them at 640px.
const svgWide = draw({
  W: 1000, railX: 500,
  sway: [16, -26, 24, -18, 26, -22, 12, -24],
  lane: 150,
  sides: { react: -1, particles: 1, universes: -1, lab: 1 },
  hugSides: { universes: -1 },
  pull: 16, hug: 16, rowH: 100, top: 54, pad: 66, gapT: 26, gapB: 14,
  narrow: false,
});
const svgNarrow = draw({
  W: 420, railX: 52,
  sway: [8, -6, 10, -8, 6, -10, 8, -6],
  lane: 70,
  sides: {},
  hugSides: { universes: -1 },
  pull: 13, hug: 9, rowH: 106, top: 50, pad: 62, gapT: 20, gapB: 13,
  narrow: true,
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FAFAF7" />
    <title>Roadmap — T R E S .</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <!-- tracking: one bootstrap for the whole site (Umami + Clarity + visitor id + self-exclusion) - public/ts.js -->
    <script is:inline defer src="/ts.js"></script>
    <script is:inline>
      /* html.js gates the hidden-at-rest styles: no JS (or PRM) = fully drawn */
      (function () {
        var reduce = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}
        if (!reduce && 'IntersectionObserver' in window) document.documentElement.classList.add('js');
      })();
    </script>
  </head>
  <body>
    <a class="back" id="back" href="/lab">← lab</a>

    <main class="arch">
      <header class="head">
        <p class="spec">where this has been · where it's going</p>
        <h1 class="name">ROADMAP<span class="ad">.</span></h1>
      </header>
      <div class="map">
        <Fragment set:html={svgWide} />
        <Fragment set:html={svgNarrow} />
      </div>
    </main>

    <footer class="foot">
      <span>© 2026 Tres Carter</span>
      <a href="/privacy">Privacy</a>
    </footer>

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }
      html { background: #FAFAF7; }
      body { font-family: 'Hanken Grotesk', system-ui, sans-serif; color: #101010; -webkit-font-smoothing: antialiased; }
      ::selection { background: #101010; color: #FAFAF7; }
      a { color: inherit; text-decoration: none; }
      .back { position: fixed; z-index: 10; top: var(--y, 14px); left: 6vw; font-family: 'Space Mono', monospace; font-size: 12px; padding: 12px 0; transition: transform 140ms cubic-bezier(0.23,1,0.32,1); }
      .back:active { transform: scale(0.96); }
      @media (hover: hover) and (pointer: fine) { .back:hover { text-decoration: underline; text-underline-offset: 4px; } }
      .back:focus-visible { outline: 2px solid #101010; outline-offset: 3px; }

      .arch { padding: 0 6vw 12svh; }
      .head { padding: clamp(110px, 22vh, 260px) 0 8svh; }
      .spec { font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(16,16,16,0.45); }
      .name { font-weight: 800; font-size: clamp(44px, 9vw, 110px); line-height: 1; margin-top: 10px; }
      .ad { color: #FF4D00; }

      .map { max-width: 1000px; margin: 0 auto; padding-top: 2svh; }
      .tl { display: block; width: 100%; height: auto; }
      .tl.n { display: none; }
      @media (max-width: 640px) { .tl.w { display: none; } .tl.n { display: block; } }

      .tl .ln { fill: none; stroke: #101010; stroke-width: 1.5; stroke-linecap: round; }
      .tl.n .ln { stroke-width: 1.4; }
      /* pathLength="1" on every stroke: dash math is normalized, so neither
         the dashed future segments nor the draw-on reveal ever needs a
         measured length */
      .tl .ln.dash { stroke-dasharray: 0.045 0.038; }
      .tl text { font-family: 'Hanken Grotesk', system-ui, sans-serif; }
      .tl .l-date { font-family: 'Space Mono', monospace; font-size: 10.5px; letter-spacing: 0.12em; fill: rgba(16,16,16,0.45); }
      .tl .l-title { font-size: 15px; font-weight: 800; fill: #101010; }
      .tl .l-note { font-size: 12.5px; fill: rgba(16,16,16,0.55); }
      .tl .l-tag { font-family: 'Space Mono', monospace; font-size: 9px; letter-spacing: 0.14em; fill: rgba(16,16,16,0.45); }
      .tl.n .l-date { font-size: 10px; }
      .tl.n .l-title { font-size: 14px; }
      .tl.n .l-note { font-size: 11.5px; }
      .tl.n .l-tag { font-size: 8.5px; }
      .tl .sup { opacity: 0.55; --lo: 0.55; }

      .foot { display: flex; justify-content: space-between; padding: 3svh 6vw 4svh; border-top: 1px solid rgba(0,0,0,0.14); font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; }
    </style>

    <style is:inline>
      /* Draw-on: hidden-at-rest lives ONLY under html.js + no-preference —
         PRM and no-JS both land on the fully drawn page with zero motion */
      @media (prefers-reduced-motion: no-preference) {
        html.js .seg .ln { stroke-dasharray: 1; stroke-dashoffset: 1; transition: stroke-dashoffset 950ms cubic-bezier(0.23,1,0.32,1); }
        html.js .seg .ln.long { transition-duration: 1500ms; }
        html.js .seg .ln.dash { stroke-dasharray: 0.045 0.038; stroke-dashoffset: 0; opacity: 0; transition: opacity 700ms ease 150ms; }
        html.js .seg .lb, html.js .seg .nd { opacity: 0; transform: translateY(8px); transition: opacity 600ms ease 260ms, transform 600ms cubic-bezier(0.23,1,0.32,1) 260ms; }
        html.js .seg.on .ln { stroke-dashoffset: 0; }
        html.js .seg.on .ln.dash { opacity: 1; }
        html.js .seg.on .lb, html.js .seg.on .nd { opacity: var(--lo, 1); transform: none; }
      }
      @media (prefers-reduced-motion: reduce) {
        .back { transition: none; }
        .back:active { transform: none; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
    </script>
    <script is:inline>
      (function () {
        var reduce = false, fine = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; fine = matchMedia('(hover: hover) and (pointer: fine)').matches; } catch (e) {}
        if (!fine || reduce) return;
        var back = document.getElementById('back');
        var target = null, cur = null, raf = null;
        function frame() {
          cur += (target - cur) * 0.09;
          back.style.setProperty('--y', cur.toFixed(1) + 'px');
          if (Math.abs(target - cur) > 0.4) raf = requestAnimationFrame(frame); else raf = null;
        }
        addEventListener('pointermove', function (e) {
          if (e.pointerType === 'touch') return; /* hybrids: taps must not move it */
          var h = back.offsetHeight;
          target = Math.min(innerHeight - h - 12, Math.max(12, e.clientY - h / 2));
          if (cur === null) cur = target;
          if (!raf) raf = requestAnimationFrame(frame);
        }, { passive: true });
      })();
    </script>
    <script is:inline>
      (function () {
        if (!document.documentElement.classList.contains('js')) return;
        var io = new IntersectionObserver(function (entries) {
          for (var i = 0; i < entries.length; i++) {
            if (!entries[i].isIntersecting) continue;
            entries[i].target.classList.add('on');
            io.unobserve(entries[i].target);
          }
        }, { threshold: 0.2, rootMargin: '0px 0px -8% 0px' });
        /* both bakes are observed; the display:none one never intersects
           until a resize swaps it in, then it draws on scroll like normal */
        var segs = document.querySelectorAll('.seg');
        for (var i = 0; i < segs.length; i++) io.observe(segs[i]);
      })();
    </script>
  </body>
</html>
