---
// Site 6 — "the hang." A gallery: one collection of 13 flat pigment blocks
// (the letterforms of TRES + the brand's orange period-dot) rehung into six
// compositions as you walk the show — TRES, a construction (work), sediment
// (archive), an orbit (lab), a self-portrait (about), then the storage rack
// as the info sheet rises. Colors are chance-assigned per visit (after
// Kelly, 1951); the wall-label number is the visit's seed. Placards are the
// doors. Scrubbed motion rides one damped follower (smoothness contract).
// Blocks are server-rendered seated in composition 0 so no-JS still shows
// the identity moment; JS recolors, disassembles, and runs the walk.
import { MV_CLIENT } from '../../lib/multiverse';

// ── the collection ─────────────────────────────────────────────────────────
// 13 blocks. Per keyframe per block: [x, y, w, h, rot, tl, tr, br, bl]
// x/y/w/h in % of the stage box; corner radii 0..1 of min(w,h)/2.
// Block roles are stable: 0 T-bar · 1 T-stem · 2 R-stem · 3 R-bowl ·
// 4 R-leg · 5 E-stem · 6 E-top · 7 E-mid · 8 E-bot · 9 S-top · 10 S-mid ·
// 11 S-bot · 12 the period (always #FF5A1F, always the smallest voice).
const KF = [
  { // 0 — TRES (the identity moment)
    b: [
      [3, 24, 18, 10, 0, 0, 0, 0, 0],
      [9.5, 37, 6, 35, 0, 0, 0, 0, 0],
      [24, 24, 6, 48, 0, 0, 0, 0, 0],
      [32.5, 24, 8.5, 19, 0, 0, 1, 1, 0],
      [32.5, 48, 5.5, 25, 21, 0, 0, 0, 0],
      [44, 24, 6, 48, 0, 0, 0, 0, 0],
      [52.5, 24, 9, 10, 0, 0, 0, 0, 0],
      [52.5, 44.5, 7.5, 8, 0, 0, 0, 0, 0],
      [52.5, 62, 9, 10, 0, 0, 0, 0, 0],
      [66.5, 24, 15.5, 10, 0, 1, 0, 0, 1],
      [64.5, 42.5, 15.5, 10, 0, 0, 0, 0, 0],
      [62.5, 60.5, 17.5, 11.5, 0, 0, 1, 1, 0],
      [86, 62, 5, 9, 0, 1, 1, 1, 1],
    ],
    m: [
      [6, 8, 38, 7, 0, 0, 0, 0, 0],
      [19, 18, 12, 21, 0, 0, 0, 0, 0],
      [54, 8, 11, 31, 0, 0, 0, 0, 0],
      [68, 8, 17, 11, 0, 0, 1, 1, 0],
      [68, 23, 10, 15, 21, 0, 0, 0, 0],
      [6, 50, 11, 31, 0, 0, 0, 0, 0],
      [20.5, 50, 20, 7, 0, 0, 0, 0, 0],
      [20.5, 61.5, 16, 6.5, 0, 0, 0, 0, 0],
      [20.5, 74, 20, 7, 0, 0, 0, 0, 0],
      [56, 50, 26, 7, 0, 1, 0, 0, 1],
      [53.5, 61.5, 26, 7, 0, 0, 0, 0, 0],
      [51, 73.5, 29, 8.5, 0, 0, 1, 1, 0],
      [84, 64, 9, 5.5, 0, 1, 1, 1, 1],
    ],
  },
  { // 1 — construction in five parts (work)
    b: [
      [8, 79, 58, 8, 0, 0, 0, 0, 0],
      [13, 48, 6, 28, 0, 0, 0, 0, 0],
      [31, 48, 6, 28, 0, 0, 0, 0, 0],
      [15, 17, 20, 16, 0, 0, 0, 0, 0],
      [23, 51, 5, 22, -28, 0, 0, 0, 0],
      [49, 48, 6, 28, 0, 0, 0, 0, 0],
      [10, 37, 50, 8, 0, 0, 0, 0, 0],
      [39, 21, 12, 12, 0, 0, 0, 0, 0],
      [63, 60, 8, 16, 0, 0, 0, 0, 0],
      [53, 26, 21, 6, 0, 0, 0, 0, 0],
      [68, 82, 16, 5, 0, 0, 0, 0, 0],
      [81, 20, 4, 59, 0, 0, 0, 0, 0],
      [76, 13, 4, 7, 0, 1, 1, 1, 1],
    ],
  },
  { // 2 — everything else, in layers (archive)
    b: [
      [8, 20, 62, 4.5, 0, 0, 0, 0, 0],
      [26, 27.5, 66, 7, 0, 0, 0, 0, 0],
      [8, 37.5, 56, 3.5, 0, 0, 0, 0, 0],
      [40, 46, 12, 10, 0, 1, 1, 1, 1],
      [70, 26, 4.5, 13, 14, 0, 0, 0, 0],
      [14, 44, 52, 9, 0, 0, 0, 0, 0],
      [8, 56, 70, 5, 0, 0, 0, 0, 0],
      [32, 64, 60, 7.5, 0, 0, 0, 0, 0],
      [8, 74.5, 58, 4, 0, 0, 0, 0, 0],
      [20, 81.5, 64, 8, 0, 0, 0, 0, 0],
      [56, 46, 30, 5, 0, 0, 0, 0, 0],
      [8, 64, 20, 7.5, 0, 0, 0, 0, 0],
      [85, 11, 4, 7, 0, 1, 1, 1, 1],
    ],
  },
  { // 3 — controlled experiments (lab)
    b: [
      [18, 19, 24, 6, -27, 1, 1, 1, 1],
      [10, 35, 5, 24, 0, 0, 0, 0, 0],
      [13, 74, 6, 15, 0, 0, 0, 0, 0],
      [42, 36, 16, 28.5, 0, 1, 1, 1, 1],
      [49, 8, 5, 16, 44, 0, 0, 0, 0],
      [78, 13, 5, 17, 0, 0, 0, 0, 0],
      [58, 22, 19, 6, 21, 1, 1, 1, 1],
      [24, 6, 7, 11, 0, 0, 0, 0, 0],
      [69, 78, 9, 12, 0, 0, 0, 0, 0],
      [61, 65, 19, 6, -24, 1, 1, 1, 1],
