---
// Site 6 — about. Wall text beside a small hung self-portrait (the same
// bauhaus-bust composition the landing walks through, held still here).
import { MV_CLIENT } from '../../lib/multiverse';

// the bust, re-authored for a 100×100 portrait card
const BUST = [
  ['#2E5EA8', [26, 52, 48, 12, 0, '0']],
  ['#1F8A70', [42, 40, 6, 10, 0, '0']],
  ['#E3B71F', [37, 12, 26, 26, 0, '999px']],
  ['#C7356B', [30, 66, 40, 24, 0, '0']],
  ['#E8442E', [10, 14, 10, 30, 0, '999px 0 0 999px']],
  ['#6B4C9A', [80, 14, 10, 30, 0, '0 999px 999px 0']],
  ['#141310', [24, 92, 52, 4, 0, '0']],
  ['#FF5A1F', [43.5, 22, 5, 5, 0, '999px']],
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FAF8F3" />
    <title>ABOUT — 06 TRES CARTER</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Schibsted+Grotesk:wght@400;500;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <script is:inline set:html={MV_CLIENT(6)} />
  </head>
  <body>
    <a class="back" id="back" href="/6/">← index</a>
    <span class="tag" aria-hidden="true">cat. 06.3 — wall text</span>
    <main class="room">
      <div class="text">
        <p class="spec">wall text</p>
        <h1 class="statement">Tres Carter is an architectural designer from 30A, Florida. Buildings, pictures, code.</h1>
        <div class="plaq">
          <a href="mailto:tres@tres.studio">tres@tres.studio</a>
          <a href="https://instagram.com/tres.studio" target="_blank" rel="noopener">ig</a>
          <a href="https://www.linkedin.com/in/tres-carter" target="_blank" rel="noopener">linkedin</a>
        </div>
      </div>
      <figure class="port" aria-hidden="true">
        <div class="canvas">
          {BUST.map(([c, g]) => (
            <i style={`left:${g[0]}%;top:${g[1]}%;width:${g[2]}%;height:${g[3]}%;background:${c};border-radius:${g[5]}`} />
          ))}
        </div>
        <figcaption class="cap">self-portrait, after bauhaus · 2026</figcaption>
      </figure>
    </main>

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }
      html { background: #FAF8F3; }
      body { font-family: 'Schibsted Grotesk', system-ui, sans-serif; color: #141310; -webkit-font-smoothing: antialiased; }
      ::selection { background: #141310; color: #FAF8F3; }
      a { color: inherit; text-decoration: none; }
      .tag { position: fixed; top: calc(16px + env(safe-area-inset-top, 0px)); right: calc(20px + env(safe-area-inset-right, 0px)); z-index: 90; pointer-events: none; font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.14em; color: #6B665A; }
      .back { position: fixed; z-index: 10; top: var(--y, 14px); left: calc(20px + env(safe-area-inset-left, 0px)); font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 0.16em; padding: 12px 0; transition: transform 140ms cubic-bezier(0.23,1,0.32,1); }
      .back:active { transform: scale(0.96); }
      @media (hover: hover) and (pointer: fine) { .back:hover { text-decoration: underline; text-underline-offset: 4px; } }
      .back:focus-visible { outline: 2px solid #141310; outline-offset: 3px; }
      .room {
        min-height: 100svh; max-width: 1200px; margin: 0 auto;
        display: grid; grid-template-columns: minmax(0, 7fr) minmax(0, 4fr);
        align-items: center; gap: clamp(28px, 6vw, 90px);
        padding: clamp(90px, 14vh, 160px) 6vw 10svh;
      }
      .spec { font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 0.16em; color: #6B665A; }
      .statement {
        font-weight: 700; font-size: clamp(28px, 4.4vw, 58px); line-height: 1.14;
        letter-spacing: -0.01em; margin-top: 16px; text-wrap: balance;
      }
      .plaq { display: flex; flex-wrap: wrap; gap: 30px; margin-top: 5svh; font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.08em; }
      /* 44px hit areas; padding + negative margin keep the visual rhythm */
      .plaq a { position: relative; z-index: 0; padding: 14px; margin: 0 -14px; }
      .plaq a::after { content: ""; position: absolute; left: 14px; right: calc(100% - 14px); bottom: 10px; height: 3px; background: #FF5A1F; transition: right 200ms cubic-bezier(0.19, 1, 0.22, 1); }
      @media (hover: hover) and (pointer: fine) { .plaq a:hover::after { right: 14px; } }
      .plaq a:focus-visible { outline: 2px solid #141310; outline-offset: 3px; }
      .port { justify-self: center; width: min(100%, 380px); }
      .canvas { position: relative; aspect-ratio: 4 / 5; }
      .canvas i { position: absolute; display: block; }
      .cap { font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.1em; color: #6B665A; margin-top: 14px; }
      @media (max-width: 760px) {
        .room { grid-template-columns: 1fr; align-content: center; gap: 7svh; }
        .port { justify-self: start; width: min(72vw, 300px); }
      }
      @media (prefers-reduced-motion: reduce) {
        .back, .plaq a::after { transition: none; }
        .back:active { transform: none; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
    </script>
    <script is:inline>
      (function () {
        var reduce = false, fine = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; fine = matchMedia('(hover: hover) and (pointer: fine)').matches; } catch (e) {}
        if (!fine || reduce) return;
        var back = document.getElementById('back');
        var target = null, cur = null, raf = null;
        function frame() {
          cur += (target - cur) * 0.09;
          back.style.setProperty('--y', cur.toFixed(1) + 'px');
          if (Math.abs(target - cur) > 0.4) raf = requestAnimationFrame(frame); else raf = null;
        }
        addEventListener('pointermove', function (e) {
          if (e.pointerType === 'touch') return; /* hybrids: taps must not move it */
          var h = back.offsetHeight;
          target = Math.min(innerHeight - h - 12, Math.max(12, e.clientY - h / 2));
          if (cur === null) cur = target;
          if (!raf) raf = requestAnimationFrame(frame);
        }, { passive: true });
      })();
    </script>
  </body>
</html>
