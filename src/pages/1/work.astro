---
// Site 1 — work. The five, in the dense index format.
// R4: hovering a row plows its hero out from the right (desktop only),
// pencil cursor sketches on the page, paper texture, handwritten eyebrow.
import { MV_CLIENT } from '../../lib/multiverse';
import { getCollection } from 'astro:content';
import { joinUrl } from '../../lib/cloudinary';
import Paper from './_paper.astro';
import Pencil from './_pencil.astro';

const WORK = ['z07', 'ee13', 'flatwood', 'tucker', 'thesis'];
const all = (await getCollection('projects')).map((e) => e.data);
const rows = WORK.map((s) => all.find((p) => p.slug === s)).filter(Boolean);
// w_900 covers the ~340px hover preview at 2x; w_1800 would be dead weight.
const pv = (p) => joinUrl(p.heroImage, 'w_900', 'image');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FFEDDB" />
    <title>Work — Tres.</title>
    <link rel="preconnect" href="https://res.cloudinary.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600&family=Caveat:wght@500;600&family=Space+Mono&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/v2-tokens.css" />
    <script is:inline set:html={MV_CLIENT(1)} />
    <!-- tracking: one bootstrap for the whole site (Umami + Clarity + visitor id + self-exclusion) - public/ts.js -->
    <script is:inline defer src="/ts.js"></script>
  </head>
  <body>
    <a class="back" id="back" href="/1/">← index</a>

    <main class="arch">
      <header class="head">
        <p class="spec">— Work · {String(rows.length).padStart(2, '0')} projects</p>
        <h1 class="name">Selected work</h1>
        <span class="annot" aria-hidden="true">selected — 2026</span>
      </header>

      <div class="list">
        {rows.map((p, i) => (
          <a class="row" href={`/1/project/${p.slug}`}>
            <span class="r-no">{String(i + 1).padStart(2, '0')}</span>
            <span class="r-name">{p.name}</span>
            <span class="r-meta">{p.location}</span>
            <span class="r-meta r-year">{p.year}</span>
            {pv(p) && (
              <span class="r-pv" aria-hidden="true">
                <img src={pv(p)} alt="" loading="lazy" decoding="async" />
              </span>
            )}
          </a>
        ))}
      </div>
    </main>

    <footer class="foot">
      <span>© 2026 Tres Carter</span>
      <a href="/privacy">Privacy</a>
    </footer>

    <Paper />
    <Pencil />

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }
      html { background: var(--v2-cream, #FFEDDB); }
      body { font-family: var(--v2-display, 'Archivo', sans-serif); color: var(--v2-ink, #2B1F1A); -webkit-font-smoothing: antialiased; }
      ::selection { background: var(--v2-sand, #EDCDBB); }
      a { color: inherit; text-decoration: none; }

      .back {
        position: fixed; z-index: 10;
        top: var(--y, calc(var(--v2-pad, 24px) * 0.55));
        left: var(--v2-pad, 24px);
        font-family: var(--v2-mono, monospace); font-size: 12px; padding: 12px 0;
        transition: transform var(--v2-press, 140ms) var(--v2-out, ease-out);
      }
      .back:active { transform: scale(0.96); }
      @media (hover: hover) and (pointer: fine) {
        .back:hover { text-decoration: underline; text-underline-offset: 4px; }
      }
      .back:focus-visible { outline: 2px solid var(--v2-ink, #2B1F1A); outline-offset: 3px; }

      .arch { max-width: 1180px; margin: 0 auto; padding: 0 var(--v2-pad, 24px) 10svh; }
      .head { position: relative; padding: clamp(110px, 20vh, 220px) 0 6svh; }
      .spec { font-family: 'Caveat', cursive; font-weight: 500; font-size: 21px; letter-spacing: 0.01em; color: rgba(43, 31, 26, 0.62); }
      .name { font-weight: 600; font-size: clamp(40px, 8.4vw, 96px); line-height: 0.96; text-transform: uppercase; margin-top: 12px; }
      .annot {
        display: none;
        font-family: 'Caveat', cursive; font-weight: 500;
        font-size: 19px; line-height: 1.1; color: rgba(43, 31, 26, 0.62);
        rotate: -2deg;
      }
      @media (min-width: 640px) {
        .annot { display: block; position: absolute; right: 0; bottom: 6.5svh; }
      }

      .list { border-top: 1px solid var(--v2-hairline, rgba(43,31,26,.16)); }
      .row {
        display: grid; position: relative; grid-template-columns: 3ch minmax(0, 1fr) auto auto; gap: 18px; align-items: baseline;
        padding: 26px 0; border-bottom: 1px solid var(--v2-hairline, rgba(43,31,26,.16));
        transition: transform var(--v2-press, 140ms) var(--v2-out, ease-out);
        transform-origin: left center;
      }
      .row:active { transform: scale(0.985); }
      .r-no, .r-meta { font-family: var(--v2-mono, monospace); font-size: 12px; letter-spacing: 0.05em; text-transform: uppercase; color: var(--v2-ink-soft, #6b5c54); }
      .r-name { font-weight: 600; font-size: clamp(24px, 4.2vw, 44px); line-height: 1; text-transform: uppercase; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .r-year { text-align: right; min-width: 4ch; }
      @media (max-width: 560px) { .r-meta:not(.r-year) { display: none; } .row { grid-template-columns: 3ch minmax(0, 1fr) auto; } }

      /* plow-out hero previews — desktop only, hover only, zero layout shift */
      .r-pv { display: none; }
      @media (hover: hover) and (pointer: fine) {
        .r-name { transition: translate 200ms cubic-bezier(0.23, 1, 0.32, 1); }
        .row:hover .r-name { translate: 6px 0; }
        .row { transition: transform var(--v2-press, 140ms) var(--v2-out, ease-out), opacity 240ms var(--v2-out, ease-out); }
        .list:hover .row { opacity: 0.45; }
        .list .row:hover { opacity: 1; z-index: 3; }

        .r-pv {
          display: grid; place-items: center;
          position: absolute; right: 0; top: 50%; translate: 0 -50%;
          width: clamp(220px, 26vw, 340px); aspect-ratio: 4 / 3;
          overflow: hidden; pointer-events: none;
        }
        .r-pv img {
          width: calc(100% - 16px); height: calc(100% - 20px); object-fit: cover;
          outline: 1px solid rgba(0, 0, 0, 0.1); outline-offset: -1px;
          transform: translateX(115%) rotate(3deg);
          transition: transform 480ms cubic-bezier(0.19, 1, 0.22, 1);
        }
        .row:hover .r-pv img { transform: translateX(0) rotate(-2deg); }
      }
      @media (prefers-reduced-motion: reduce) {
        .r-pv img { transition: opacity 180ms ease-out; transform: rotate(-2deg); opacity: 0; }
        .row:hover .r-pv img { transform: rotate(-2deg); opacity: 1; }
        .row, .list:hover .row { transition: opacity 180ms ease-out; }
        .back, .r-name { transition: none; }
        .back:active, .row:active { transform: none; }
      }

      .foot {
        display: flex; justify-content: space-between; align-items: center; gap: 16px;
        max-width: 1180px; margin: 0 auto; padding: 3svh var(--v2-pad, 24px) 4svh;
        border-top: 1px solid var(--v2-hairline, rgba(43,31,26,.16));
        font-family: var(--v2-mono, monospace); font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase;
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
    </script>
    <script is:inline>
      (function () {
        var reduce = false, fine = false;
        try {
          reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
          fine = matchMedia('(hover: hover) and (pointer: fine)').matches;
        } catch (e) {}
        if (!fine || reduce) return;
        var back = document.getElementById('back');
        var target = null, cur = null, raf = null;
        function frame() {
          cur += (target - cur) * 0.09;
          back.style.setProperty('--y', cur.toFixed(1) + 'px');
          if (Math.abs(target - cur) > 0.4) raf = requestAnimationFrame(frame);
          else raf = null;
        }
        addEventListener('pointermove', function (e) {
          if (e.pointerType === 'touch') return; /* hybrids: taps must not move it */
          var h = back.offsetHeight;
          target = Math.min(innerHeight - h - 12, Math.max(12, e.clientY - h / 2));
          if (cur === null) cur = target;
          if (!raf) raf = requestAnimationFrame(frame);
        }, { passive: true });
      })();
    </script>
  </body>
</html>
