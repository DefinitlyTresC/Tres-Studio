---
// Site 1 — about. Same facts as every universe, this site's voice.
// R4: paper texture, handwritten eyebrow, honest press states.
import { MV_CLIENT } from '../../lib/multiverse';
import Paper from './_paper.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FFEDDB" />
    <title>About — Tres.</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600&family=Caveat:wght@500;600&family=Space+Mono&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/v2-tokens.css" />
    <script is:inline set:html={MV_CLIENT(1)} />
  </head>
  <body>
    <a class="back" href="/1/">← back</a>

    <main class="about">
      <p class="spec">— About</p>
      <h1 class="name">Tres<br />Carter<span class="pd">.</span></h1>
      <p class="lede">Architectural designer on 30A, Florida.</p>
      <div class="acts">
        <a href="mailto:tres@tres.studio">tres@tres.studio</a>
        <a href="https://instagram.com/tres.studio" target="_blank" rel="noopener">IG</a>
      </div>
    </main>

    <Paper />

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }
      html, body { overflow-x: hidden; }
      html { background: var(--v2-cream, #FFEDDB); }
      body { font-family: var(--v2-display, 'Archivo', sans-serif); color: var(--v2-ink, #2B1F1A); -webkit-font-smoothing: antialiased; }
      ::selection { background: var(--v2-sand, #EDCDBB); }
      a { color: inherit; text-decoration: none; }
      .back {
        position: fixed; top: calc(var(--v2-pad, 24px) * 0.6); left: var(--v2-pad, 24px);
        font-family: var(--v2-mono, monospace); font-size: 12px; padding: 12px 0;
        transition: transform var(--v2-press, 140ms) var(--v2-out, ease-out);
      }
      .back:active { transform: scale(0.96); }
      .back:focus-visible { outline: 2px solid var(--v2-ink, #2B1F1A); outline-offset: 3px; }
      .about { max-width: 860px; margin: 0 auto; padding: clamp(140px, 26vh, 320px) var(--v2-pad, 24px) 14svh; }
      .spec { font-family: 'Caveat', cursive; font-weight: 500; font-size: 21px; letter-spacing: 0.01em; color: rgba(43, 31, 26, 0.62); }
      .name { font-weight: 600; font-size: clamp(56px, 11vw, 130px); line-height: 0.94; text-transform: uppercase; letter-spacing: -0.015em; margin-top: 14px; }
      .pd { color: var(--v2-umber, #BF9270); }
      .lede { font-size: clamp(19px, 2.6vw, 28px); font-weight: 400; margin-top: 24px; color: var(--v2-ink-soft, #6b5c54); }
      .acts { display: flex; gap: 28px; margin-top: 34px; font-family: var(--v2-mono, monospace); font-size: 13px; }
      .acts a {
        padding: 14px 0;
        transition: transform var(--v2-press, 140ms) var(--v2-out, ease-out);
      }
      .acts a:active { transform: scale(0.96); }
      @media (hover: hover) and (pointer: fine) {
        a:hover { text-decoration: underline; text-underline-offset: 4px; }
      }
    </style>
  </body>
</html>
