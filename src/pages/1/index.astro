---
// Site 1 — landing. Pure identity: the mark, the menu, the info footer.
// No project imagery here (landing rule, 2026-07-02) — work lives at /1/work.
import { MV_CLIENT } from '../../lib/multiverse';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FFEDDB" />
    <title>Tres.</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600&family=Space+Mono&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/v2-tokens.css" />
    <script is:inline set:html={MV_CLIENT(1)} />
  </head>
  <body>
    <header class="hero">
      <h1 class="mark">Tres<span class="pd">.</span></h1>
      <p class="spec">architecture · art · code — 30A</p>
      <p class="cue" aria-hidden="true">scroll</p>
    </header>

    <nav class="menu" aria-label="Sections">
      <a href="/1/work">Work</a>
      <a href="/1/archive">Archive</a>
      <a href="/lab">Lab</a>
      <a href="/1/about">About</a>
      <span class="soon">Plugins — soon</span>
    </nav>

    <footer id="mv-info" class="info">
      <div class="i-top">
        <p class="stmt">Designing across architecture, art, and code<span class="pd">.</span></p>
      </div>
      <div class="i-cols">
        <div class="i-col">
          <span class="lbl">Location</span>
          Seagrove · 30A<br />Florida, USA
        </div>
        <div class="i-col">
          <span class="lbl">Contact</span>
          <a href="mailto:tres@tres.studio">tres@tres.studio</a><br />
          <a href="https://instagram.com/tres.studio" target="_blank" rel="noopener">IG</a>
        </div>
        <div class="i-col">
          <span class="lbl">Sections</span>
          <a href="/1/work">Work</a><br />
          <a href="/1/archive">Archive</a><br />
          <a href="/lab">Lab</a><br />
          <a href="/1/about">About</a><br />
          <span class="soon">Plugins — soon</span>
        </div>
      </div>
      <div class="i-meta">
        <span>© 2026 Tres Carter</span>
        <span id="mv-ticker-slot"></span>
        <a href="/privacy">Privacy</a>
      </div>
    </footer>

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }
      html, body { overflow-x: hidden; }
      html { background: var(--v2-cream, #FFEDDB); }
      body {
        font-family: var(--v2-display, 'Archivo', sans-serif);
        color: var(--v2-ink, #2B1F1A);
        -webkit-font-smoothing: antialiased;
      }
      ::selection { background: var(--v2-sand, #EDCDBB); }
      a { color: inherit; text-decoration: none; }

      .hero { min-height: 96svh; display: grid; place-content: center; text-align: center; position: relative; padding: var(--v2-pad, 24px); }
      .mark { font-weight: 600; font-size: clamp(72px, 17vw, 210px); line-height: 0.9; text-transform: uppercase; letter-spacing: -0.02em; }
      .pd { color: var(--v2-umber, #BF9270); }
      .spec { font-family: var(--v2-mono, monospace); font-size: 12px; letter-spacing: 0.08em; color: var(--v2-ink-soft, #6b5c54); margin-top: 18px; }
      .cue {
        position: absolute; bottom: calc(var(--v2-pad, 24px) * 0.8); left: 50%; translate: -50% 0;
        font-family: var(--v2-mono, monospace); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
        color: var(--v2-ink-soft, #6b5c54);
      }

      .menu { min-height: 92svh; display: grid; align-content: center; padding: 0 var(--v2-pad, 24px); }
      .menu a, .menu .soon {
        display: block; padding: 3.6svh 0;
        font-weight: 600; font-size: clamp(40px, 9vw, 104px); line-height: 1; text-transform: uppercase;
        border-bottom: 1px solid var(--v2-hairline, rgba(43,31,26,.16));
      }
      .menu a:first-child { border-top: 1px solid var(--v2-hairline, rgba(43,31,26,.16)); }
      .menu .soon { color: var(--v2-ink-soft, #6b5c54); border-bottom: none; }
      @media (hover: hover) and (pointer: fine) {
        .menu a { transition: translate 220ms cubic-bezier(0.23, 1, 0.32, 1); }
        .menu a:hover { translate: 10px 0; }
      }

      .info { min-height: 74svh; display: grid; align-content: end; gap: 7svh; position: relative; padding: 10svh var(--v2-pad, 24px) 4svh; border-top: 1px solid var(--v2-hairline, rgba(43,31,26,.16)); }
      .i-top { display: flex; justify-content: space-between; align-items: baseline; gap: 20px; flex-wrap: wrap; }
      .stmt { font-weight: 600; font-size: clamp(28px, 4.6vw, 52px); line-height: 1.04; max-width: 15ch; text-wrap: balance; }
      .i-cols {
        display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px;
        padding-right: clamp(100px, 24vw, 240px);
        font-family: var(--v2-mono, monospace); font-size: 12px; letter-spacing: 0.05em;
        text-transform: uppercase; line-height: 1.9;
      }
      @media (max-width: 640px) { .i-cols { grid-template-columns: 1fr; } }
      .lbl { display: block; color: var(--v2-ink-soft, #6b5c54); margin-bottom: 6px; }
      .soon { color: var(--v2-ink-soft, #6b5c54); }
      .i-meta {
        display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap;
        border-top: 1px solid var(--v2-hairline, rgba(43,31,26,.16)); padding-top: 16px;
        font-family: var(--v2-mono, monospace); font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase;
      }
      @media (hover: hover) and (pointer: fine) {
        .info a:hover { text-decoration: underline; text-underline-offset: 4px; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
      import('/mv/ring.js');
    </script>
    <script is:inline defer src="/mv/ticker.js"></script>
  </body>
</html>
