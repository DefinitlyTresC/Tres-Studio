---
// Site 1 — cream/espresso/Archivo. CHASSIS STUB: the anchors in skeleton
// form. Grows into the full site next phase.
import { MV_CLIENT } from '../../lib/multiverse';
import { getCollection } from 'astro:content';

const WORK = ['z07', 'ee13', 'flatwood', 'tucker', 'thesis'];
const all = await getCollection('projects');
const work = WORK.map((s) => all.find((p) => p.id === s)?.data).filter(Boolean);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FFEDDB" />
    <title>Tres.</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600&family=Space+Mono&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/v2-tokens.css" />
    <script is:inline set:html={MV_CLIENT(1)} />
  </head>
  <body>
    <header class="hero">
      <h1 class="mark">Tres<span class="pd">.</span></h1>
      <p class="spec">architecture · art · code — 30A</p>
    </header>

    <main class="work">
      {work.map((p, i) => (
        <a class="row" href={`/project/${WORK[i]}`}>
          <span class="row-name">{p.name}</span>
          <span class="row-spec">{p.year}</span>
        </a>
      ))}
      <div class="more">
        <a href="/architecture">archive</a>
        <a href="/lab">lab</a>
        <a href="/" aria-disabled="true">plugins — soon</a>
      </div>
    </main>

    <footer id="mv-info" class="info">
      <div class="i-top">
        <p class="stmt">Designing across architecture, art, and code<span class="pd">.</span></p>
      </div>
      <div class="i-cols">
        <div class="i-col">
          <span class="lbl">Location</span>
          Seagrove · 30A<br />Florida, USA
        </div>
        <div class="i-col">
          <span class="lbl">Contact</span>
          <a href="mailto:tres@tres.studio">tres@tres.studio</a><br />
          <a href="https://instagram.com/tres.studio" target="_blank" rel="noopener">IG</a>
        </div>
        <div class="i-col">
          <span class="lbl">Sections</span>
          <a href="/1/">Work</a><br />
          <a href="/architecture">Archive</a><br />
          <a href="/lab">Lab</a><br />
          <a href="/1/about">About</a><br />
          <span class="soon">Plugins — soon</span>
        </div>
      </div>
      <div class="i-meta">
        <span>© 2026 Tres Carter</span>
        <span id="mv-ticker-slot"></span>
        <a href="/privacy">Privacy</a>
      </div>
    </footer>

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }
      html { background: var(--v2-cream, #FFEDDB); }
      body {
        font-family: var(--v2-display, 'Archivo', sans-serif);
        color: var(--v2-ink, #2B1F1A);
        -webkit-font-smoothing: antialiased;
      }
      ::selection { background: var(--v2-sand, #EDCDBB); }
      a { color: inherit; text-decoration: none; }

      .hero { min-height: 88svh; display: grid; place-content: center; text-align: center; padding: var(--v2-pad, 24px); }
      .mark { font-weight: 600; font-size: clamp(72px, 17vw, 210px); line-height: 0.9; text-transform: uppercase; letter-spacing: -0.02em; }
      .pd { color: var(--v2-umber, #BF9270); }
      .spec { font-family: var(--v2-mono, monospace); font-size: 12px; letter-spacing: 0.08em; color: var(--v2-ink-soft, #6b5c54); margin-top: 18px; }

      .work { max-width: 860px; margin: 0 auto; padding: 6svh var(--v2-pad, 24px) 14svh; }
      .row {
        display: flex; justify-content: space-between; align-items: baseline; gap: 16px;
        padding: 22px 0; border-top: 1px solid var(--v2-hairline, rgba(43,31,26,.16));
      }
      .row-name { font-weight: 600; font-size: clamp(24px, 4.6vw, 44px); text-transform: uppercase; line-height: 1; }
      .row-spec { font-family: var(--v2-mono, monospace); font-size: 12px; color: var(--v2-ink-soft, #6b5c54); }
      @media (hover: hover) and (pointer: fine) {
        .row:hover .row-name { translate: 6px 0; }
        .row-name { transition: translate 200ms cubic-bezier(.23,1,.32,1); }
      }
      .more { display: flex; gap: 28px; padding-top: 34px; font-family: var(--v2-mono, monospace); font-size: 13px; }
      @media (hover: hover) and (pointer: fine) {
        .more a:hover { text-decoration: underline; text-underline-offset: 4px; }
      }

      html, body { overflow-x: hidden; } /* the dot-cluster bleeds off the right edge */
      .info {
        min-height: 74svh; display: grid; align-content: end; gap: 7svh;
        padding: 10svh var(--v2-pad, 24px) 4svh;
        border-top: 1px solid var(--v2-hairline, rgba(43,31,26,.16));
      }
      .i-top { display: flex; justify-content: space-between; align-items: baseline; gap: 20px; flex-wrap: wrap; }
      .stmt { font-weight: 600; font-size: clamp(28px, 4.6vw, 52px); line-height: 1.04; text-transform: none; max-width: 15ch; text-wrap: balance; }
      .i-cols {
        display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px;
        padding-right: clamp(100px, 24vw, 240px); /* room for the map */
        font-family: var(--v2-mono, monospace); font-size: 12px; letter-spacing: 0.05em;
        text-transform: uppercase; line-height: 1.9;
      }
      @media (max-width: 640px) { .i-cols { grid-template-columns: 1fr; } }
      .lbl { display: block; color: var(--v2-ink-soft, #6b5c54); margin-bottom: 6px; }
      .soon { color: var(--v2-ink-soft, #6b5c54); }
      .i-meta {
        display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap;
        border-top: 1px solid var(--v2-hairline, rgba(43,31,26,.16)); padding-top: 16px;
        font-family: var(--v2-mono, monospace); font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase;
      }
      @media (hover: hover) and (pointer: fine) {
        .info a:hover { text-decoration: underline; text-underline-offset: 4px; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
      import('/mv/ring.js');
    </script>
    <script is:inline defer src="/mv/ticker.js"></script>
  </body>
</html>
