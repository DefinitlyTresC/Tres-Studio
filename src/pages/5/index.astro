    <div class="marquee" aria-hidden="true">
      <div class="m-in" id="mq">TRES CARTER — TRES CARTER — TRES CARTER — TRES CARTER — TRES CARTER — TRES CARTER — TRES CARTER — TRES CARTER — TRES CARTER — TRES CARTER — TRES CARTER — TRES CARTER — TRES CARTER — TRES CARTER — TRES CARTER — TRES CARTER — TRES CARTER — TRES CARTER — TRES CARTER — TRES CARTER — </div>
    </div>

    <style is:inline>
      :root {
        --ac: #2431FF;
        --mvt-card: #ffffff; --mvt-ink: #0A0A0A; --mvt-line: rgba(0,0,0,0.3);
        --mvt-label: rgba(0,0,0,0.5); --mvt-accent: #2431FF; --mvt-confetti: #2431FF,#0A0A0A,#ffffff;
      }
      * { margin: 0; box-sizing: border-box; }
      /* NOTE: no overflow-x:hidden on html/body — it breaks position:sticky.
         The rail clips itself inside .sticky. overscroll-behavior-x is safe
         (and required: consumed trackpad deltaX must not trigger back-swipe). */
      html { background: #fff; overscroll-behavior-x: none; }
      body { font-family: 'Space Mono', ui-monospace, monospace; color: #0A0A0A; -webkit-font-smoothing: antialiased; }
      ::selection { background: var(--ac); color: #fff; }
      a { color: inherit; text-decoration: none; }
      .mono { font-family: 'Space Mono', monospace; }

      /* the way is RIGHT: one drawn arrow, mid right edge; click = advance.
         Replaces the old "scroll down to move right" text (Tres, 2026-07-03). */
      .go {
        position: fixed; top: 50%; right: calc(14px + env(safe-area-inset-right, 0px));
        translate: 0 -50%; z-index: 10;
        color: var(--ac); background: none; border: 0; padding: 14px 8px; cursor: pointer;
        transition: opacity 400ms cubic-bezier(0.16, 1, 0.3, 1), transform 300ms cubic-bezier(0.16, 1, 0.3, 1);
      }
      .go svg { display: block; }
      /* lifecycle: full presence at the front door; DEMOTED (not deleted —
         arrows go unnoticed enough as it is) once travelling; FLIPPED into a
         return arrow on the last panel */
      .go.dim { opacity: 0.35; }
      .go.flip { transform: rotate(180deg); }
      @media (hover: hover) and (pointer: fine) { .go.dim:hover { opacity: 1; } }
      .go:focus-visible { outline: 2px solid var(--ac); outline-offset: 3px; opacity: 1; }
      @keyframes nudge { 0%, 100% { transform: translateX(0); } 50% { transform: translateX(7px); } }
      @media (prefers-reduced-motion: no-preference) {
        .go:not(.dim):not(.flip) svg { animation: nudge 1.6s cubic-bezier(0.45, 0, 0.55, 1) infinite; }
      }

      /* — registration mark: the chromatic-print signature, fixed like a
           press sheet corner. Decorative; half-lost over dark panels on
           purpose (a passing print artifact). — */
      .reg { position: fixed; top: calc(15px + env(safe-area-inset-top, 0px)); right: max(6vw, calc(12px + env(safe-area-inset-right, 0px))); z-index: 10; pointer-events: none; }

      .hwrap { height: 700svh; } /* corrected 1:1 by JS */
      .sticky { position: sticky; top: 0; height: 100svh; overflow: hidden; }
      .track {
        display: flex; height: 100%; width: max-content;
        transform: translateX(var(--tx, 0px));
        will-change: transform;
      }
      .panel {
        flex: 0 0 auto; width: 100vw; height: 100%;
        display: grid; place-content: center; text-align: center;
        border-right: 4px solid #0A0A0A;
        position: relative;
      }
      /* panel 1 is 72px short of the viewport: panel 2's cut edge PEEKS at
         the right on load — the strongest "there's more this way" signal */
      .p-name { width: calc(100vw - 72px); }
      .p-line { width: 56vw; }
      .p-link { width: 68vw; }
      @media (max-width: 700px) { .p-line, .p-link { width: 100vw; } }

      /* margin annotations — one per panel, real sequence */
      .ptag {
        position: absolute; left: 18px; bottom: 76px;
        writing-mode: vertical-rl;
        font-family: 'Space Mono', monospace; font-size: 10px;
        letter-spacing: 0.14em; text-transform: uppercase;
        color: rgba(10,10,10,0.4); text-align: left;
        transition: color 160ms cubic-bezier(0.16, 1, 0.3, 1);
      }
      .panel.alt .ptag { color: rgba(255,255,255,0.45); }

      /* — the WORM: letters inch on with a decaying crawl. Per-letter spans
           are server-rendered; --i staggers the delay. em units scale the
           wriggle with the type size. — */
      .l { display: inline-block; transform-origin: 50% 80%; }
      @keyframes worm {
        0%   { opacity: 0; transform: translate(-0.38em, 0.16em) rotate(-8deg) scale(0.92, 1.06); }
        28%  { opacity: 1; transform: translate(0.15em, -0.08em) rotate(5deg) scale(1.06, 0.94); }
        52%  { transform: translate(-0.07em, 0.04em) rotate(-3deg) scale(0.97, 1.03); }
        76%  { transform: translate(0.03em, -0.015em) rotate(1.5deg) scale(1.01, 0.99); }
        100% { opacity: 1; transform: none; }
      }
      @media (prefers-reduced-motion: no-preference) {
        /* name worms on load — held until the display font is in (head
           script adds .fonts-in; letters only hide once .worm-wait proves
           JS is present, so no-JS never blanks the name) */
        html.worm-wait .giant .l { opacity: 0; }
        html.fonts-in .giant .l {
          animation: worm 900ms cubic-bezier(0.22, 1, 0.36, 1) both;
          animation-delay: calc(var(--i) * 70ms);
        }
        /* panel words hide only once JS confirms it can un-hide them */
        .wormable .word .l, .wormable .spine .l { opacity: 0; }
        .panel.in .word .l, .panel.in .spine .l {
          opacity: 1;
          animation: worm 900ms cubic-bezier(0.22, 1, 0.36, 1) both;
          animation-delay: calc(var(--i) * 70ms);
        }
      }

      /* chromatic misregistration: while the rail travels the print plates
         slip — blue/red ghost impressions offset by --ab px — and re-register
         the moment it rests. Gated by .mis so rest state costs nothing. */
      .mis .giant, .mis .p-link .word, .mis .spine {
        text-shadow:
          calc(var(--ab, 0) * 1px) 0 0 rgba(36, 49, 255, 0.5),
          calc(var(--ab, 0) * -1px) 0 0 rgba(232, 41, 41, 0.42);
      }

      /* — TRESCARTER: Bungee Shade carries its own dimension now — */
      .giant {
        font-family: 'Bungee Shade', 'Bungee', system-ui, sans-serif;
        font-weight: 400;
        font-size: clamp(56px, 14.5vw, 250px); line-height: 0.95;
        text-align: left;
        transform: translateX(calc(var(--d, 0px) * -0.07)); /* parallax: lags the rail */
      }
      .giant .ln { display: block; }
      .giant .ln-b { margin-left: 0.4em; } /* baseline-shift energy */
      .ac { color: var(--ac); }

      .p-line p {
        font-size: 15px; line-height: 2; letter-spacing: 0.1em; text-transform: uppercase;
        transform: translateX(calc(var(--d, 0px) * -0.1));
      }

      /* — section panels: dimensional Shade collapses to flat solid on hover
           (Bungee styles share metrics — the swap never reflows) — */
      .p-link .pspan { display: block; transform: translateX(calc(var(--d, 0px) * -0.07)); }
      .p-link .word {
        display: block;
        font-family: 'Bungee Shade', 'Bungee', system-ui, sans-serif;
        font-weight: 400;
        font-size: clamp(44px, 9.4vw, 170px); line-height: 1;
        transition: color 160ms cubic-bezier(0.16, 1, 0.3, 1), transform 140ms cubic-bezier(0.16, 1, 0.3, 1);
      }
      .p-link.alt { background: #0A0A0A; color: #fff; }
      @media (hover: hover) and (pointer: fine) {
        .p-link:hover .ptag { color: var(--ac); }
        .p-link:hover .word { font-family: 'Bungee', system-ui, sans-serif; color: var(--ac); }
        .p-link.alt:hover .word { color: #fff; }
      }
      .p-link:active .word { transform: scale(0.96); }

      /* — panel 07: the vertical one. END. spine down the left in Shade,
           one narrow column stacked top-to-bottom, right side reserved
           for the dot map (mounted by ring.js into #mv-info). — */
      .p-info {
        border-right: none; width: 100vw; padding: 0;
        display: grid; grid-template-columns: auto minmax(0, 1fr);
        place-content: stretch; place-items: stretch; text-align: left;
      }
      .spine {
        writing-mode: vertical-rl; text-orientation: mixed;
        font-family: 'Bungee Shade', 'Bungee', system-ui, sans-serif;
        font-weight: 400;
        font-size: clamp(56px, 16svh, 150px); line-height: 1;
        padding: 4svh clamp(12px, 2.5vw, 36px) 9svh;
        border-right: 4px solid #0A0A0A;
      }
      .v-col {
        display: flex; flex-direction: column; justify-content: space-between;
        max-width: 640px; min-width: 0;
        padding: 9svh clamp(100px, 22vw, 230px) max(10svh, 70px) clamp(20px, 4vw, 56px);
        font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.05em;
        text-transform: uppercase; line-height: 1.7;
      }
      .lbl { display: block; color: rgba(10,10,10,0.45); margin-bottom: 4px; }
      .soon { color: rgba(10,10,10,0.45); }
      .v-row { display: flex; flex-wrap: wrap; column-gap: 20px; }
      .v-row a, .v-row .soon, .v-meta a { display: inline-block; padding: 12px 0; } /* ~44px targets */
      .v-meta {
        display: flex; flex-direction: column;
        border-top: 1px solid rgba(0,0,0,0.16); padding-top: 12px;
        font-size: 10px; letter-spacing: 0.06em;
      }
      .p-info .ptag { left: auto; right: 18px; } /* spine owns the left edge */
      @media (hover: hover) and (pointer: fine) {
        .p-info a:hover { text-decoration: underline; text-underline-offset: 4px; }
      }
      @media (max-width: 640px) {
        .spine { font-size: clamp(40px, 13vw, 72px); }
        .v-col { font-size: 11px; }
      }

      .marquee {
        position: fixed; left: 0; right: 0; bottom: 0; z-index: 9;
        overflow: hidden; border-top: 4px solid #0A0A0A; background: #fff;
        padding: 10px 0 calc(10px + env(safe-area-inset-bottom, 0px));
      }
      .m-in {
        white-space: nowrap; width: max-content;
        font-family: 'Bungee', system-ui, sans-serif; font-weight: 400;
        font-size: 15px; letter-spacing: 0.04em;
        animation: slide 26s linear infinite;
        will-change: transform;
      }
      .m-in .sep { color: var(--ac); }
      @keyframes slide { from { transform: translateX(0); } to { transform: translateX(-50%); } }

      /* touch: native sideways swipe with snap; parallax stays at rest.
         touch-action pan-x keeps horizontal native while handing VERTICAL
         flicks to JS — swipe down/up advances the rail (Tres, 2026-07-03) */
      @media (hover: none), (pointer: coarse) {
        .hwrap { height: auto !important; }
        .sticky { position: static; height: 100svh; overflow: visible; }
        .track {
          transform: none !important;
          overflow-x: auto; overscroll-behavior-x: contain;
          scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;
          touch-action: pan-x;
        }
        .panel { scroll-snap-align: center; scroll-snap-stop: always; }
      }
      /* reduced-motion desktop: the rail becomes a plain vertical stack —
         .sticky must unclip or everything past panel 1 is UNREACHABLE */
      html.rm .hwrap { height: auto; }
      html.rm .sticky { position: static; height: auto; overflow: visible; }
      html.rm .track { height: auto; width: 100%; flex-wrap: wrap; transform: none; }
      html.rm .panel { width: 100%; height: auto; min-height: 100svh; border-right: none; border-bottom: 4px solid #0A0A0A; }
      @media (prefers-reduced-motion: reduce) {
        .m-in { animation: none; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
      import('/mv/ring.js');
    </script>
    <script is:inline>
      (function () {
        'use strict';
        var reduce = false, coarse = false;
        try {
          reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
          coarse = matchMedia('(hover: none), (pointer: coarse)').matches;
        } catch (e) {}

        var wrap = document.getElementById('hwrap');
        var track = document.getElementById('track');
        var sticky = document.querySelector('.sticky');
        var go = document.getElementById('go');
        var mq = document.getElementById('mq');
        var panels = Array.prototype.slice.call(track.children);
        var centers = [];
        var ticking = false;
        var SPEED = 2.4;
        var lastTx = 0;

        /* — marquee: rebuilt as an EVEN number of segments spanning >= 2x the
             viewport — the -50% loop only reads seamless when the two halves
             are identical AND wider than the screen (6 fixed reps weren't,
             on anything past ~1500px: the banner showed a blank gap) — */
        function buildMq() {
          mq.innerHTML = 'TRES CARTER <span class="sep">—</span> ';
          var one = Math.max(1, mq.scrollWidth);
          var n = Math.ceil((innerWidth * 2) / one);
          n += n % 2; /* identical halves */
          n = Math.max(n, 4);
          var s = '';
          for (var i = 0; i < n; i++) s += 'TRES CARTER <span class="sep">—</span> ';
          mq.innerHTML = s;
          /* constant ~90px/s editorial pace on every screen width — a fixed
             26s loop ran 30px/s on phones and 200px/s on wide desktops */
          mq.style.animationDuration = Math.max(12, Math.round(mq.scrollWidth / 2 / 90)) + 's';
        }
        buildMq();
        /* Bungee reshapes the segments when it lands — re-measure once */
        if (document.fonts && document.fonts.ready) document.fonts.ready.then(buildMq);

        if (reduce) {
          document.documentElement.classList.add('rm'); /* stacked layout, CSS-owned */
          if (go) go.hidden = true; /* nothing scrubs sideways to point at */
          addEventListener('resize', buildMq, { passive: true });
          return;
        }

        var VW = document.documentElement.clientWidth || innerWidth; /* excludes the Windows scrollbar */
        function measure() {
          VW = document.documentElement.clientWidth || innerWidth;
          centers = panels.map(function (p) { return p.offsetLeft + p.offsetWidth / 2; });
        }

        /* — velocity settle loop: marquee speeds up while travelling, and
             the print plates slip off-register (--ab), re-registering at
             rest. .mis gates the text-shadow so idle costs nothing. — */
        var disp = 0, vel = 0, loopOn = false, anim = null, lastAb = 0;
        function settle() {
          disp += (vel - disp) * 0.12;
          vel *= 0.88;
          if (!anim && mq.getAnimations) {
            try { anim = mq.getAnimations()[0] || null; } catch (e) {}
          }
          if (anim) anim.playbackRate = 1 + Math.min(disp * 0.05, 3.5);
          var ab = Math.round(Math.min(disp * 0.045, 2.2) * 4) / 4; /* quantized: fewer repaints */
          if (ab !== lastAb) {
            lastAb = ab;
            track.style.setProperty('--ab', ab);
            track.classList.toggle('mis', ab > 0);
          }
          if (disp > 0.1 || vel > 0.1) {
            requestAnimationFrame(settle);
          } else {
            loopOn = false; disp = 0;
            if (anim) anim.playbackRate = 1;
            if (lastAb !== 0) { lastAb = 0; track.style.setProperty('--ab', 0); track.classList.remove('mis'); }
          }
        }
        function kickVel(v) {
          vel = Math.min(Math.max(v, vel), 120);
          if (!loopOn && vel > 0.5) { loopOn = true; requestAnimationFrame(settle); }
        }

        /* — shared travel helpers: the arrow, keys and flicks all speak in
             panels; both rail modes translate that to their own scroller — */
        function railX() { return coarse ? track.scrollLeft : lastTx; }
        function wrapTop() { return wrap.getBoundingClientRect().top + scrollY; }
        function nearest() {
          var x = railX() + VW / 2, best = 0, d = 1e9;
          for (var i = 0; i < centers.length; i++) {
            var dd = Math.abs(centers[i] - x);
            if (dd < d) { d = dd; best = i; }
          }
          return best;
        }
        function goTo(i) {
          i = Math.min(panels.length - 1, Math.max(0, i));
          var x = Math.max(0, centers[i] - VW / 2);
          if (coarse) track.scrollTo({ left: x, behavior: 'smooth' });
          else scrollTo({ top: wrapTop() + x / SPEED, behavior: 'smooth' });
        }
        go.addEventListener('click', function () {
          goTo(nearest() + (go.classList.contains('flip') ? -1 : 1));
        });
        /* arrow lifecycle: demote once travelling (never delete — arrows go
           unnoticed enough as it is), flip into a return arrow at the END */
        function cueState(x, max) {
          var nr = nearest();
          go.classList.toggle('dim', x > 120 && nr < panels.length - 1);
          go.classList.toggle('flip', nr === panels.length - 1);
        }

        if (coarse) {
          /* — touch: the rail swipes natively sideways; this layer adds the
               missing pieces — arrow fade, marquee/plate coupling, and the
               direction fix: a mostly-VERTICAL flick (which used to do
               nothing) now advances the rail — swipe up = onward, down =
               back, matching how every page "continues" under a thumb — */
          measure();
          var lastL = 0;
          track.addEventListener('scroll', function () {
            if (!ticking) {
              ticking = true;
              requestAnimationFrame(function () {
                ticking = false;
                kickVel(Math.abs(track.scrollLeft - lastL));
                lastL = track.scrollLeft;
                cueState(track.scrollLeft);
              });
            }
          }, { passive: true });
          var t0 = null;
          track.addEventListener('pointerdown', function (e) {
            if (e.pointerType !== 'touch') return;
            t0 = { x: e.clientX, y: e.clientY, t: performance.now() };
          }, { passive: true });
          track.addEventListener('pointerup', function (e) {
            if (!t0 || e.pointerType !== 'touch') return;
            var dx = e.clientX - t0.x, dy = e.clientY - t0.y, dt = performance.now() - t0.t;
            t0 = null;
            /* Hammer-derived flick gate: vertical dominance + 50px or 0.3px/ms */
            if (Math.abs(dy) > Math.abs(dx) && (Math.abs(dy) > 50 || Math.abs(dy) / Math.max(1, dt) > 0.3)) {
              goTo(nearest() + (dy < 0 ? 1 : -1));
            }
          }, { passive: true });
          addEventListener('resize', function () { buildMq(); measure(); }, { passive: true });
          return;
        }

        /* — desktop rail: scroll-driven translateX at SPEED — */
        function size() {
          /* sticky.clientHeight, not innerHeight: svh-true (URL-bar class);
             VW, not innerWidth: the classic Windows scrollbar isn't viewport */
          wrap.style.height = ((track.scrollWidth - VW) / SPEED + sticky.clientHeight) + 'px';
          measure();
        }
        function place() {
          ticking = false;
          var top = wrap.getBoundingClientRect().top;
          var max = track.scrollWidth - VW;
          var tx = Math.min(max, Math.max(0, -top * SPEED));
          track.style.setProperty('--tx', -tx + 'px');
          /* per-panel parallax input: distance from viewport centre */
          var mid = VW / 2;
          for (var i = 0; i < panels.length; i++) {
            panels[i].style.setProperty('--d', (centers[i] - tx - mid).toFixed(1) + 'px');
          }
          kickVel(Math.abs(tx - lastTx));
          lastTx = tx;
          cueState(tx, max);
        }
        /* focus must never scroll the clipped sticky box — a container
           scroll would stack on top of --tx and shear the rail for good */
        sticky.addEventListener('scroll', function () {
          if (sticky.scrollLeft || sticky.scrollTop) { sticky.scrollLeft = 0; sticky.scrollTop = 0; }
        }, { passive: true });
        track.addEventListener('focusin', function (e) {
          sticky.scrollLeft = 0;
          var p = e.target;
          while (p && p !== track && !(p.classList && p.classList.contains('panel'))) p = p.parentNode;
          var i = panels.indexOf(p);
          if (i >= 0) goTo(i); /* the reveal happens in page scroll instead */
        });
        addEventListener('scroll', function () {
          if (!ticking) { ticking = true; requestAnimationFrame(place); }
        }, { passive: true });
        /* trackpad sideways swipe / tilt-wheel: the rail's native language —
           map horizontal deltas onto the scrub instead of dropping them */
        addEventListener('wheel', function (e) {
          if (e.ctrlKey) return; /* pinch-zoom stays untouched */
          var dx = e.deltaX, dy = e.deltaY;
          if (e.deltaMode === 1) { dx *= 16; dy *= 16; }        /* lines (Firefox) */
          else if (e.deltaMode === 2) { dx *= innerHeight; dy *= innerHeight; } /* pages */
          if (Math.abs(dx) > Math.abs(dy)) {
            scrollBy(0, dx);
            e.preventDefault();
          }
        }, { passive: false });
        /* arrow keys travel the rail one panel at a time */
        addEventListener('keydown', function (e) {
          if (e.altKey || e.ctrlKey || e.metaKey || e.shiftKey) return;
          if (e.key === 'ArrowRight') { goTo(nearest() + 1); e.preventDefault(); }
          else if (e.key === 'ArrowLeft') { goTo(nearest() - 1); e.preventDefault(); }
        });
        addEventListener('resize', function () { buildMq(); size(); place(); }, { passive: true });
        size(); place();
      })();
    </script>
    <script is:inline>
      /* worm trigger: first viewport entry per panel. IntersectionObserver
         respects the rail's transform on desktop AND the native scroller on
         touch — one path for both. Letters are only hidden once this runs. */
      (function () {
        'use strict';
        var reduce = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}
        if (reduce || !('IntersectionObserver' in window)) return;
        var track = document.getElementById('track');
        if (!track) return;
        track.classList.add('wormable');
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (en) {
            if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); }
          });
        }, { threshold: 0.2 });
        Array.prototype.forEach.call(document.querySelectorAll('.p-link, .p-info'), function (p) { io.observe(p); });
      })();
    </script>
    <script is:inline defer src="/mv/ticker.js"></script>
  </body>
</html>
