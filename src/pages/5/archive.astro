---
// Site 5 — archive. Outlined heading (mirrors its outlined landing panel).
import { MV_CLIENT } from '../../lib/multiverse';
import { getCollection } from 'astro:content';
const WORK = ['z07', 'ee13', 'flatwood', 'tucker', 'thesis'];
const all = (await getCollection('projects')).map((e) => e.data);
const rows = all.filter((p) => !WORK.includes(p.slug));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FFFFFF" />
    <title>ARCHIVE — TRES ⁵</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Space+Mono&display=swap" rel="stylesheet" />
    <script is:inline set:html={MV_CLIENT(5)} />
  </head>
  <body>
    <a class="back" id="back" href="/5/">← index</a>
    <main class="arch">
      <header class="head">
        <p class="spec">archive — {String(rows.length).padStart(2, '0')}</p>
        <h1 class="name">THE REST<span class="ac">.</span></h1>
      </header>
      <div class="list">
        {rows.map((p) => (
          <a class="row" href={`/5/project/${p.slug}`}>
            <span class="r-no">{String(p.id ?? '').padStart(2, '0')}</span>
            <span class="r-name">{p.name.toUpperCase()}</span>
            <span class="r-meta">{p.category}</span>
            <span class="r-meta r-year">{p.year}</span>
          </a>
        ))}
      </div>
    </main>
    <footer class="foot"><span>© 2026 tres carter</span><a href="/privacy">privacy</a></footer>

    <style is:inline>
      :root { --ac: #2431FF; }
      * { margin: 0; box-sizing: border-box; }
      html { background: #fff; }
      body { font-family: 'Anton', system-ui, sans-serif; color: #0A0A0A; -webkit-font-smoothing: antialiased; }
      ::selection { background: var(--ac); color: #fff; }
      a { color: inherit; text-decoration: none; }
      .back { position: fixed; z-index: 10; top: var(--y, 14px); left: 6vw; font-family: 'Space Mono', monospace; font-size: 12px; padding: 12px 0; transition: transform 140ms cubic-bezier(0.23,1,0.32,1); }
      .back:active { transform: scale(0.96); }
      @media (hover: hover) and (pointer: fine) { .back:hover { text-decoration: underline; text-underline-offset: 4px; } }
      .arch { max-width: 1100px; margin: 0 auto; padding: 0 6vw 12svh; }
      .head { padding: clamp(110px, 22vh, 260px) 0 7svh; }
      .spec { font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(10,10,10,0.45); }
      .name { font-size: clamp(38px, 8vw, 104px); line-height: 1; margin-top: 10px; }
      .ac { color: var(--ac); }
      /* outlined display type — solid fallback where text-stroke is missing */
      @supports (-webkit-text-stroke: 2px #000) {
        .name { color: transparent; -webkit-text-stroke: 2.5px #0A0A0A; }
        .name .ac { color: var(--ac); -webkit-text-stroke-color: var(--ac); }
      }
      .list { border-top: 3px solid #0A0A0A; }
      .row { display: grid; grid-template-columns: 3ch minmax(0, 1fr) auto auto; gap: 16px; align-items: baseline; padding: 15px 0; border-bottom: 1px solid rgba(0,0,0,0.2); }
      .r-no, .r-meta { font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 0.05em; text-transform: uppercase; color: rgba(10,10,10,0.45); }
      .r-name { font-size: clamp(14px, 2vw, 20px); line-height: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .r-year { text-align: right; min-width: 4ch; }
      @media (max-width: 560px) { .r-meta:not(.r-year) { display: none; } .row { grid-template-columns: 3ch minmax(0, 1fr) auto; } }
      @media (hover: hover) and (pointer: fine) {
        .r-name, .r-no { transition: color 150ms cubic-bezier(0.16, 1, 0.3, 1); }
        .row:hover .r-name { color: var(--ac); }
        .row:hover .r-no { color: var(--ac); }
      }
      .foot { display: flex; justify-content: space-between; max-width: 1100px; margin: 0 auto; padding: 3svh 6vw 4svh; border-top: 1px solid rgba(0,0,0,0.16); font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
    </script>
    <script is:inline>
      (function () {
        var reduce = false, fine = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; fine = matchMedia('(hover: hover) and (pointer: fine)').matches; } catch (e) {}
        if (!fine || reduce) return;
        var back = document.getElementById('back');
        var target = null, cur = null, raf = null;
        function frame() {
          cur += (target - cur) * 0.09;
          back.style.setProperty('--y', cur.toFixed(1) + 'px');
          if (Math.abs(target - cur) > 0.4) raf = requestAnimationFrame(frame); else raf = null;
        }
        addEventListener('pointermove', function (e) {
          var h = back.offsetHeight;
          target = Math.min(innerHeight - h - 12, Math.max(12, e.clientY - h / 2));
          if (cur === null) cur = target;
          if (!raf) raf = requestAnimationFrame(frame);
        }, { passive: true });
      })();
    </script>
  </body>
</html>
