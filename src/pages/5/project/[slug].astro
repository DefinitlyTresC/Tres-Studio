---
// Site 5 — project page. Same bones, chromatic-print skin: Bungee Shade
// header worms on per-letter on load.
import { MV_CLIENT } from '../../../lib/multiverse';
import { getCollection } from 'astro:content';
import { heroUrl, gridUrl, mediaUrl } from '../../../lib/cloudinary';

export async function getStaticPaths() {
  const all = (await getCollection('projects')).map((e) => e.data);
  return all.map((p) => {
    const cat = all.filter((q) => q.category === p.category);
    const ring = cat.length > 1 ? cat : all; /* singleton category: nav must not self-link */
    const i = ring.findIndex((q) => q.slug === p.slug);
    return { params: { slug: p.slug }, props: { p, prev: ring[(i - 1 + ring.length) % ring.length], next: ring[(i + 1) % ring.length] } };
  });
}
const WORK = ['z07', 'ee13', 'flatwood', 'tucker', 'thesis'];
const { p, prev, next } = Astro.props;
const backHref = WORK.includes(p.slug) ? '/5/work' : '/5/archive';
const backLabel = WORK.includes(p.slug) ? 'work' : 'archive';
const spec = [`no.${String(p.id ?? '').padStart(2, '0')}`, p.year, p.location, p.status].filter(Boolean).join(' — ').toLowerCase();
const paragraphs = (p.description || '').split(/\n\s*\n/).map((s) => s.trim()).filter(Boolean);
/* per-letter split for the worm; spaces become NBSP so inline-block
   letter spans keep their width */
const worm = (word, offset = 0) =>
  [...word].map((ch, i) => ({ ch: ch === ' ' ? ' ' : ch, i: i + offset }));
const nameLetters = worm(p.name.toUpperCase());
// image ordinal must match the lightbox counter, which counts images only
let imgOrdinal = 0;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FFFFFF" />
    <title>{p.name.toUpperCase()} — TRES ⁵</title>
    <link rel="preconnect" href="https://res.cloudinary.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bungee&family=Bungee+Shade&family=Space+Mono&display=swap" rel="stylesheet" />
    <script is:inline set:html={MV_CLIENT(5)} />
    <!-- tracking: one bootstrap for the whole site (Umami + Clarity + visitor id + self-exclusion) - public/ts.js -->
    <script is:inline defer src="/ts.js"></script>
  </head>
  <body>
    <a class="back" id="back" href={backHref}>← {backLabel}</a>
    <svg class="reg" viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
      <circle cx="12" cy="12" r="7.5" fill="none" stroke="#2431FF" stroke-width="1.5" />
      <path d="M12 1v22M1 12h22" fill="none" stroke="#2431FF" stroke-width="1.5" />
    </svg>
    <main class="proj">
      <header class="head">
        <p class="spec">{spec}</p>
        <h1 class="name" aria-label={p.name}>
          <span aria-hidden="true">{nameLetters.map((l) => <span class="l" style={`--i:${l.i}`}>{l.ch}</span>)}<span class="l ac" style={`--i:${nameLetters.length}`}>.</span></span>
        </h1>
        {p.designedAt && (
          <p class="spec at">designed at {p.designedAtUrl ? <a href={p.designedAtUrl} target="_blank" rel="noopener">{p.designedAt.toLowerCase()}</a> : p.designedAt.toLowerCase()}</p>
        )}
      </header>
      {heroUrl(p) && <img class="hero" src={heroUrl(p)} alt={p.name} fetchpriority="high" decoding="async" />}
      {paragraphs.length > 0 && <div class="desc">{paragraphs.map((t) => <p>{t}</p>)}</div>}
      {p.media.length > 0 && (
        <div class="gallery">
          {p.media.map((m, i) =>
            m.type === 'video'
              ? <video src={mediaUrl(m)} autoplay muted loop playsinline preload="metadata"></video>
              : <button class="cell" type="button" data-full={mediaUrl(m)} aria-label={`View image ${++imgOrdinal}`}><img src={gridUrl(m)} alt="" loading="lazy" decoding="async" /></button>
          )}
        </div>
      )}
      <nav class="pn">
        <a href={`/5/project/${prev.slug}`}>← {prev.name.toLowerCase()}</a>
        <a class="pn-next" href={`/5/project/${next.slug}`}>{next.name.toLowerCase()} →</a>
      </nav>
    </main>
    <footer class="foot"><span>© 2026 tres carter</span><a href="/privacy">privacy</a></footer>

    <div class="lb" id="lb" hidden role="dialog" aria-modal="true" aria-label="Gallery image">
      <img id="lb-img" alt="" />
      <p class="lb-n" id="lb-n"></p>
      <button class="lb-x" id="lb-x" type="button" aria-label="Close">close</button>
      <button class="lb-prev" id="lb-prev" type="button" aria-label="Previous">←</button>
      <button class="lb-next" id="lb-next" type="button" aria-label="Next">→</button>
    </div>

    <style is:inline>
      :root { --ac: #2431FF; }
      * { margin: 0; box-sizing: border-box; }
      html { background: #fff; }
      body { font-family: 'Space Mono', ui-monospace, monospace; color: #0A0A0A; -webkit-font-smoothing: antialiased; }
      ::selection { background: var(--ac); color: #fff; }
      a { color: inherit; text-decoration: none; }
      button { font: inherit; color: inherit; background: none; border: none; padding: 0; cursor: pointer; }
      .back { position: fixed; z-index: 10; top: var(--y, 14px); left: max(6vw, calc(14px + env(safe-area-inset-left, 0px))); font-family: 'Space Mono', monospace; font-size: 12px; padding: 12px 0; transition: transform 140ms cubic-bezier(0.23,1,0.32,1); }
      .back:active { transform: scale(0.96); }
      @media (hover: hover) and (pointer: fine) { .back:hover { text-decoration: underline; text-underline-offset: 4px; } }
      .back:focus-visible { outline: 2px solid var(--ac); outline-offset: 3px; }
      .reg { position: fixed; top: calc(15px + env(safe-area-inset-top, 0px)); right: max(6vw, calc(12px + env(safe-area-inset-right, 0px))); z-index: 10; pointer-events: none; }
      .proj { max-width: 1100px; margin: 0 auto; padding: 0 6vw 6svh; }
      .head { padding: clamp(110px, 20vh, 220px) 0 5svh; }
      .spec { font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(10,10,10,0.45); }
      .name { font-family: 'Bungee Shade', 'Bungee', system-ui, sans-serif; font-weight: 400; font-size: clamp(24px, 5vw, 64px); line-height: 1.1; text-wrap: balance; margin-top: 12px; }
      .ac { color: var(--ac); }
      /* — worm-on: header letters inch into place on load — */
      .l { display: inline-block; transform-origin: 50% 80%; }
      @keyframes worm {
        0%   { opacity: 0; transform: translate(-0.38em, 0.16em) rotate(-8deg) scale(0.92, 1.06); }
        28%  { opacity: 1; transform: translate(0.15em, -0.08em) rotate(5deg) scale(1.06, 0.94); }
        52%  { transform: translate(-0.07em, 0.04em) rotate(-3deg) scale(0.97, 1.03); }
        76%  { transform: translate(0.03em, -0.015em) rotate(1.5deg) scale(1.01, 0.99); }
        100% { opacity: 1; transform: none; }
      }
      @media (prefers-reduced-motion: no-preference) {
        .name .l { animation: worm 900ms cubic-bezier(0.22, 1, 0.36, 1) both; animation-delay: calc(var(--i) * 70ms); }
      }
      .at { margin-top: 14px; }
      .at a { text-decoration: underline; text-underline-offset: 3px; }
      .hero { display: block; width: 100%; height: auto; outline: 1px solid rgba(0,0,0,0.1); outline-offset: -1px; }
      .desc { max-width: 58ch; padding: 6svh 0 2svh; }
      .desc p { font-family: 'Space Mono', monospace; font-size: 14px; line-height: 1.8; text-wrap: pretty; }
      .desc p + p { margin-top: 1em; }
      .gallery { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; padding-top: 5svh; }
      @media (max-width: 640px) { .gallery { grid-template-columns: 1fr; } }
      .gallery img, .gallery video { display: block; width: 100%; height: auto; outline: 1px solid rgba(0,0,0,0.1); outline-offset: -1px; }
      .cell { display: block; }
      .cell:focus-visible { outline: 2px solid var(--ac); outline-offset: 3px; }
      .pn { display: flex; justify-content: space-between; gap: 18px; padding: 8svh 0 0; font-family: 'Space Mono', monospace; font-size: 12px; }
      .pn a { display: inline-block; padding: 10px 0; }
      .pn-next { text-align: right; }
      @media (hover: hover) and (pointer: fine) {
        .pn a { transition: color 150ms cubic-bezier(0.16, 1, 0.3, 1), transform 150ms cubic-bezier(0.16, 1, 0.3, 1); }
        .pn a:hover { color: var(--ac); transform: translateX(-4px); }
        .pn a.pn-next:hover { transform: translateX(4px); }
        .cell img { transition: opacity 160ms cubic-bezier(0.16, 1, 0.3, 1); }
        .cell:hover img { opacity: 0.85; }
      }
      .pn a:active { transform: scale(0.96); }
      .foot { display: flex; justify-content: space-between; max-width: 1100px; margin: 0 auto; padding: 3svh 6vw 4svh; border-top: 1px solid rgba(0,0,0,0.16); font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; }
      .lb { position: fixed; inset: 0; z-index: 100; background: rgba(255,255,255,0.97); display: grid; place-items: center; }
      .lb[hidden] { display: none; }
      .lb img { max-width: 92vw; max-height: 86svh; outline: 1px solid rgba(0,0,0,0.1); outline-offset: -1px; }
      .lb-n { position: fixed; bottom: calc(18px + env(safe-area-inset-bottom, 0px)); left: 50%; translate: -50% 0; font-family: 'Space Mono', monospace; font-size: 11px; color: rgba(10,10,10,0.5); }
      .lb-x { position: fixed; top: calc(10px + env(safe-area-inset-top, 0px)); right: max(6vw, calc(14px + env(safe-area-inset-right, 0px))); font-family: 'Space Mono', monospace; font-size: 12px; padding: 14px 0 14px 14px; min-height: 44px; }
      .lb-prev, .lb-next { position: fixed; top: 50%; translate: 0 -50%; font-family: 'Space Mono', monospace; font-size: 18px; padding: 14px; min-width: 44px; min-height: 44px; }
      .lb-prev { left: calc(2vw + env(safe-area-inset-left, 0px)); } .lb-next { right: calc(2vw + env(safe-area-inset-right, 0px)); }
      @media (hover: hover) and (pointer: fine) { .lb button:hover { color: var(--ac); } }
      .lb button:focus-visible { outline: 2px solid var(--ac); outline-offset: 3px; }
      @media (prefers-reduced-motion: reduce) {
        .back, .pn a, .cell img { transition: none; }
        .back:active, .pn a:active { transform: none; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
    </script>
    <script is:inline>
      (function () {
        'use strict';
        var reduce = false, fine = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; fine = matchMedia('(hover: hover) and (pointer: fine)').matches; } catch (e) {}
        if (reduce) {
          /* reduced motion: gallery videos must not autoplay-loop */
          Array.prototype.forEach.call(document.querySelectorAll('.gallery video'), function (v) {
            v.removeAttribute('autoplay'); v.removeAttribute('loop');
            try { v.pause(); } catch (err) {}
            v.controls = true;
          });
        }
        if (fine && !reduce) {
          var back = document.getElementById('back');
          var target = null, cur = null, raf = null;
          function frame() {
            cur += (target - cur) * 0.09;
            back.style.setProperty('--y', cur.toFixed(1) + 'px');
            if (Math.abs(target - cur) > 0.4) raf = requestAnimationFrame(frame); else raf = null;
          }
          addEventListener('pointermove', function (e) {
            if (e.pointerType === 'touch') return; /* hybrids: taps must not move it */
            var h = back.offsetHeight;
            target = Math.min(innerHeight - h - 12, Math.max(12, e.clientY - h / 2));
            if (cur === null) cur = target;
            if (!raf) raf = requestAnimationFrame(frame);
          }, { passive: true });
        }
        var cellEls = Array.prototype.slice.call(document.querySelectorAll('.cell'));
        var full = cellEls.map(function (c) { return c.getAttribute('data-full'); });
        var lb = document.getElementById('lb');
        var img = document.getElementById('lb-img');
        var n = document.getElementById('lb-n');
        var at = 0, lastFocus = null, lockY = 0;
        function open(i) {
          var wasClosed = lb.hidden;
          at = i; img.src = full[at];
          n.textContent = (at + 1) + ' / ' + full.length;
          lb.hidden = false;
          if (wasClosed) {
            /* lock + focus capture on a TRUE open only — re-running on
               prev/next steps zeroes lockY (body is already fixed, so
               scrollY reads 0) and steals focus from the stepping button */
            lockY = window.scrollY || 0;
            /* body position:fixed — the lock iOS actually honors */
            document.body.style.position = 'fixed';
            document.body.style.top = -lockY + 'px';
            document.body.style.left = '0';
            document.body.style.right = '0';
            document.body.style.overflow = 'hidden';
            lastFocus = document.activeElement;
            document.getElementById('lb-x').focus();
          }
        }
        function close() {
          lb.hidden = true; img.src = '';
          document.body.style.position = '';
          document.body.style.top = '';
          document.body.style.left = '';
          document.body.style.right = '';
          document.body.style.overflow = '';
          window.scrollTo(0, lockY);
          if (lastFocus) lastFocus.focus();
        }
        function step(d) { open((at + d + full.length) % full.length); }
        cellEls.forEach(function (c, i) { c.addEventListener('click', function () { open(i); }); });
        document.getElementById('lb-x').addEventListener('click', close);
        document.getElementById('lb-prev').addEventListener('click', function (e) { e.stopPropagation(); step(-1); });
        document.getElementById('lb-next').addEventListener('click', function (e) { e.stopPropagation(); step(1); });
        lb.addEventListener('click', function (e) { if (e.target === lb) close(); });
        addEventListener('keydown', function (e) {
          if (lb.hidden) return;
          if (e.key === 'Escape') close();
          else if (e.key === 'ArrowLeft') step(-1);
          else if (e.key === 'ArrowRight') step(1);
          else if (e.key === 'Tab') {
            /* keep focus inside the dialog */
            var ring = [document.getElementById('lb-x'), document.getElementById('lb-prev'), document.getElementById('lb-next')];
            var idx = ring.indexOf(document.activeElement);
            e.preventDefault();
            var nx = idx === -1 ? 0 : (idx + (e.shiftKey ? -1 : 1) + ring.length) % ring.length;
            ring[nx].focus();
          }
        });
      })();
    </script>
  </body>
</html>
