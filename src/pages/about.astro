---
// About — weightless voice, same facts.
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FAFAF7" />
    <title>About — T R E S .</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;700;800&family=Space+Mono&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/cursor.css" />
    <!-- tracking: one bootstrap for the whole site (Umami + Clarity + visitor id + self-exclusion) - public/ts.js -->
    <script is:inline defer src="/ts.js"></script>
  </head>
  <body>
    <a class="back" id="back" href="/">← index</a>

    <main class="about" data-zg-room>
      <h1 class="name"><span data-zg data-zg-slim>T r e s</span><span class="shift" data-zg data-zg-slim>C a r t e r</span></h1>
      <p class="lede" data-zg data-zg-slim>Architectural designer — 30A, Florida.</p>
      <p class="hey" data-zg data-zg-slim>hey, im tres. i design houses, buildings, websites, tools, pretty much anything. reach out below!</p>
      <div class="acts">
        <a href="mailto:tres@tres.studio" data-zg data-zg-slim>tres@tres.studio</a>
        <a href="https://instagram.com/tres.studio" target="_blank" rel="noopener" data-zg data-zg-slim>IG</a>
        <a href="https://www.linkedin.com/in/tres-carter" target="_blank" rel="noopener" data-zg data-zg-slim>LinkedIn</a>
      </div>
    </main>

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }
      html { background: #FAFAF7; }
      body { font-family: 'Hanken Grotesk', system-ui, sans-serif; color: #101010; -webkit-font-smoothing: antialiased; }
      ::selection { background: #101010; color: #FAFAF7; }
      a { color: inherit; text-decoration: none; }
      .back { position: fixed; z-index: 10; top: var(--y, 14px); left: 6vw; font-family: 'Space Mono', monospace; font-size: 12px; padding: 12px 0; transition: transform 140ms cubic-bezier(0.23,1,0.32,1); }
      .back:active { transform: scale(0.96); }
      @media (hover: hover) and (pointer: fine) { .back:hover { text-decoration: underline; text-underline-offset: 4px; } }
      .back:focus-visible { outline: 2px solid #101010; outline-offset: 3px; }

      .about { padding: clamp(140px, 28vh, 340px) 6vw 16svh; }
      .name { font-weight: 800; font-size: clamp(52px, 10vw, 130px); line-height: 1.02; }
      /* fit-content: lines hug their text so the zero-g engine gets horizontal
         room to throw them in — visually identical at rest (left-aligned) */
      .name span { display: block; width: fit-content; }
      .name .shift { margin-left: clamp(30px, 12vw, 220px); }
      .lede { font-family: 'Space Mono', monospace; font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(16,16,16,0.5); margin-top: 26px; width: fit-content; }
      /* type-on: the full line ships in markup and keeps holding the box
         (visibility:hidden) while an overlay inside types over it — the element
         never changes size, and the zero-g engine keeps the outer transform */
      .hey { position: relative; font-size: 15px; line-height: 1.65; color: rgba(16,16,16,0.72); max-width: 44ch; margin-top: 18px; width: fit-content; }
      .hey-hold { visibility: hidden; }
      .hey-live { position: absolute; inset: 0; } /* same box, same font: identical line wraps */
      .hey-caret { display: inline-block; width: 2px; height: 1.05em; margin-left: 2px; vertical-align: text-bottom; background: #101010; animation: hey-blink 0.9s step-end infinite; transition: opacity 400ms ease; }
      .hey-caret.is-done { animation: none; opacity: 0; }
      .hey-sr { position: absolute; width: 1px; height: 1px; overflow: hidden; clip-path: inset(50%); white-space: nowrap; } /* the full line for AT while the overlay types */
      @keyframes hey-blink { 50% { opacity: 0; } }
      .acts { display: flex; gap: 28px; margin-top: 44px; font-family: 'Space Mono', monospace; font-size: 13px; }
      /* 44px hit areas without moving anything: pad out, pull back in */
      .acts a { display: inline-block; padding: 14px; margin: -14px; }
      @media (hover: hover) and (pointer: fine) {
        a:hover { text-decoration: underline; text-underline-offset: 4px; }
        .sim [data-zg] { cursor: grab; }
        .sim [data-zg]:active { cursor: grabbing; }
      }
      @media (prefers-reduced-motion: reduce) {
        .back { transition: none; }
        .back:active { transform: none; }
        /* mid-session PRM flip: the full line, at rest, no caret */
        .hey-hold { visibility: visible; }
        .hey-live { display: none; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
    </script>
    <script is:inline>
      (function () {
        var reduce = false, fine = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; fine = matchMedia('(hover: hover) and (pointer: fine)').matches; } catch (e) {}
        if (!fine || reduce) return;
        var back = document.getElementById('back');
        var target = null, cur = null, raf = null;
        function frame() {
          cur += (target - cur) * 0.09;
          back.style.setProperty('--y', cur.toFixed(1) + 'px');
          if (Math.abs(target - cur) > 0.4) raf = requestAnimationFrame(frame); else raf = null;
        }
        addEventListener('pointermove', function (e) {
          if (e.pointerType === 'touch') return; /* hybrids: taps must not move it */
          var h = back.offsetHeight;
          target = Math.min(innerHeight - h - 12, Math.max(12, e.clientY - h / 2));
          if (cur === null) cur = target;
          if (!raf) raf = requestAnimationFrame(frame);
        }, { passive: true });
      })();
    </script>
    <script is:inline>
      /* type-on for .hey — the markup already carries the full line (no-JS and
         PRM read it complete at rest). This only rearranges children INSIDE the
         element; the zero-g engine owns the outer transform, untouched here. */
      (function () {
        var reduce = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}
        if (reduce) return;
        var p = document.querySelector('.hey');
        if (!p) return;
        var full = p.textContent;
        p.textContent = '';
        var hold = document.createElement('span');
        hold.className = 'hey-hold';
        hold.setAttribute('aria-hidden', 'true');
        hold.textContent = full; /* width-holder: the box never changes size */
        var live = document.createElement('span');
        live.className = 'hey-live';
        live.setAttribute('aria-hidden', 'true');
        var out = document.createTextNode('');
        var caret = document.createElement('span');
        caret.className = 'hey-caret';
        live.appendChild(out);
        live.appendChild(caret);
        var sr = document.createElement('span');
        sr.className = 'hey-sr';
        sr.textContent = full;
        p.appendChild(hold);
        p.appendChild(live);
        p.appendChild(sr);
        var i = 0;
        function done() {
          setTimeout(function () {
            caret.classList.add('is-done');
            /* after the fade: back to a plain paragraph, same box */
            setTimeout(function () { p.textContent = full; }, 500);
          }, 1200);
        }
        function tick() {
          i += 1;
          out.data = full.slice(0, i);
          if (i < full.length) setTimeout(tick, 28); else done();
        }
        setTimeout(tick, 500);
      })();
    </script>
    <script is:inline defer src="/mv/zerog.js"></script>
  </body>
</html>
