---
// 404 — Netlify serves dist/404.html for every unmatched path. Short,
// themed, and it points home.
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#101010" />
    <title>404 — T R E S .</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script is:inline src="/theme.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/cursor.css" />
    <!-- tracking: one bootstrap for the whole site (Umami + Clarity + visitor id + self-exclusion) - public/ts.js -->
    <script is:inline defer src="/ts.js"></script>
  </head>
  <body>
    <main>
      <p class="spec">404 — nothing hangs here</p>
      <h1 class="mark">Lost<span class="dot">.</span></h1>
      <nav class="ways" aria-label="Ways out">
        <a href="/">index</a>
        <a href="/work">work</a>
        <a href="/lab">lab</a>
      </nav>
    </main>

    <style is:inline>
      :root {
        --paper: #FAFAF7; --ink: #101010;
        --soft: rgba(16,16,16,0.66);
        --faint: rgba(16,16,16,0.62);
        --hair: rgba(0,0,0,0.14);
        --tint: rgba(16,16,16,0.04);
      }
      html[data-theme="dark"] {
        --paper: #101010; --ink: #FAFAF7;
        --soft: rgba(250,250,247,0.62);
        --faint: rgba(250,250,247,0.55);
        --hair: rgba(255,255,255,0.16);
        --tint: rgba(250,250,247,0.05);
      }
      html[data-theme="red"] {
        --paper: #E0301F; --ink: #0A0A0A;
        --soft: rgba(10,10,10,0.78);
        --faint: rgba(10,10,10,0.72);
        --hair: rgba(0,0,0,0.25);
        --tint: rgba(0,0,0,0.06);
      }
      html { background: var(--paper); }
      body { color: var(--ink); }
      ::selection { background: var(--ink); color: var(--paper); }

      * { margin: 0; box-sizing: border-box; }
      body { font-family: 'Space Mono', ui-monospace, monospace; -webkit-font-smoothing: antialiased; }
      a { color: inherit; text-decoration: none; }
      main { min-height: 100svh; display: grid; place-content: center; justify-items: center; text-align: center; gap: 18px; padding: 6vw; }
      .spec { font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--faint); }
      .mark { font-weight: 700; font-size: clamp(64px, 16vw, 200px); line-height: 0.95; }
      .dot { color: var(--faint); }
      .ways { display: flex; gap: 26px; margin-top: 14px; font-family: 'Space Mono', monospace; font-size: 13px; }
      .ways a { display: inline-block; padding: 14px 8px; margin: -14px -8px; }
      .ways a:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }
      @media (hover: hover) and (pointer: fine) {
        .ways a:hover { text-decoration: underline; text-underline-offset: 4px; }
      }
    </style>
  </body>
</html>
