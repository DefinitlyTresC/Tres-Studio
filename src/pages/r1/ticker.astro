---
// R1 prototype — the visitor ticker, flat edition (per Tres: "too 3d, make it
// a flat card that flips over naturally"). Each digit is a flat monochrome
// card with a seam; on change it collapses edge-on and reopens with the new
// value — a card flip with zero skeuomorphism. Real data from the existing
// pulse function; degrades to invisible exactly like counter.js does.
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FFEDDB" />
    <title>Ticker — R1 · Tres.</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600&family=Newsreader:ital,opsz,wght@1,16..72,400&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/v2-tokens.css" />
  </head>
  <body>
    <main>
      <p class="spec">R1 · prototype — the ticker</p>
      <h1 class="name">Visits, counted like it's 1962</h1>
      <p class="lede">
        Bottom right. It fetches the real total and flips up to it, one digit
        card at a time — the ones place leads, the rest follow only when they
        turn over. <a href="/r1">Back to index</a>.
      </p>
      <button class="crank" id="crank" type="button">advance one — demo</button>
    </main>

    <div class="tick" id="tick" aria-live="polite" aria-label="Total site visits">
      <span class="cells" id="cells"></span>
      <span class="lbl">visits</span>
    </div>

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }
      html { background: var(--v2-cream, #FFEDDB); }
      body {
        font-family: var(--v2-body, Georgia, serif);
        color: var(--v2-ink, #2B1F1A);
        -webkit-font-smoothing: antialiased;
        min-height: 100svh;
      }
      ::selection { background: var(--v2-sand, #EDCDBB); }
      a { color: inherit; }

      main { max-width: 560px; margin: 0 auto; padding: 20svh var(--v2-pad, 24px); }
      .spec { font-family: var(--v2-mono, monospace); font-size: 12px; color: var(--v2-ink-soft, #6b5c54); }
      .name {
        font-family: var(--v2-display, sans-serif); font-weight: 600;
        font-size: clamp(30px, 5.4vw, 48px); line-height: 1.02;
        text-transform: uppercase; text-wrap: balance; margin-top: 10px;
      }
      .lede { font-size: 18px; font-style: italic; line-height: 1.55; color: var(--v2-ink-soft, #6b5c54); margin-top: 16px; max-width: 44ch; text-wrap: pretty; }
      .crank {
        margin-top: 6svh;
        font-family: var(--v2-mono, monospace); font-size: 13px;
        color: var(--v2-ink, #2B1F1A);
        background: none; border: none; cursor: pointer;
        padding: 12px 0; /* quiet text control, full 44px hit height */
        text-decoration: underline; text-underline-offset: 4px;
        transition: transform var(--v2-press, 140ms) var(--v2-out, ease-out);
      }
      .crank:active { transform: scale(0.96); }

      /* ── the ticker ─────────────────────────────────────────────────── */
      .tick {
        position: fixed;
        right: max(16px, env(safe-area-inset-right, 0px));
        bottom: max(16px, env(safe-area-inset-bottom, 0px));
        display: flex; align-items: baseline; gap: 8px;
        opacity: 0; translate: 0 6px;
        transition: opacity 300ms var(--v2-out, ease-out), translate 300ms var(--v2-out, ease-out);
      }
      .tick.in { opacity: 1; translate: 0 0; }
      .cells { display: inline-flex; gap: 3px; }
      .cell {
        position: relative;
        width: 1.35ch; padding: 5px 3px;
        font-family: var(--v2-mono, monospace); font-weight: 700; font-size: 15px;
        font-variant-numeric: tabular-nums;
        line-height: 1; text-align: center;
        background: #fff; color: #111;
        border: 1px solid rgba(0, 0, 0, 0.28);
        border-radius: 3px;
        transition: transform 90ms var(--v2-inout, ease-in-out);
      }
      .cell::after { /* the seam that makes a card read as a flap */
        content: '';
        position: absolute; left: 0; right: 0; top: 50%;
        border-top: 1px solid rgba(0, 0, 0, 0.14);
      }
      .cell.mid { transform: scaleY(0.06); } /* edge-on — the flip's midpoint */
      .lbl {
        font-family: var(--v2-mono, monospace); font-size: 10px;
        letter-spacing: 0.14em; text-transform: uppercase;
        color: var(--v2-ink-soft, #6b5c54);
      }

      @media (prefers-reduced-motion: reduce) {
        .cell { transition: none; }
        .tick { transition: opacity 200ms ease; }
      }
    </style>

    <script is:inline>
      (function () {
        'use strict';
        var ENDPOINT = '/.netlify/functions/pulse';
        var PAD = 5;
        var reduce = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}

        /* Same session key as the live counter — visiting this page never
           double-counts. */
        var sid;
        try {
          sid = sessionStorage.getItem('ts_sid');
          if (!sid) {
            sid = Date.now().toString(36) + Math.random().toString(36).slice(2, 10);
            sessionStorage.setItem('ts_sid', sid);
          }
        } catch (e) { sid = String(Math.random()).slice(2); }

        var tick = document.getElementById('tick');
        var cellsWrap = document.getElementById('cells');
        var shown = null; /* digits currently displayed, as a string */

        function ensureCells(n) {
          while (cellsWrap.children.length < n) {
            var c = document.createElement('span');
            c.className = 'cell';
            c.textContent = '0';
            cellsWrap.insertBefore(c, cellsWrap.firstChild);
          }
        }

        /* One digit card flip: collapse edge-on, swap, reopen. Two 90ms
           halves; CSS transition handles both directions, so rapid updates
           interrupt cleanly instead of queueing. */
        function flipCell(cell, digit) {
          if (reduce) { cell.textContent = digit; return; }
          if (cell._t) clearTimeout(cell._t); /* rapid updates retarget, never race */
          cell.classList.add('mid');
          cell._t = setTimeout(function () {
            cell.textContent = digit;
            cell.classList.remove('mid');
            cell._t = null;
          }, 95);
        }

        function show(total) {
          var str = String(Math.max(0, Math.floor(total)));
          if (str.length < PAD) str = ('00000' + str).slice(-Math.max(PAD, str.length));
          ensureCells(str.length);
          var cells = cellsWrap.children;
          var delay = 0;
          for (var i = str.length - 1; i >= 0; i--) { /* ones place leads */
            (function (cell, digit, d) {
              if (cell.textContent === digit) return;
              if (reduce || d === 0) flipCell(cell, digit);
              else setTimeout(function () { flipCell(cell, digit); }, d);
            })(cells[i], str[i], delay);
            if (cells[i].textContent !== str[i]) delay += 40;
          }
          shown = str;
        }

        /* Ease from the last-seen value up to the real one in a handful of
           flips rather than every integer — calm, not frantic. */
        function rollTo(target) {
          var from = 0;
          try { from = parseInt(localStorage.getItem('ts_v2_ticker') || '0', 10) || 0; } catch (e) {}
          if (from > target) from = 0;
          try { localStorage.setItem('ts_v2_ticker', String(target)); } catch (e) {}
          if (reduce || target - from < 2) { show(target); return; }
          var steps = Math.min(9, target - from);
          var i = 0;
          (function next() {
            i++;
            var p = i / steps;
            var eased = 1 - Math.pow(1 - p, 3);
            show(Math.round(from + (target - from) * eased));
            if (i < steps) setTimeout(next, 110 + 90 * p); /* decelerate */
          })();
        }

        var real = 0;
        fetch(ENDPOINT + '?sid=' + encodeURIComponent(sid), { cache: 'no-store' })
          .then(function (r) { return r.ok ? r.json() : null; })
          .then(function (data) {
            if (!data || typeof data.total !== 'number') return; /* stay hidden */
            real = data.total;
            tick.classList.add('in');
            rollTo(real);
          })
          .catch(function () { /* silent, like the real counter */ });

        /* demo crank — local only, so the flip can be felt repeatedly */
        document.getElementById('crank').addEventListener('click', function () {
          real += 1;
          tick.classList.add('in');
          show(real);
        });
      })();
    </script>
  </body>
</html>
