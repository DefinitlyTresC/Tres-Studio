---
// R1 prototype — tracking back button, simplified per Tres's review:
// keep the Y-tracking with its mechanical lag; drop the ring, the lean, the
// arrow gymnastics. A quiet sand pill with an arrow. On touch it just sits
// still where a thumb can reach it.
import { getCollection } from 'astro:content';

const WORK = ['z07', 'ee13', 'flatwood', 'tucker', 'thesis'];
const all = await getCollection('projects');
const projects = WORK.map((slug) => all.find((p) => p.id === slug)?.data).filter(Boolean);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FFEDDB" />
    <title>Tracking button — R1 · Tres.</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600&family=Newsreader:ital,opsz,wght@0,16..72,400;1,16..72,400&family=Space+Mono&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/v2-tokens.css" />
  </head>
  <body>
    <div class="rail">
      <a class="track-back" id="trackBack" href="/r1">
        <span class="arr" aria-hidden="true">←</span>
        <span>Back</span>
      </a>
    </div>

    <main>
      <p class="spec">R1 · prototype — the back control</p>
      <p class="lede">
        Plain text, no pill. On a laptop it follows your cursor down the left
        rail, a beat behind. On a phone it stays put, where a thumb can reach
        it. Pressing it goes back to the index — it is a real control, not a
        demo of one.
      </p>

      {projects.map((p) => (
        <article class="row">
          <h2 class="name">{p.name}</h2>
          <p class="meta">{p.year}{p.location ? ` · ${p.location}` : ''}</p>
          <p class="body">
            {p.description ? p.description.slice(0, 220) : 'Placeholder reading content so the page is tall enough to scroll against.'}
          </p>
        </article>
      ))}
    </main>

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }
      html { background: var(--v2-cream, #FFEDDB); }
      body {
        font-family: var(--v2-body, Georgia, serif);
        color: var(--v2-ink, #2B1F1A);
        -webkit-font-smoothing: antialiased;
      }
      ::selection { background: var(--v2-sand, #EDCDBB); }

      .rail {
        position: fixed; top: 0; left: 0; bottom: 0;
        width: clamp(76px, 12vw, 140px);
        z-index: 2;
      }
      .track-back {
        position: absolute;
        top: var(--y, var(--v2-pad, 24px));
        left: max(14px, calc(var(--v2-pad, 24px) * 0.5));
        display: inline-flex; align-items: center; gap: 6px;
        min-height: 44px; padding: 10px 4px;
        color: var(--v2-ink, #2B1F1A);
        font-family: var(--v2-mono, monospace); font-size: 13px;
        text-decoration: none;
        transition: transform var(--v2-press, 140ms) var(--v2-out, ease-out);
      }
      .track-back:active { transform: scale(0.96); }
      @media (hover: hover) and (pointer: fine) {
        .track-back:hover { text-decoration: underline; text-underline-offset: 4px; }
      }
      .track-back:focus-visible {
        outline: 2px solid var(--v2-ink, #2B1F1A);
        outline-offset: 3px;
      }

      main {
        max-width: 620px;
        margin: 0 auto;
        padding: 16svh var(--v2-pad, 24px) 20svh calc(clamp(76px, 12vw, 140px) + var(--v2-pad, 24px));
      }
      @media (max-width: 700px) {
        main { padding-left: var(--v2-pad, 24px); padding-top: 22svh; }
      }
      .spec { font-family: var(--v2-mono, monospace); font-size: 12px; color: var(--v2-ink-soft, #6b5c54); }
      .lede { font-size: 19px; font-style: italic; margin: 14px 0 10svh; max-width: 44ch; text-wrap: pretty; color: var(--v2-ink-soft, #6b5c54); }
      .row { padding: 5svh 0; border-top: 1px solid var(--v2-hairline, rgba(43,31,26,0.16)); }
      .name {
        font-family: var(--v2-display, sans-serif); font-weight: 600;
        font-size: clamp(26px, 4.4vw, 40px); line-height: 1.02;
        text-transform: uppercase; text-wrap: balance;
      }
      .meta { font-family: var(--v2-mono, monospace); font-size: 12px; color: var(--v2-ink-soft, #6b5c54); margin-top: 6px; }
      .body { font-size: 17px; line-height: 1.55; margin-top: 14px; max-width: 52ch; text-wrap: pretty; }
    </style>

    <script is:inline>
      (function () {
        'use strict';
        var canTrack = false, reduce = false;
        try {
          canTrack = matchMedia('(hover: hover) and (pointer: fine)').matches;
          reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
        } catch (e) {}
        if (!canTrack || reduce) return; /* touch / reduced motion: it just sits still */

        var btn = document.getElementById('trackBack');
        if (!btn) return;
        var target = null, cur = null, raf = null;

        function frame() {
          cur += (target - cur) * 0.09; /* the lag is the feel — do not rush it */
          btn.style.setProperty('--y', cur.toFixed(1) + 'px');
          if (Math.abs(target - cur) > 0.4) raf = requestAnimationFrame(frame);
          else raf = null;
        }
        addEventListener('pointermove', function (e) {
          var h = btn.offsetHeight;
          var max = innerHeight - h - 16;
          target = Math.min(max, Math.max(16, e.clientY - h / 2));
          if (cur === null) cur = target;
          if (!raf) raf = requestAnimationFrame(frame);
        }, { passive: true });
      })();
    </script>
  </body>
</html>
