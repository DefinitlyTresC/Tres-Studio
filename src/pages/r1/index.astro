---
// ============================================================
// R1 PROTOTYPE HUB — /r1
// ------------------------------------------------------------
// A small, handsome index for the four R1 rebrand motion/system
// prototypes. Light "drawing-set" V2 identity. Fully self-contained:
// own <head>, own <style is:inline>. Links the shared V2 token layer
// (public copy) so it renders without the bundler. Does NOT use
// Base.astro and touches no V1 asset.
//
// These pages are PROTOTYPES for Tres to feel on his phone — decision
// aids, not the real site.
// ============================================================

// The four prototypes, each with a one-line "what to feel" and a
// spec-label index so the list reads like a drawing-set titleblock.
const PROTOS = [
  {
    idx: '01',
    href: '/r1/tokens',
    name: 'Tokens',
    label: 'Palette + type directions',
    feel: 'Pick the ink (A / B) and a type direction (1 / 2) — the whole system hangs off these two calls.',
  },
  {
    idx: '02',
    href: '/r1/blob',
    name: 'Blob scroll',
    label: 'The Work five, in motion',
    feel: 'Scroll the five Work projects — imagery flows behind a soft ragged edge that never touches the text.',
  },
  {
    idx: '03',
    href: '/r1/button',
    name: 'Tracking button',
    label: 'The back control',
    feel: 'A back control that leans toward your thumb; steady and reachable no matter how far you scroll.',
  },
  {
    idx: '04',
    href: '/r1/ticker',
    name: 'Ticker',
    label: 'Mechanical counter',
    feel: 'A black-and-white odometer that rolls the visitor count over with a crisp, drafting-machine snap.',
  },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>R1 Prototypes — tres.studio</title>
<meta name="robots" content="noindex" />
<meta name="description" content="R1 rebrand motion & design-system prototypes for tres.studio. Prototypes, not the site." />
<link rel="stylesheet" href="/v2-tokens.css" />
<style is:inline>
  *, *::before, *::after { box-sizing: border-box; }

  html { -webkit-text-size-adjust: 100%; }

  body {
    margin: 0;
    min-height: 100dvh;
    background: var(--v2-bg);
    color: var(--v2-ink);
    font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    font-size: var(--v2-fs-body);
    line-height: var(--v2-lh-normal);
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  .mono {
    font-family: ui-monospace, "SF Mono", "SFMono-Regular", Menlo, Consolas, monospace;
  }

  .wrap {
    max-width: var(--v2-maxw);
    margin-inline: auto;
    padding: var(--v2-space-8) var(--v2-gutter) var(--v2-space-9);
  }

  /* --- Header / titleblock --- */
  header { margin-bottom: var(--v2-space-8); }

  .eyebrow {
    font-family: ui-monospace, "SF Mono", "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: var(--v2-fs-spec);
    letter-spacing: var(--v2-tracking-wide);
    text-transform: uppercase;
    color: var(--v2-ink-muted);
    margin: 0 0 var(--v2-space-4);
  }

  h1 {
    font-size: var(--v2-fs-display);
    line-height: var(--v2-lh-tight);
    letter-spacing: var(--v2-tracking-display);
    font-weight: var(--v2-weight-display);
    margin: 0 0 var(--v2-space-5);
  }

  .lede {
    max-width: var(--v2-maxw-text);
    font-size: var(--v2-fs-body-lg);
    color: var(--v2-ink-muted);
    margin: 0;
  }

  .rule {
    height: var(--v2-hairline-w);
    background: var(--v2-line);
    border: 0;
    margin: var(--v2-space-7) 0 0;
  }

  /* --- Prototype list --- */
  .list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: var(--v2-hairline-w) solid var(--v2-line);
  }

  .item { border-bottom: var(--v2-hairline-w) solid var(--v2-line); }

  .card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: var(--v2-space-3) var(--v2-space-5);
    padding: var(--v2-space-6) var(--v2-space-2);
    text-decoration: none;
    color: inherit;
    position: relative;
    transition: background var(--v2-dur-base) var(--v2-ease-mechanical),
                padding-left var(--v2-dur-base) var(--v2-ease-mechanical);
    /* generous touch target */
    min-height: 44px;
    -webkit-tap-highlight-color: transparent;
  }

  .num {
    font-family: ui-monospace, "SF Mono", "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: var(--v2-fs-spec);
    letter-spacing: var(--v2-tracking-spec);
    color: var(--v2-ink-faint);
    padding-top: 0.35em;
  }

  .body { grid-column: 2; min-width: 0; }

  .name {
    font-size: var(--v2-fs-h2);
    line-height: var(--v2-lh-snug);
    font-weight: var(--v2-weight-medium);
    margin: 0;
  }

  .route {
    font-family: ui-monospace, "SF Mono", "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: var(--v2-fs-spec);
    letter-spacing: var(--v2-tracking-spec);
    color: var(--v2-umber);
    text-transform: uppercase;
  }

  .feel {
    margin: var(--v2-space-3) 0 0;
    color: var(--v2-ink-muted);
    font-size: var(--v2-fs-body);
    max-width: 44ch;
  }

  .label {
    grid-column: 2;
    font-family: ui-monospace, "SF Mono", "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: var(--v2-fs-spec);
    letter-spacing: var(--v2-tracking-spec);
    text-transform: uppercase;
    color: var(--v2-ink-faint);
    margin: 0 0 var(--v2-space-2);
  }

  .arrow {
    grid-column: 3;
    grid-row: 1 / span 3;
    align-self: center;
    font-size: var(--v2-fs-h3);
    color: var(--v2-ink-faint);
    transition: transform var(--v2-dur-base) var(--v2-ease-mechanical),
                color var(--v2-dur-base) var(--v2-ease-mechanical);
  }

  /* Hover / focus: hairline-precise nudge, no spectacle. */
  @media (hover: hover) and (pointer: fine) {
    .card:hover { background: var(--v2-surface); padding-left: var(--v2-space-4); }
    .card:hover .arrow { transform: translateX(4px); color: var(--v2-umber); }
    .card:hover .route { text-decoration: underline; text-underline-offset: 3px; }
  }

  .card:active { background: var(--v2-surface); }

  .card:focus-visible {
    outline: none;
    box-shadow: var(--v2-focus-ring);
    border-radius: var(--v2-radius-sm);
  }

  /* --- Footer note --- */
  footer {
    margin-top: var(--v2-space-8);
    padding-top: var(--v2-space-5);
    border-top: var(--v2-hairline-w) solid var(--v2-line);
    color: var(--v2-ink-muted);
    font-size: var(--v2-fs-caption);
  }

  footer strong { color: var(--v2-ink); font-weight: var(--v2-weight-medium); }

  @media (prefers-reduced-motion: reduce) {
    .card, .arrow { transition: none; }
  }
</style>
</head>
<body>
  <main class="wrap">
    <header>
      <p class="eyebrow">tres.studio · rebrand · R1</p>
      <h1>Motion &amp; system prototypes</h1>
      <p class="lede">
        Four isolated prototypes in the light &ldquo;drawing-set&rdquo; identity.
        Built to feel on a phone before anything real gets made. Tap each, then
        tell me what lands.
      </p>
      <hr class="rule" />
    </header>

    <ul class="list">
      {PROTOS.map((p) => (
        <li class="item">
          <a class="card" href={p.href}>
            <span class="num mono">{p.idx}</span>
            <p class="label">{p.label}</p>
            <div class="body">
              <h2 class="name">{p.name} <span class="route">{p.href}</span></h2>
              <p class="feel">{p.feel}</p>
            </div>
            <span class="arrow" aria-hidden="true">&rarr;</span>
          </a>
        </li>
      ))}
    </ul>

    <footer>
      <p>
        <strong>These are prototypes, not the site.</strong> Isolated pages on the
        <span class="mono">astro-migration</span> branch for R1 sign-off &mdash;
        palette locked, ink &amp; type &amp; motion still up for a decision. Nothing
        here is wired into the live navigation.
      </p>
    </footer>
  </main>
</body>
</html>
