---
// ============================================================
// R1 PROTOTYPE — /r1/blob  ·  "BLOB SCROLL"
// ------------------------------------------------------------
// A vertical scroll through the five Work projects. Each project is one
// full-viewport-ish moment: the hero photo is masked by an organic BLOB
// (SVG clipPath) whose edge subtly morphs/breathes as you scroll, while
// scroll progress drives a gentle image parallax. The project name + a
// mono spec-line (year · location) sit in CRISP TYPE *outside* the masked
// image — the blob is a layout treatment on imagery only and NEVER touches,
// distorts, or overlaps text.
//
// Fully self-contained: own <head>, own <style is:inline>, own <script
// is:inline>. Shares the token layer via <link href="/v2-tokens.css">
// (public copy) so it renders without the bundler. Does NOT use Base.astro
// and does NOT touch any V1 page/layout/style.
//
// Motion budget / rules honored:
//   - Native touch scroll only. No scroll-jacking, no scroll-snap trapping.
//   - Animates transforms/opacity + a cheap SVG path `d` swap (per-frame,
//     only for on/near-screen sections) — targets 60fps on a phone.
//   - prefers-reduced-motion: static soft-edged blob masks, no morph, no
//     parallax. Never broken.
//
// Real imagery: getCollection('projects') + heroUrl/heroUrlThumb. Falls back
// to a labelled Clay placeholder per slug if a hero can't be resolved at
// build time, so the page never breaks offline.
// ============================================================
import { getCollection } from 'astro:content';
import { heroUrl, heroUrlThumb } from '../../lib/cloudinary';
import type { Project } from '../../lib/sheet';

// The five Work projects, in the brief's discussion order.
const WORK_SLUGS = ['z07', 'ee13', 'flatwood', 'tucker', 'thesis'];

// Human-friendly fallback labels if the sheet snapshot lacks a slug.
const FALLBACK: Record<string, { name: string; year: string; location: string }> = {
  z07:      { name: 'Alys Beach Z-07',            year: '2023', location: 'Alys Beach, FL' },
  ee13:     { name: 'Alys Beach EE-13',           year: '2022', location: 'Alys Beach, FL' },
  flatwood: { name: 'Flatwood Residence',         year: '2021', location: 'Florida' },
  tucker:   { name: 'The Pointe at Tucker Landing', year: '2020', location: 'Tucker Landing' },
  thesis:   { name: 'Thesis Project',             year: '2019', location: 'Academic' },
};

let bySlug = new Map<string, Project>();
try {
  const all = await getCollection('projects');
  bySlug = new Map(all.map((e) => [e.data.slug, e.data]));
} catch {
  bySlug = new Map();
}

interface Moment {
  slug: string;
  index: string;   // "01".."05"
  name: string;
  spec: string;    // "year · location"
  src: string | null;
  srcSmall: string | null;
}

const moments: Moment[] = WORK_SLUGS.map((slug, i) => {
  const p = bySlug.get(slug);
  const fb = FALLBACK[slug];
  const name = (p?.name && p.name.trim()) || fb.name;
  const year = (p?.year && p.year.trim()) || fb.year;
  const location = (p?.location && p.location.trim()) || fb.location;
  const spec = [year, location].filter(Boolean).join('  ·  ');
  return {
    slug,
    index: String(i + 1).padStart(2, '0'),
    name,
    spec,
    src: p ? heroUrl(p) : null,
    srcSmall: p ? heroUrlThumb(p) : null,
  };
});

// Two organic blob outlines per moment (start + drift target). The runtime
// interpolates between them (and layers a small breathing offset), so the
// edge is always evolving but never spiky. Each path is a closed cubic loop
// authored in a 0..1000 square; the SVG clipPath uses clipPathUnits so it
// scales to whatever box it clips. Distinct silhouettes per index keep the
// five moments from feeling identical.
const BLOBS: [string, string][] = [
  [
    'M500,60 C760,60 940,210 940,470 C940,720 780,940 510,940 C250,940 70,760 70,500 C70,240 240,60 500,60 Z',
    'M500,40 C740,80 960,230 930,500 C905,740 800,930 490,955 C240,975 55,780 80,510 C100,250 260,0 500,40 Z',
  ],
  [
    'M520,50 C790,70 950,260 930,510 C912,745 790,955 500,935 C255,918 60,770 75,500 C90,235 250,30 520,50 Z',
    'M480,70 C760,40 955,250 945,520 C935,760 800,910 500,930 C230,948 50,740 70,480 C88,230 210,100 480,70 Z',
  ],
  [
    'M500,55 C775,45 930,235 935,500 C940,760 800,945 505,940 C245,935 65,745 65,490 C65,235 225,65 500,55 Z',
    'M515,45 C800,80 940,270 920,530 C902,770 770,940 490,930 C235,921 55,730 80,470 C102,225 235,10 515,45 Z',
  ],
  [
    'M490,50 C765,55 945,220 940,490 C935,755 795,950 500,940 C240,931 60,760 70,495 C80,240 220,45 490,50 Z',
    'M505,65 C790,45 930,255 935,515 C940,765 810,930 500,945 C245,959 50,755 75,485 C98,225 220,85 505,65 Z',
  ],
  [
    'M500,45 C780,60 940,245 925,510 C910,760 790,945 500,935 C250,926 70,755 78,490 C86,230 220,30 500,45 Z',
    'M485,55 C775,35 955,240 940,505 C926,755 800,955 495,940 C235,926 55,745 72,480 C90,220 195,75 485,55 Z',
  ],
];
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<title>R1 · Blob Scroll — tres.studio</title>
<meta name="robots" content="noindex" />
<meta name="theme-color" content="#FFEDDB" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<!-- Draughtsman's Grotesque direction: Archivo (display) + Space Mono (spec). -->
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />

<link rel="stylesheet" href="/v2-tokens.css" />

<style is:inline>
  *, *::before, *::after { box-sizing: border-box; }

  html { scroll-behavior: auto; }

  body {
    margin: 0;
    background: var(--v2-cream);
    color: var(--v2-ink);
    font-family: 'Archivo', system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    /* iOS: keep native momentum scroll, no jacking. */
    -webkit-text-size-adjust: 100%;
  }

  /* ---- fixed drawing-set chrome (does not scroll) ---- */
  .hud {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 40;
    padding: max(var(--v2-space-4), env(safe-area-inset-top))
             max(var(--v2-space-4), env(safe-area-inset-right))
             max(var(--v2-space-4), env(safe-area-inset-bottom))
             max(var(--v2-space-4), env(safe-area-inset-left));
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .hud-row { display: flex; justify-content: space-between; align-items: baseline; }
  .hud-mark {
    font-family: 'Space Mono', monospace;
    font-size: var(--v2-fs-spec);
    letter-spacing: var(--v2-tracking-spec);
    text-transform: uppercase;
    color: var(--v2-ink-muted);
  }
  .hud-count {
    font-family: 'Space Mono', monospace;
    font-size: var(--v2-fs-spec);
    letter-spacing: var(--v2-tracking-spec);
    color: var(--v2-ink-muted);
  }
  .hud-count b { color: var(--v2-ink); font-weight: 700; }

  /* thin scroll-progress rule pinned to the very top */
  .progress {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--v2-umber);
    transform: scaleX(0);
    transform-origin: 0 50%;
    z-index: 50;
    will-change: transform;
  }

  /* ---- one project moment ---- */
  .moment {
    min-height: 100svh;
    display: grid;
    grid-template-rows: 1fr auto;
    align-items: center;
    padding:
      calc(env(safe-area-inset-top) + var(--v2-space-8))
      var(--v2-gutter)
      calc(env(safe-area-inset-bottom) + var(--v2-space-7));
    position: relative;
  }

  /* The masked-image stage. The blob clip lives on .blob-img. Text is a
     SEPARATE sibling below/around it and is never clipped. */
  .stage {
    position: relative;
    width: 100%;
    max-width: 560px;
    margin: 0 auto;
    aspect-ratio: 1 / 1;
    justify-self: center;
    align-self: center;
  }

  /* faint drafted guide ring behind the blob — pure decoration, drawing-set */
  .stage-ring {
    position: absolute;
    inset: 4%;
    border: var(--v2-hairline-w) solid var(--v2-line);
    border-radius: 50%;
    opacity: 0.5;
  }

  .blob-clip {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    pointer-events: none;
  }

  .blob-img {
    position: absolute;
    /* oversize so parallax translate never reveals an edge inside the blob */
    inset: -9%;
    width: 118%;
    height: 118%;
    object-fit: cover;
    display: block;
    /* clipped by the per-moment SVG path */
    -webkit-clip-path: var(--clip);
    clip-path: var(--clip);
    will-change: transform;
    transform: translate3d(0,0,0);
    background: var(--v2-clay);
  }
  /* labelled placeholder when no hero resolves */
  .blob-img.is-fallback {
    display: grid;
    place-items: center;
    color: var(--v2-cream);
    font-family: 'Space Mono', monospace;
    letter-spacing: var(--v2-tracking-spec);
    text-transform: uppercase;
    font-size: var(--v2-fs-caption);
    background:
      repeating-linear-gradient(45deg,
        rgba(255,237,219,0.10) 0 10px, rgba(255,237,219,0) 10px 20px),
      var(--v2-umber);
  }

  /* the inline SVG that HOLDS the clip paths — zero-size, off the flow */
  .clip-defs { position: absolute; width: 0; height: 0; overflow: hidden; }

  /* ---- crisp type block, OUTSIDE the mask ---- */
  .caption {
    justify-self: center;
    align-self: end;
    width: 100%;
    max-width: 560px;
    margin-top: var(--v2-space-6);
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: var(--v2-space-4);
    align-items: baseline;
    border-top: var(--v2-hairline-w) solid var(--v2-line);
    padding-top: var(--v2-space-4);
  }
  .caption-index {
    font-family: 'Space Mono', monospace;
    font-size: var(--v2-fs-spec);
    letter-spacing: var(--v2-tracking-spec);
    color: var(--v2-umber);
    font-weight: 700;
    grid-row: 1 / span 2;
  }
  .caption-name {
    font-family: 'Archivo', system-ui, sans-serif;
    font-weight: var(--v2-weight-display);
    font-size: var(--v2-fs-h2);
    line-height: var(--v2-lh-snug);
    letter-spacing: var(--v2-tracking-display);
    margin: 0;
  }
  .caption-spec {
    font-family: 'Space Mono', monospace;
    font-size: var(--v2-fs-spec);
    letter-spacing: var(--v2-tracking-spec);
    text-transform: uppercase;
    color: var(--v2-ink-muted);
    margin-top: var(--v2-space-2);
  }

  /* end plate after the five moments */
  .outro {
    min-height: 60svh;
    display: grid;
    place-items: center;
    text-align: center;
    padding: var(--v2-space-9) var(--v2-gutter)
             calc(env(safe-area-inset-bottom) + var(--v2-space-9));
    gap: var(--v2-space-3);
  }
  .outro-kicker {
    font-family: 'Space Mono', monospace;
    font-size: var(--v2-fs-spec);
    letter-spacing: var(--v2-tracking-wide);
    text-transform: uppercase;
    color: var(--v2-ink-faint);
  }
  .outro-line {
    font-family: 'Archivo', system-ui, sans-serif;
    font-weight: var(--v2-weight-display);
    font-size: var(--v2-fs-h3);
    letter-spacing: var(--v2-tracking-display);
    color: var(--v2-ink);
    margin: 0;
  }

  @media (min-width: 900px) {
    /* on wide screens, set the caption beside the blob rather than under it,
       so the type stays large and the image stays generous — still no overlap. */
    .moment { grid-template-rows: 1fr; }
    .moment-inner {
      width: 100%;
      max-width: var(--v2-maxw);
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      align-items: center;
      column-gap: var(--v2-space-9);
    }
    .stage { margin: 0; max-width: 620px; }
    .caption {
      align-self: center;
      margin-top: 0;
      border-top: none;
      border-left: var(--v2-hairline-w) solid var(--v2-line);
      padding-top: 0;
      padding-left: var(--v2-space-6);
      grid-template-columns: auto;
      row-gap: var(--v2-space-3);
    }
    .caption-index { grid-row: auto; }
    .caption-name { font-size: var(--v2-fs-h1); }
  }
  @media (max-width: 899px) {
    .moment-inner { display: contents; }
  }

  /* ---- reduced motion: static soft edge, no morph, no parallax ---- */
  @media (prefers-reduced-motion: reduce) {
    .blob-img { transform: none !important; }
    .progress { transition: none; }
  }
</style>
</head>

<body>
  <div class="progress" id="progress" aria-hidden="true"></div>

  <div class="hud" aria-hidden="true">
    <div class="hud-row">
      <span class="hud-mark">Tres · Work</span>
      <span class="hud-mark">Blob Scroll</span>
    </div>
    <div class="hud-row">
      <span class="hud-mark">Scroll ↓</span>
      <span class="hud-count"><b id="hudCur">01</b> / {String(moments.length).padStart(2, '0')}</span>
    </div>
  </div>

  <!-- All clip paths live in one hidden SVG. clipPathUnits=objectBoundingBox
       lets a 0..1 path clip any-sized box; we author in a 0..1000 grid and
       divide at runtime, so keep the runtime authoritative. Static `d` here is
       the reduced-motion / no-JS fallback (start silhouette of each blob). -->
  <svg class="clip-defs" aria-hidden="true" focusable="false">
    <defs>
      {moments.map((m, i) => (
        <clipPath id={`blob-${i}`} clipPathUnits="objectBoundingBox">
          <path id={`blobpath-${i}`} d="M0.5,0.06 C0.76,0.06 0.94,0.21 0.94,0.47 C0.94,0.72 0.78,0.94 0.51,0.94 C0.25,0.94 0.07,0.76 0.07,0.5 C0.07,0.24 0.24,0.06 0.5,0.06 Z" />
        </clipPath>
      ))}
    </defs>
  </svg>

  <main id="content">
    {moments.map((m, i) => (
      <section class="moment" data-index={i} aria-label={`${m.name} — project ${m.index} of ${moments.length}`}>
        <div class="moment-inner">
          <div class="stage">
            <div class="stage-ring"></div>
            <div class="blob-clip">
              {m.src ? (
                <img
                  class="blob-img"
                  data-parallax
                  style={`--clip:url(#blob-${i})`}
                  src={m.src}
                  srcset={m.srcSmall ? `${m.srcSmall} 1800w, ${m.src} 2400w` : undefined}
                  sizes="(max-width: 899px) 92vw, 620px"
                  alt={m.name}
                  loading={i === 0 ? 'eager' : 'lazy'}
                  fetchpriority={i === 0 ? 'high' : undefined}
                  decoding="async"
                  onerror="this.classList.add('is-fallback');this.removeAttribute('src');this.removeAttribute('srcset');this.textContent=this.alt;"
                />
              ) : (
                <div class="blob-img is-fallback" data-parallax style={`--clip:url(#blob-${i})`}>{m.name}</div>
              )}
            </div>
          </div>

          <figcaption class="caption">
            <span class="caption-index">{m.index}</span>
            <div>
              <h2 class="caption-name">{m.name}</h2>
              <div class="caption-spec">{m.spec}</div>
            </div>
          </figcaption>
        </div>
      </section>
    ))}

    <section class="outro">
      <div class="outro-kicker">End of selected work</div>
      <p class="outro-line">Five projects. One continuous scroll.</p>
    </section>
  </main>

  <script is:inline define:vars={{ BLOBS }}>
    (function () {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');

      // Author paths in a 0..1000 grid; clipPathUnits is objectBoundingBox
      // (0..1), so we scale numbers by /1000 when writing `d`. Parsing the two
      // silhouettes into number arrays lets us lerp between them cheaply.
      function parseNums(d) {
        // capture command letters + all numbers, preserving order/structure
        const tokens = d.match(/[MCZ]|-?\d*\.?\d+/gi) || [];
        const nums = [];
        const shape = []; // 'cmd' | 'num'
        for (const t of tokens) {
          if (/[MCZ]/i.test(t)) shape.push({ cmd: t });
          else { shape.push({ i: nums.length }); nums.push(parseFloat(t)); }
        }
        return { nums, shape };
      }

      // Precompute per-moment start/end number arrays (same structure by design).
      const blobs = BLOBS.map(([a, b]) => {
        const A = parseNums(a);
        const B = parseNums(b);
        return { shape: A.shape, a: A.nums, b: B.nums };
      });

      const imgs = Array.from(document.querySelectorAll('[data-parallax]'));
      const paths = imgs.map((_, i) => document.getElementById('blobpath-' + i));
      const sections = Array.from(document.querySelectorAll('.moment'));
      const progressBar = document.getElementById('progress');
      const hudCur = document.getElementById('hudCur');

      // Rebuild a `d` string for moment i at mix m (0..1) plus a breathing
      // offset phase. Divides the 0..1000 grid down to 0..1 for objectBoundingBox.
      function buildD(i, mix, phase) {
        const blob = blobs[i];
        const { shape, a, b } = blob;
        let out = '';
        let k = 0; // number index
        // small per-vertex breathing: sinusoid keyed to number index so the
        // outline undulates instead of scaling uniformly. Amplitude tiny.
        for (const s of shape) {
          if (s.cmd) { out += s.cmd; }
          else {
            let v = a[k] + (b[k] - a[k]) * mix;
            const breathe = Math.sin(phase + k * 0.9) * 6; // ±6 in 1000-grid
            v = (v + breathe) / 1000;
            out += (out && !/[MCZ]$/i.test(out) ? ',' : '') + v.toFixed(4);
            k++;
          }
        }
        return out;
      }

      // Static render (reduced motion / initial paint): mid-mix, no breathing.
      function renderStatic() {
        for (let i = 0; i < paths.length; i++) {
          if (paths[i]) paths[i].setAttribute('d', buildD(i, 0.5, 0));
        }
      }
      renderStatic();

      if (reduce.matches) {
        // Static soft edge only. Still light up the progress bar + counter so
        // the page reads as intentional, but no morph, no parallax.
        let scheduled = false;
        function calm() {
          scheduled = false;
          const doc = document.documentElement;
          const max = doc.scrollHeight - window.innerHeight;
          const ratio = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
          progressBar.style.transform = 'scaleX(' + ratio + ')';
          updateCounter();
        }
        function onScrollCalm() { if (!scheduled) { scheduled = true; requestAnimationFrame(calm); } }
        window.addEventListener('scroll', onScrollCalm, { passive: true });
        window.addEventListener('resize', onScrollCalm);
        calm();
        return;
      }

      // ---- full motion path ----
      let vh = window.innerHeight;
      function onResize() { vh = window.innerHeight; }
      window.addEventListener('resize', onResize, { passive: true });

      function updateCounter() {
        // whichever section's centre is closest to viewport centre "wins"
        const mid = window.scrollY + vh / 2;
        let best = 0, bestDist = Infinity;
        for (let i = 0; i < sections.length; i++) {
          const r = sections[i].getBoundingClientRect();
          const c = window.scrollY + r.top + r.height / 2;
          const d = Math.abs(c - mid);
          if (d < bestDist) { bestDist = d; best = i; }
        }
        const label = String(best + 1).padStart(2, '0');
        if (hudCur.textContent !== label) hudCur.textContent = label;
      }

      // rAF loop: breathing phase advances slowly; scroll progress drives both
      // the morph-mix and image parallax. Only touches sections within ~1.4vh
      // of the viewport (cheap on a phone).
      let t0 = performance.now();
      let lastScrollY = -1;
      function frame(now) {
        const phase = (now - t0) / 1400;         // ~0.7 Hz breathing
        const sy = window.scrollY;

        for (let i = 0; i < imgs.length; i++) {
          const rect = sections[i].getBoundingClientRect();
          const top = rect.top;
          const h = rect.height || vh;
          // near-screen gate
          if (top > vh * 1.4 || top + h < -vh * 0.4) continue;

          // progress of this section through the viewport: 0 entering bottom,
          // 1 leaving top. Clamped.
          const p = Math.min(1, Math.max(0, (vh - top) / (vh + h)));

          // Blob mix: ease from a->b across the pass, so the silhouette
          // evolves as you scroll THROUGH the project (not just breathes).
          const mix = 0.5 + Math.sin((p * Math.PI) - Math.PI / 2) * 0.5; // 0..1 smooth
          const local = phase + i * 1.7; // desync sections
          if (paths[i]) paths[i].setAttribute('d', buildD(i, mix, local));

          // Parallax: image drifts opposite scroll within its blob window.
          // Transform only. Kept small so no blob edge is ever exposed.
          const py = (p - 0.5) * -46; // px
          imgs[i].style.transform = 'translate3d(0,' + py.toFixed(2) + 'px,0)';
        }

        if (sy !== lastScrollY) {
          lastScrollY = sy;
          const doc = document.documentElement;
          const max = doc.scrollHeight - vh;
          const ratio = max > 0 ? Math.min(1, Math.max(0, sy / max)) : 0;
          progressBar.style.transform = 'scaleX(' + ratio + ')';
          updateCounter();
        }

        requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);

      // If the user toggles Reduce Motion mid-session, reload behavior gracefully
      // by freezing to a static edge (paths already valid; just stop transforms).
      reduce.addEventListener?.('change', function (e) {
        if (e.matches) {
          for (const el of imgs) el.style.transform = 'none';
        }
      });
    })();
  </script>
</body>
</html>
