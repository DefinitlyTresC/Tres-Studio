---
// R1 prototype — blob scroll through the five Work projects.
// The mask is a two-radius organic shape that breathes very slowly; scroll
// drifts the photo inside it. Text never enters the mask. Native scroll only.
import { getCollection } from 'astro:content';
import { heroUrlThumb } from '../../lib/cloudinary';

const WORK = ['z07', 'ee13', 'flatwood', 'tucker', 'thesis'];
const all = await getCollection('projects');
const projects = WORK.map((slug) => all.find((p) => p.id === slug)?.data).filter(Boolean);

// Hand-tuned per-moment mask shapes: [resting radius, breathed radius, seconds].
// Different phase per project so no two moments pulse in sync.
const SHAPES = [
  ['63% 37% 54% 46% / 42% 61% 39% 58%', '38% 62% 43% 57% / 60% 39% 57% 40%', 11],
  ['41% 59% 63% 37% / 57% 42% 60% 43%', '62% 38% 42% 58% / 40% 60% 38% 60%', 13],
  ['57% 43% 38% 62% / 62% 55% 45% 38%', '39% 61% 59% 41% / 43% 39% 61% 57%', 12],
  ['64% 36% 45% 55% / 39% 57% 43% 61%', '40% 60% 61% 39% / 59% 41% 58% 42%', 14],
  ['39% 61% 58% 42% / 60% 38% 55% 45%', '61% 39% 40% 60% / 41% 62% 39% 59%', 12],
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FFEDDB" />
    <title>Blob scroll — R1 · Tres.</title>
    <link rel="preconnect" href="https://res.cloudinary.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600&family=Newsreader:ital,opsz,wght@1,16..72,400&family=Space+Mono&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/v2-tokens.css" />
  </head>
  <body>
    <header class="top">
      <a class="back" href="/r1">← index</a>
      <p class="hint">Scroll.</p>
    </header>

    <main>
      {projects.map((p, i) => (
        <section class="moment">
          <div
            class="stage"
            style={`--r0:${SHAPES[i][0]}; --r1:${SHAPES[i][1]}; --t:${SHAPES[i][2]}s;`}
          >
            <img
              class="ph"
              src={heroUrlThumb(p)}
              alt={p.name}
              loading={i === 0 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : 'auto'}
              decoding="async"
            />
          </div>
          <div class="caption">
            <p class="spec">{String(i + 1).padStart(2, '0')} — {p.year}{p.location ? ` · ${p.location}` : ''}</p>
            <h2 class="name">{p.name}</h2>
          </div>
        </section>
      ))}
    </main>

    <footer class="end">
      <p>Prototype only — judging the mask, the drift, the pace. <a href="/r1">Back to index</a>.</p>
    </footer>

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }
      html { background: var(--v2-cream, #FFEDDB); }
      body {
        font-family: var(--v2-body, Georgia, serif);
        color: var(--v2-ink, #2B1F1A);
        -webkit-font-smoothing: antialiased;
      }
      ::selection { background: var(--v2-sand, #EDCDBB); }
      a { color: inherit; }

      .top {
        position: fixed; inset: 0 0 auto 0; z-index: 2;
        display: flex; justify-content: space-between; align-items: baseline;
        padding: calc(var(--v2-pad, 24px) * 0.6) var(--v2-pad, 24px);
        pointer-events: none;
      }
      .back {
        pointer-events: auto;
        font-family: var(--v2-mono, monospace); font-size: 12px;
        text-decoration: none; padding: 10px 0; /* ≥40px hit area with line-height */
      }
      @media (hover: hover) and (pointer: fine) {
        .back:hover { text-decoration: underline; text-underline-offset: 4px; }
      }
      .hint { font-family: var(--v2-mono, monospace); font-size: 12px; color: var(--v2-ink-soft, #6b5c54); }

      .moment {
        min-height: 100svh;
        display: grid; place-content: center; justify-items: start;
        padding: var(--v2-pad, 24px);
      }
      .stage {
        width: min(88vw, 640px);
        height: min(64svh, 680px);
        border-radius: var(--r0);
        overflow: hidden;
        transform: translateZ(0); /* keep the mask clip on its own layer (iOS) */
      }
      .stage { animation: breathe var(--t, 12s) ease-in-out infinite alternate; }
      .stage.paused { animation-play-state: paused; }
      @keyframes breathe { to { border-radius: var(--r1); } }
      .ph {
        width: 100%; height: 100%;
        object-fit: cover;
        transform: translateY(var(--drift, 0)) scale(1.1); /* headroom so drift never shows edges */
        display: block;
      }

      .caption { max-width: min(88vw, 640px); margin-top: 18px; }
      .spec {
        font-family: var(--v2-mono, monospace); font-size: 12px;
        letter-spacing: 0.04em; color: var(--v2-ink-soft, #6b5c54);
      }
      .name {
        font-family: var(--v2-display, sans-serif); font-weight: 600;
        font-size: clamp(34px, 7vw, 68px); line-height: 0.98;
        text-transform: uppercase; letter-spacing: -0.01em;
        text-wrap: balance; margin-top: 6px;
      }

      .end { padding: 12svh var(--v2-pad, 24px) 16svh; }
      .end p { font-style: italic; font-size: 17px; color: var(--v2-ink-soft, #6b5c54); max-width: 46ch; text-wrap: pretty; }

      @media (prefers-reduced-motion: reduce) {
        .stage { animation: none; }
      }
    </style>

    <script is:inline>
      (function () {
        'use strict';
        var reduce = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}

        var stages = Array.prototype.slice.call(document.querySelectorAll('.stage'));

        // Masks breathe by default (CSS). The observer only PAUSES offscreen
        // ones to save paint — if it never fires, nothing visibly breaks.
        if (!reduce && 'IntersectionObserver' in window) {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (en) {
              en.target.classList.toggle('paused', !en.isIntersecting);
            });
          }, { rootMargin: '20% 0px' });
          stages.forEach(function (s) { io.observe(s); });
        }

        // Gentle drift: photo slides a few percent inside the mask as its
        // section crosses the viewport. Transform-only, one rAF, no listeners
        // firing layout work.
        if (!reduce) {
          var ticking = false;
          function drift() {
            ticking = false;
            var vh = innerHeight;
            for (var i = 0; i < stages.length; i++) {
              var r = stages[i].getBoundingClientRect();
              if (r.bottom < -80 || r.top > vh + 80) continue;
              var p = (r.top + r.height / 2 - vh / 2) / vh; /* -0.5 … 0.5-ish */
              var img = stages[i].firstElementChild;
              if (img) img.style.setProperty('--drift', (p * -7).toFixed(2) + '%');
            }
          }
          function onScroll() {
            if (!ticking) { ticking = true; requestAnimationFrame(drift); }
          }
          addEventListener('scroll', onScroll, { passive: true });
          drift();
        }
      })();
    </script>
  </body>
</html>
