---
// R1 prototype — blob scroll, round 2 (Tres's notes, 2026-07-02):
// faster jello masks, moments magnetized to alternating screen edges, ink
// particle dots orbiting the cursor near a mask's edge, click = fly through
// the opening to the real project page, text-only tracking back link.
import { getCollection } from 'astro:content';
import { heroUrlThumb } from '../../lib/cloudinary';

const WORK = ['z07', 'ee13', 'flatwood', 'tucker', 'thesis'];
const all = await getCollection('projects');
const projects = WORK.map((slug) => all.find((p) => p.id === slug)?.data).filter(Boolean);

// Per-moment character: three mask radii cycled by the jello loop + seconds,
// then which screen edge the blob clings to, its size, and how far past the
// edge it leans. No two moments share a rhythm or a footprint.
const SHAPES = [
  ['63% 37% 54% 46% / 42% 61% 39% 58%', '38% 62% 43% 57% / 60% 39% 57% 40%', '55% 45% 60% 40% / 39% 58% 42% 61%', 6.5],
  ['41% 59% 63% 37% / 57% 42% 60% 43%', '62% 38% 42% 58% / 40% 60% 38% 60%', '44% 56% 39% 61% / 61% 44% 57% 39%', 7.5],
  ['57% 43% 38% 62% / 62% 55% 45% 38%', '39% 61% 59% 41% / 43% 39% 61% 57%', '60% 40% 55% 45% / 40% 62% 38% 58%', 5.8],
  ['64% 36% 45% 55% / 39% 57% 43% 61%', '40% 60% 61% 39% / 59% 41% 58% 42%', '56% 44% 38% 62% / 62% 40% 59% 41%', 7.0],
  ['39% 61% 58% 42% / 60% 38% 55% 45%', '61% 39% 40% 60% / 41% 62% 39% 59%', '45% 55% 62% 38% / 57% 43% 41% 59%', 6.2],
];
const LAYOUT = [
  { side: 'left', w: 'min(82vw, 600px)', h: 'min(62svh, 660px)', peek: '9%' },
  { side: 'right', w: 'min(72vw, 520px)', h: 'min(52svh, 560px)', peek: '14%' },
  { side: 'left', w: 'min(90vw, 660px)', h: 'min(66svh, 700px)', peek: '7%' },
  { side: 'right', w: 'min(78vw, 560px)', h: 'min(57svh, 600px)', peek: '12%' },
  { side: 'left', w: 'min(86vw, 620px)', h: 'min(63svh, 670px)', peek: '10%' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FFEDDB" />
    <title>Blob scroll — R1 · Tres.</title>
    <link rel="preconnect" href="https://res.cloudinary.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600&family=Newsreader:ital,opsz,wght@1,16..72,400&family=Space+Mono&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/v2-tokens.css" />
  </head>
  <body>
    <a class="back" id="back" href="/r1">← index</a>
    <p class="hint">Scroll. Click one to go through it.</p>

    <main>
      {projects.map((p, i) => (
        <section class={`moment side-${LAYOUT[i].side}`}>
          <a
            class="stage-link"
            href={`/project/${WORK[i]}`}
            aria-label={`Open ${p.name}`}
            style={`--w:${LAYOUT[i].w}; --h:${LAYOUT[i].h}; --peek:${LAYOUT[i].peek};`}
          >
            <div
              class="stage"
              style={`--r0:${SHAPES[i][0]}; --r1:${SHAPES[i][1]}; --r2:${SHAPES[i][2]}; --t:${SHAPES[i][3]}s;`}
            >
              <img
                class="ph"
                src={heroUrlThumb(p)}
                alt={p.name}
                loading={i === 0 ? 'eager' : 'lazy'}
                fetchpriority={i === 0 ? 'high' : 'auto'}
                decoding="async"
              />
            </div>
          </a>
          <div class="caption">
            <p class="spec">{String(i + 1).padStart(2, '0')} — {p.year}{p.location ? ` · ${p.location}` : ''}</p>
            <h2 class="name">{p.name}</h2>
          </div>
        </section>
      ))}
    </main>

    <footer class="end">
      <p>Prototype — the mask, the pull to the edge, the dots, the way through. <a href="/r1">Back to index</a>.</p>
    </footer>

    <canvas id="dots" aria-hidden="true"></canvas>
    <div id="veil" aria-hidden="true"></div>

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }
      html { background: var(--v2-cream, #FFEDDB); }
      html, body { overflow-x: hidden; } /* blobs lean past the edges on purpose */
      body {
        font-family: var(--v2-body, Georgia, serif);
        color: var(--v2-ink, #2B1F1A);
        -webkit-font-smoothing: antialiased;
      }
      ::selection { background: var(--v2-sand, #EDCDBB); }
      a { color: inherit; }

      .back {
        position: fixed; z-index: 6;
        top: var(--y, calc(var(--v2-pad, 24px) * 0.6));
        left: var(--v2-pad, 24px);
        font-family: var(--v2-mono, monospace); font-size: 12px;
        text-decoration: none; padding: 12px 0; /* full-height thumb target */
        transition: transform var(--v2-press, 140ms) var(--v2-out, ease-out);
      }
      .back:active { transform: scale(0.96); }
      @media (hover: hover) and (pointer: fine) {
        .back:hover { text-decoration: underline; text-underline-offset: 4px; }
      }
      .back:focus-visible { outline: 2px solid var(--v2-ink, #2B1F1A); outline-offset: 3px; }
      .hint {
        position: fixed; z-index: 2;
        top: calc(var(--v2-pad, 24px) * 0.6); right: var(--v2-pad, 24px);
        font-family: var(--v2-mono, monospace); font-size: 12px;
        color: var(--v2-ink-soft, #6b5c54); padding: 12px 0;
      }

      .moment { min-height: 100svh; display: grid; align-content: center; padding: 6svh 0; }

      .stage-link {
        display: block; width: var(--w); height: var(--h);
        transition: transform 900ms var(--v2-out, ease-out);
      }
      .side-left .stage-link { margin-right: auto; margin-left: calc(var(--peek) * -1); }
      .side-right .stage-link { margin-left: auto; margin-right: calc(var(--peek) * -1); }
      /* .pre = a below-the-fold moment waiting its turn: its blob hangs toward
         center, and entering pulls it out to its edge — the magnet. Moments
         REST magnetized; JS only adds .pre where the flourish is safe. */
      html.js .moment.pre.side-left .stage-link { transform: translateX(14%); }
      html.js .moment.pre.side-right .stage-link { transform: translateX(-14%); }

      .stage {
        width: 100%; height: 100%;
        border-radius: var(--r0);
        overflow: hidden;
        transform: translateZ(0);
        animation: jello var(--t, 6.5s) ease-in-out infinite;
      }
      .stage.paused { animation-play-state: paused; }
      @keyframes jello {
        0%   { border-radius: var(--r0); }
        36%  { border-radius: var(--r1); }
        72%  { border-radius: var(--r2); }
        100% { border-radius: var(--r0); }
      }
      .ph {
        width: 100%; height: 100%;
        object-fit: cover; display: block;
        transform: translateY(var(--drift, 0)) scale(1.12);
      }

      /* the way through: the mask swallows the viewport, then we're gone */
      .stage.zoom {
        animation: none;
        transition: transform 620ms var(--v2-inout, ease-in-out);
        transform: scale(9);
        position: relative; z-index: 8;
      }
      #veil {
        position: fixed; inset: 0; z-index: 9;
        background: var(--v2-cream, #FFEDDB);
        opacity: 0; pointer-events: none;
        transition: opacity 280ms ease 300ms;
      }
      #veil.on { opacity: 1; }

      .caption { padding: 20px var(--v2-pad, 24px) 0; }
      .side-right .caption { text-align: right; }
      .spec {
        font-family: var(--v2-mono, monospace); font-size: 12px;
        letter-spacing: 0.04em; color: var(--v2-ink-soft, #6b5c54);
      }
      .name {
        font-family: var(--v2-display, sans-serif); font-weight: 600;
        font-size: clamp(34px, 7vw, 68px); line-height: 0.98;
        text-transform: uppercase; letter-spacing: -0.01em;
        text-wrap: balance; margin-top: 6px;
      }

      #dots { position: fixed; inset: 0; z-index: 5; pointer-events: none; }

      .end { padding: 10svh var(--v2-pad, 24px) 16svh; }
      .end p { font-style: italic; font-size: 17px; color: var(--v2-ink-soft, #6b5c54); max-width: 46ch; text-wrap: pretty; }

      @media (prefers-reduced-motion: reduce) {
        .stage { animation: none; }
        .stage-link { transition: none; }
        html.js .moment.pre .stage-link { transform: none; }
      }
    </style>

    <script is:inline>
      (function () {
        'use strict';
        var reduce = false, fine = false;
        try {
          reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
          fine = matchMedia('(hover: hover) and (pointer: fine)').matches;
        } catch (e) {}
        document.documentElement.classList.add('js');

        var moments = Array.prototype.slice.call(document.querySelectorAll('.moment'));
        var stages = Array.prototype.slice.call(document.querySelectorAll('.stage'));

        /* ── edge magnet: below-fold moments start pulled inward and snap to
           their edge on entry. Anything already visible (or if the observer
           never fires) simply rests magnetized — no failure mode. ────────── */
        if (!reduce && 'IntersectionObserver' in window) {
          moments.forEach(function (m) {
            if (m.getBoundingClientRect().top > innerHeight * 0.85) m.classList.add('pre');
          });
          var ioIn = new IntersectionObserver(function (entries) {
            entries.forEach(function (en) {
              if (en.isIntersecting) { en.target.classList.remove('pre'); ioIn.unobserve(en.target); }
            });
          }, { threshold: 0.18 });
          moments.forEach(function (m) { if (m.classList.contains('pre')) ioIn.observe(m); });

          /* pause offscreen jello — purely a paint saver */
          var ioPause = new IntersectionObserver(function (entries) {
            entries.forEach(function (en) {
              en.target.classList.toggle('paused', !en.isIntersecting);
            });
          }, { rootMargin: '25% 0px' });
          stages.forEach(function (s) { ioPause.observe(s); });
        }

        /* ── drift inside the mask on scroll ─────────────────────────────── */
        if (!reduce) {
          var ticking = false;
          function drift() {
            ticking = false;
            var vh = innerHeight;
            for (var i = 0; i < stages.length; i++) {
              var r = stages[i].getBoundingClientRect();
              if (r.bottom < -80 || r.top > vh + 80) continue;
              var p = (r.top + r.height / 2 - vh / 2) / vh;
              var img = stages[i].firstElementChild;
              if (img) img.style.setProperty('--drift', (p * -8).toFixed(2) + '%');
            }
          }
          addEventListener('scroll', function () {
            if (!ticking) { ticking = true; requestAnimationFrame(drift); }
          }, { passive: true });
          drift();
        }

        /* ── through the opening: click zooms into the mask, then leaves ─── */
        var leaving = false;
        Array.prototype.forEach.call(document.querySelectorAll('.stage-link'), function (a) {
          a.addEventListener('click', function (e) {
            if (reduce || leaving) return; /* reduced motion: plain navigation */
            leaving = true;
            e.preventDefault();
            a.querySelector('.stage').classList.add('zoom');
            document.getElementById('veil').classList.add('on');
            setTimeout(function () { location.href = a.href; }, 620);
          });
        });

        /* ── ink dots orbiting the cursor near a mask's edge ─────────────── */
        if (fine && !reduce) {
          var cv = document.getElementById('dots');
          var ctx = cv.getContext('2d');
          var dots = [], mx = -1e4, my = -1e4, raf = null, dpr = Math.min(2, devicePixelRatio || 1);
          function size() { cv.width = innerWidth * dpr; cv.height = innerHeight * dpr; }
          size();
          addEventListener('resize', size, { passive: true });

          function nearEdge(x, y) {
            for (var i = 0; i < stages.length; i++) {
              var r = stages[i].getBoundingClientRect();
              if (r.bottom < 0 || r.top > innerHeight) continue;
              var out = x > r.left - 64 && x < r.right + 64 && y > r.top - 64 && y < r.bottom + 64;
              var inn = x > r.left + 64 && x < r.right - 64 && y > r.top + 64 && y < r.bottom - 64;
              if (out && !inn) return true;
            }
            return false;
          }

          function frame() {
            ctx.clearRect(0, 0, cv.width, cv.height);
            var alive = false;
            for (var i = dots.length - 1; i >= 0; i--) {
              var d = dots[i];
              d.age += 16;
              if (d.age > d.life) { dots.splice(i, 1); continue; }
              alive = true;
              d.ang += d.spin;
              d.rad += d.grow;
              var x = mx + Math.cos(d.ang) * d.rad;
              var y = my + Math.sin(d.ang) * d.rad;
              var a = 1 - d.age / d.life;
              ctx.fillStyle = d.c === 1
                ? 'rgba(191, 146, 112,' + (a * 0.9).toFixed(3) + ')'   /* umber */
                : 'rgba(43, 31, 26,' + (a * 0.8).toFixed(3) + ')';     /* ink   */
              ctx.beginPath();
              ctx.arc(x * dpr, y * dpr, d.size * dpr, 0, 6.2832);
              ctx.fill();
            }
            raf = alive ? requestAnimationFrame(frame) : null;
          }

          addEventListener('pointermove', function (e) {
            mx = e.clientX; my = e.clientY;
            if (!nearEdge(mx, my) || dots.length > 70) { if (!raf && dots.length) raf = requestAnimationFrame(frame); return; }
            for (var n = 0; n < 2; n++) {
              dots.push({
                ang: Math.random() * 6.2832,
                rad: 6 + Math.random() * 22,
                spin: (Math.random() < 0.5 ? -1 : 1) * (0.05 + Math.random() * 0.08),
                grow: 0.25 + Math.random() * 0.5,
                size: 1.2 + Math.random() * 1.8,
                life: 650 + Math.random() * 550,
                age: 0,
                c: Math.random() < 0.22 ? 1 : 0,
              });
            }
            if (!raf) raf = requestAnimationFrame(frame);
          }, { passive: true });
        }

        /* ── back link tracks the cursor's Y (desktop only) ──────────────── */
        if (fine && !reduce) {
          var back = document.getElementById('back');
          var target = null, cur = null, braf = null;
          function bframe() {
            cur += (target - cur) * 0.09;
            back.style.setProperty('--y', cur.toFixed(1) + 'px');
            if (Math.abs(target - cur) > 0.4) braf = requestAnimationFrame(bframe);
            else braf = null;
          }
          addEventListener('pointermove', function (e) {
            var h = back.offsetHeight;
            target = Math.min(innerHeight - h - 12, Math.max(12, e.clientY - h / 2));
            if (cur === null) cur = target;
            if (!braf) braf = requestAnimationFrame(bframe);
          }, { passive: true });
        }
      })();
    </script>
  </body>
</html>
