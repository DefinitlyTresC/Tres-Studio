---
// Site 8 — archive. Same ledger as work, longer stock list: everything that
// isn't one of the five mains.
import { MV_CLIENT } from '../../lib/multiverse';
import { getCollection } from 'astro:content';

const WORK = ['z07', 'ee13', 'flatwood', 'tucker', 'thesis'];
const all = (await getCollection('projects')).map((e) => e.data);
const rows = all.filter((p) => !WORK.includes(p.slug));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#F6F4EE" />
    <title>Archive — T R E S — 08</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Hepta+Slab:wght@700;800;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <script is:inline set:html={MV_CLIENT(8)} />
    <!-- tracking: one bootstrap for the whole site (Umami + Clarity + visitor id + self-exclusion) - public/ts.js -->
    <script is:inline defer src="/ts.js"></script>
  </head>
  <body>
    <a class="back" href="/8/">← the shelf</a>

    <main class="ledger">
      <header class="head">
        <p class="spec">stock — archive · {String(rows.length).padStart(2, '0')} items</p>
        <h1 class="name">Archive</h1>
      </header>
      <div class="list" data-g8-room>
        {rows.map((p, i) => (
          <div class="ledge">
            <a class="row" data-g8 data-g8-slim href={`/8/project/${p.slug}`}>
              <span class="r-no">{String(i + 1).padStart(2, '0')}</span>
              <span class="r-name">{p.name}</span>
              <span class="r-meta">{[p.year, p.category].filter(Boolean).join(' · ')}</span>
            </a>
          </div>
        ))}
      </div>
    </main>

    <footer class="foot">
      <span>© 2026 Tres Carter</span>
      <a href="/privacy">Privacy</a>
    </footer>

    <style is:inline>
      :root { --paper: #F6F4EE; --ink: #141310; --red: #D8341F; --faint: rgba(20,19,16,0.45); }
      * { margin: 0; box-sizing: border-box; }
      html { background: var(--paper); }
      body { font-family: 'Hepta Slab', serif; color: var(--ink); -webkit-font-smoothing: antialiased; }
      ::selection { background: var(--red); color: var(--paper); }
      a { color: inherit; text-decoration: none; }

      .back { position: fixed; z-index: 10; top: 14px; left: 6vw; font-family: 'Space Mono', monospace; font-size: 12px; padding: 12px 0; }
      @media (hover: hover) and (pointer: fine) { .back:hover { text-decoration: underline; text-underline-offset: 4px; } }
      .back:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }

      .ledger { padding: 0 6vw 12svh; }
      .head { padding: clamp(110px, 22vh, 260px) 0 8svh; }
      .spec { font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--faint); }
      .name { font-weight: 900; font-size: clamp(44px, 9vw, 110px); line-height: 1; margin-top: 10px; }

      .list { display: grid; gap: 6svh; padding-top: 2svh; }
      .ledge { border-bottom: 2px solid var(--ink); position: relative; }
      .ledge::before, .ledge::after { content: ''; position: absolute; bottom: -2px; width: 2px; height: 8px; background: var(--ink); }
      .ledge::before { left: 0; }
      .ledge::after { right: 0; }
      .row { display: flex; align-items: baseline; gap: 18px; width: fit-content; padding: 0 4px 6px 0; }
      .r-no, .r-meta { font-family: 'Space Mono', monospace; font-size: 12px; color: var(--faint); }
      .r-name { font-weight: 800; font-size: clamp(24px, 4.6vw, 52px); line-height: 1; letter-spacing: -0.01em; }
      @media (hover: hover) and (pointer: fine) {
        .r-name { transition: letter-spacing 300ms cubic-bezier(0.23,1,0.32,1); }
        .row:hover .r-name { letter-spacing: 0.03em; }
        .sim .row { cursor: grab; }
        .sim .row:active { cursor: grabbing; }
      }

      .foot { display: flex; justify-content: space-between; padding: 3svh 6vw calc(4svh + env(safe-area-inset-bottom, 0px)); border-top: 1px solid rgba(20,19,16,0.2); font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; }

      @media (prefers-reduced-motion: reduce) { .r-name { transition: none; } }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
    </script>
    <script is:inline defer src="/mv8/grav.js"></script>
  </body>
</html>
