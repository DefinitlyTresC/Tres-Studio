---
// Site 8 — project page. Site-2 bones (lightbox/focus-trap/iOS-lock canon),
// stockroom skin: shelf-lined plates, mono spec labels, stamp red accents.
import { MV_CLIENT } from '../../../lib/multiverse';
import { getCollection } from 'astro:content';
import { heroUrl, gridUrl, mediaUrl } from '../../../lib/cloudinary';

export async function getStaticPaths() {
  const all = (await getCollection('projects')).map((e) => e.data);
  return all.map((p) => {
    const cat = all.filter((q) => q.category === p.category);
    const ring = cat.length > 1 ? cat : all; /* singleton category: nav must not self-link */
    const i = ring.findIndex((q) => q.slug === p.slug);
    return {
      params: { slug: p.slug },
      props: { p, prev: ring[(i - 1 + ring.length) % ring.length], next: ring[(i + 1) % ring.length] },
    };
  });
}

const WORK = ['z07', 'ee13', 'flatwood', 'tucker', 'thesis'];
const { p, prev, next } = Astro.props;
const backHref = WORK.includes(p.slug) ? '/8/work' : '/8/archive';
const backLabel = WORK.includes(p.slug) ? 'work' : 'archive';
const spec = [`No. ${String(p.id ?? '').padStart(2, '0')}`, p.year, p.location, p.status].filter(Boolean).join(' · ');
const paragraphs = (p.description || '').split(/\n\s*\n/).map((s) => s.trim()).filter(Boolean);
// image ordinal must match the lightbox counter, which counts images only
let imgOrdinal = 0;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#F6F4EE" />
    <title>{p.name} — T R E S — 08</title>
    <link rel="preconnect" href="https://res.cloudinary.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Hepta+Slab:wght@700;800;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <script is:inline set:html={MV_CLIENT(8)} />
    <!-- tracking: one bootstrap for the whole site (Umami + Clarity + visitor id + self-exclusion) - public/ts.js -->
    <script is:inline defer src="/ts.js"></script>
  </head>
  <body>
    <a class="back" href={backHref}>← {backLabel}</a>

    <main class="proj">
      <header class="head">
        <p class="spec">{spec}</p>
        <h1 class="name">{p.name}</h1>
        {p.designedAt && (
          <p class="spec at">
            designed at {p.designedAtUrl
              ? <a href={p.designedAtUrl} target="_blank" rel="noopener">{p.designedAt}</a>
              : p.designedAt}
          </p>
        )}
      </header>

      {heroUrl(p) && (
        <div class="plate">
          <img class="hero" src={heroUrl(p)} alt={p.name} fetchpriority="high" decoding="async" />
        </div>
      )}

      {paragraphs.length > 0 && (
        <div class="desc">{paragraphs.map((t) => <p>{t}</p>)}</div>
      )}

      {p.media.length > 0 && (
        <div class="gallery">
          {p.media.map((m) =>
            m.type === 'video' ? (
              <div class="plate"><video src={mediaUrl(m)} autoplay muted loop playsinline preload="metadata"></video></div>
            ) : (
              <button class="cell plate" type="button" data-full={mediaUrl(m)} aria-label={`View image ${++imgOrdinal}`}>
                <img src={gridUrl(m)} alt="" loading="lazy" decoding="async" />
              </button>
            )
          )}
        </div>
      )}

      <nav class="pn">
        <a href={`/8/project/${prev.slug}`}>← {prev.name}</a>
        <a class="pn-next" href={`/8/project/${next.slug}`}>{next.name} →</a>
      </nav>
    </main>

    <footer class="foot">
      <span>© 2026 Tres Carter</span>
      <a href="/privacy">Privacy</a>
    </footer>

    <div class="lb" id="lb" hidden role="dialog" aria-modal="true" aria-label="Gallery image">
      <img id="lb-img" alt="" />
      <p class="lb-n" id="lb-n"></p>
      <button class="lb-x" id="lb-x" type="button" aria-label="Close">close</button>
      <button class="lb-prev" id="lb-prev" type="button" aria-label="Previous">←</button>
      <button class="lb-next" id="lb-next" type="button" aria-label="Next">→</button>
    </div>

    <style is:inline>
      :root { --paper: #F6F4EE; --ink: #141310; --red: #D8341F; --faint: rgba(20,19,16,0.45); }
      * { margin: 0; box-sizing: border-box; }
      html { background: var(--paper); }
      body { font-family: 'Hepta Slab', serif; color: var(--ink); -webkit-font-smoothing: antialiased; }
      ::selection { background: var(--red); color: var(--paper); }
      a { color: inherit; text-decoration: none; }
      button { font: inherit; color: inherit; background: none; border: none; padding: 0; cursor: pointer; }

      .back { position: fixed; z-index: 10; top: 14px; left: 6vw; font-family: 'Space Mono', monospace; font-size: 12px; padding: 12px 0; }
      @media (hover: hover) and (pointer: fine) { .back:hover { text-decoration: underline; text-underline-offset: 4px; } }
      .back:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }

      .proj { max-width: 1100px; margin: 0 auto; padding: 0 6vw 6svh; }
      .head { padding: clamp(110px, 20vh, 220px) 0 5svh; }
      .spec { font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--faint); }
      .name { font-weight: 900; font-size: clamp(38px, 7.8vw, 92px); line-height: 1.02; letter-spacing: -0.01em; text-wrap: balance; margin-top: 12px; }
      .at { margin-top: 14px; }
      .at a { text-decoration: underline; text-underline-offset: 3px; }

      /* plates sit on shelf lines — every image is stock on the wall */
      .plate { position: relative; border-bottom: 2px solid var(--ink); padding-bottom: 10px; }
      .plate::before, .plate::after { content: ''; position: absolute; bottom: -2px; width: 2px; height: 8px; background: var(--ink); }
      .plate::before { left: 0; }
      .plate::after { right: 0; }
      .hero, .gallery img, .gallery video { display: block; width: 100%; height: auto; outline: 1px solid rgba(20,19,16,0.12); outline-offset: -1px; }

      .desc { max-width: 62ch; padding: 6svh 0 2svh; }
      .desc p { font-size: 16px; line-height: 1.7; font-weight: 700; text-wrap: pretty; }
      .desc p + p { margin-top: 1em; }

      .gallery { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: clamp(14px, 2vw, 26px); padding-top: 5svh; }
      @media (max-width: 640px) { .gallery { grid-template-columns: 1fr; } }
      .cell { display: block; transition: transform 140ms cubic-bezier(0.23,1,0.32,1); text-align: inherit; }
      .cell:active { transform: scale(0.99); }
      .cell:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }

      .pn { display: flex; justify-content: space-between; gap: 18px; padding: 8svh 0 0; font-family: 'Space Mono', monospace; font-size: 13px; }
      .pn-next { text-align: right; }
      @media (hover: hover) and (pointer: fine) { .pn a:hover { text-decoration: underline; text-underline-offset: 4px; } }

      .foot { display: flex; justify-content: space-between; max-width: 1100px; margin: 0 auto; padding: 3svh 6vw calc(4svh + env(safe-area-inset-bottom, 0px)); border-top: 1px solid rgba(20,19,16,0.2); font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; }

      .lb { position: fixed; inset: 0; z-index: 100; background: rgba(246, 244, 238, 0.97); display: grid; place-items: center; }
      .lb[hidden] { display: none; }
      .lb img { max-width: 92vw; max-height: 86svh; outline: 1px solid rgba(20,19,16,0.12); outline-offset: -1px; }
      .lb-n { position: fixed; bottom: calc(18px + env(safe-area-inset-bottom, 0px)); left: 50%; translate: -50% 0; font-family: 'Space Mono', monospace; font-size: 11px; color: var(--faint); }
      .lb-x { position: fixed; top: calc(10px + env(safe-area-inset-top, 0px)); right: 6vw; font-family: 'Space Mono', monospace; font-size: 12px; padding: 14px 0 14px 14px; min-height: 44px; }
      .lb-prev, .lb-next { position: fixed; top: 50%; translate: 0 -50%; font-family: 'Space Mono', monospace; font-size: 18px; padding: 14px; min-width: 44px; min-height: 44px; }
      .lb-prev { left: calc(3vw + env(safe-area-inset-left, 0px)); }
      .lb-next { right: calc(3vw + env(safe-area-inset-right, 0px)); }
      @media (hover: hover) and (pointer: fine) { .lb button:hover { text-decoration: underline; text-underline-offset: 4px; } }
      .lb button:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }

      @media (prefers-reduced-motion: reduce) {
        .cell { transition: none; }
        .cell:active { transform: none; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
    </script>
    <script is:inline>
      (function () {
        'use strict';
        var reduce = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}

        if (reduce) {
          /* reduced motion: gallery videos must not autoplay-loop */
          Array.prototype.forEach.call(document.querySelectorAll('.gallery video'), function (v) {
            v.removeAttribute('autoplay'); v.removeAttribute('loop');
            try { v.pause(); } catch (err) {}
            v.controls = true;
          });
        }

        var cellEls = Array.prototype.slice.call(document.querySelectorAll('.cell'));
        var full = cellEls.map(function (c) { return c.getAttribute('data-full'); });
        var lb = document.getElementById('lb');
        var img = document.getElementById('lb-img');
        var n = document.getElementById('lb-n');
        var at = 0, lastFocus = null, lockY = 0;
        function open(i) {
          var wasClosed = lb.hidden;
          at = i;
          img.src = full[at];
          n.textContent = (at + 1) + ' / ' + full.length;
          lb.hidden = false;
          if (wasClosed) {
            /* lock + focus capture on a TRUE open only — re-running on
               prev/next steps zeroes lockY (body is already fixed, so
               scrollY reads 0) and steals focus from the stepping button */
            lockY = window.scrollY || 0;
            /* body position:fixed — the lock iOS actually honors */
            document.body.style.position = 'fixed';
            document.body.style.top = -lockY + 'px';
            document.body.style.left = '0';
            document.body.style.right = '0';
            document.body.style.overflow = 'hidden';
            lastFocus = document.activeElement;
            document.getElementById('lb-x').focus();
          }
        }
        function close() {
          lb.hidden = true; img.src = '';
          document.body.style.position = '';
          document.body.style.top = '';
          document.body.style.left = '';
          document.body.style.right = '';
          document.body.style.overflow = '';
          window.scrollTo(0, lockY);
          if (lastFocus) lastFocus.focus();
        }
        function step(d) { open((at + d + full.length) % full.length); }
        cellEls.forEach(function (c, i) { c.addEventListener('click', function () { open(i); }); });
        document.getElementById('lb-x').addEventListener('click', close);
        document.getElementById('lb-prev').addEventListener('click', function (e) { e.stopPropagation(); step(-1); });
        document.getElementById('lb-next').addEventListener('click', function (e) { e.stopPropagation(); step(1); });
        lb.addEventListener('click', function (e) { if (e.target === lb) close(); });
        addEventListener('keydown', function (e) {
          if (lb.hidden) return;
          if (e.key === 'Escape') close();
          else if (e.key === 'ArrowLeft') step(-1);
          else if (e.key === 'ArrowRight') step(1);
          else if (e.key === 'Tab') {
            /* keep focus inside the dialog */
            var ring = [document.getElementById('lb-x'), document.getElementById('lb-prev'), document.getElementById('lb-next')];
            var idx = ring.indexOf(document.activeElement);
            e.preventDefault();
            var nx = idx === -1 ? 0 : (idx + (e.shiftKey ? -1 : 1) + ring.length) % ring.length;
            ring[nx].focus();
          }
        });
      })();
    </script>
  </body>
</html>
