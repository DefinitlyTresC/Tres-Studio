---
// LAB — port of root lab.html onto the shared Base layout.
//
// Head: lab-specific title/description via props. Base owns the canonical
// <head> (fonts/analytics/counter); lab.html's og:/twitter:/canonical meta are
// dropped for now, matching the migration plan (same as category/about).
//
// PARITY NOTES:
//   - Experiment links stay "labs/<name>.html" ON PURPOSE. The /labs folder
//     ports via public/ passthrough in Phase 4, so these relative URLs keep
//     resolving after cutover. Do NOT rewrite them to clean paths.
//   - All markup/classes are byte-for-byte from lab.html so global.css styles
//     and brand.js tilt (which targets .lab-index-card) keep working. The
//     decorative inline <svg> previews are copied verbatim.
//   - The subtitle typewriter is the original inline <script>, kept as
//     is:inline so Astro doesn't process/relocate it. It reads #labSub and
//     respects prefers-reduced-motion, exactly as before.
//
// VIEWPORT NOTE (flagged, not fixed): lab.html's viewport meta is
// "width=device-width, initial-scale=1.0, viewport-fit=cover". Base emits the
// standard viewport WITHOUT viewport-fit=cover and takes no per-page override.
// Rather than complicate Base for one page, this port uses Base's standard
// viewport. viewport-fit=cover only affects safe-area insets on notched devices
// and the lab layout doesn't rely on env(safe-area-*), so this is cosmetic.
import Base from '../layouts/Base.astro';
---

<Base
