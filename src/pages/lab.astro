---
// THE LAB — the shared portals room of the multiverse. Every universe's Lab
// link gets swallowed by the ink curtain and lands HERE. One page, five
// skins: on each load an inline head script rolls one of the five universes'
// identities (palette + type + flavor) onto :root BEFORE paint — "all lab
// pages are the same. the branding is just randomized."
//
// The 7 experiments are presented as tall DOORWAYS, each with a living
// pattern inside (pure CSS transform/opacity animation on inline SVG).
// Clicking a door floods the screen with the rolled skin's ink (curtain)
// and steps through to the static experiment at /labs/<name>.html.
//
// Map: MV_CLIENT(0) — no universe highlighted; all five dots are exits.
import { MV_CLIENT } from '../lib/multiverse';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FAFAF7" />
    <title>LAB — TRES.</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script is:inline set:html={MV_CLIENT(0)} />
    <!-- Umami analytics — data-domains scopes tracking to the real site so
         previews/branch URLs don't pollute stats. Clarity below is guarded
         to the production host for the same reason. -->
    <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="96e73988-106a-415e-bf80-5e10ffaec0dc" data-domains="tres.studio"></script>
    <script is:inline type="text/javascript">
      if (location.hostname === 'tres.studio') {
        (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "xang6oq7f9");
      }
    </script>
    <script is:inline>
      /* THE SKIN ROLL — runs before paint. Picks one of the five universes'
         identities, never the same one twice in a row (per tab). */
      (function () {
        'use strict';
        var SKINS = {
          1: { paper: '#FFEDDB', ink: '#2B1F1A', ac: '#BF9270',
               soft: 'rgba(43,31,26,0.55)', hair: 'rgba(43,31,26,0.22)',
               disp: "'Archivo', system-ui, sans-serif", mono: "'Space Mono', ui-monospace, monospace",
               gf: 'Archivo:wght@500;600;700', spec: 'sheet L·07 — seven live studies',
               card: '#ffffff', line: 'rgba(43,31,26,0.3)', mac: '#BF9270',
               conf: '#EDCDBB,#E3B7A0,#BF9270,#2B1F1A,#ffffff' },
          2: { paper: '#FAFAF7', ink: '#101010', ac: '#9A9A9A',
               soft: 'rgba(16,16,16,0.5)', hair: 'rgba(16,16,16,0.16)',
               disp: "'Hanken Grotesk', system-ui, sans-serif", mono: "'Space Mono', ui-monospace, monospace",
               gf: 'Hanken+Grotesk:wght@400;700;800', spec: 'seven doors, one quiet room',
               card: '#ffffff', line: 'rgba(0,0,0,0.25)', mac: '#101010',
               conf: '#101010,#9A9A9A,#ffffff' },
          3: { paper: '#FFFFFF', ink: '#141414', ac: '#141414',
               soft: 'rgba(20,20,20,0.45)', hair: 'rgba(20,20,20,0.28)',
               disp: "'IBM Plex Mono', ui-monospace, monospace", mono: "'IBM Plex Mono', ui-monospace, monospace",
               gf: 'IBM+Plex+Mono:wght@400;600;700', spec: '/lab · seven doors, shared by every universe',
               card: '#ffffff', line: 'rgba(0,0,0,0.3)', mac: '#141414',
               conf: '#141414,#4A4A4A,#ffffff' },
          4: { paper: '#EC5B13', ink: '#141210', ac: '#E8DCC6',
               soft: 'rgba(20,18,16,0.55)', hair: 'rgba(20,18,16,0.4)',
               disp: "'Inter Tight', system-ui, sans-serif", mono: "'Space Mono', ui-monospace, monospace",
               gf: 'Inter+Tight:wght@800;900', spec: 'seven live experiments — enter at your own risk',
               card: '#ffffff', line: 'rgba(0,0,0,0.35)', mac: '#141210',
               conf: '#E8DCC6,#141210,#ffffff' },
          5: { paper: '#FFFFFF', ink: '#0A0A0A', ac: '#2431FF',
               soft: 'rgba(10,10,10,0.5)', hair: 'rgba(10,10,10,0.2)',
               disp: "'Anton', system-ui, sans-serif", mono: "'Space Mono', ui-monospace, monospace",
               gf: 'Anton', spec: 'one room — every universe',
               card: '#ffffff', line: 'rgba(0,0,0,0.3)', mac: '#2431FF',
               conf: '#2431FF,#0A0A0A,#ffffff' }
        };
        var last = 0;
        try { last = parseInt(sessionStorage.getItem('mv:lab-skin') || '0', 10) || 0; } catch (e) {}
        var pool = [1, 2, 3, 4, 5].filter(function (n) { return n !== last; });
        var id = pool[Math.floor(Math.random() * pool.length)];
        try { sessionStorage.setItem('mv:lab-skin', String(id)); } catch (e) {}
        var k = SKINS[id];
        var r = document.documentElement;
        r.dataset.skin = String(id);
        r.style.background = k.paper; /* before-paint guarantee */
        var P = {
          '--paper': k.paper, '--ink': k.ink, '--accent': k.ac,
          '--soft': k.soft, '--hair': k.hair, '--disp': k.disp, '--mono': k.mono,
          '--mvt-card': k.card, '--mvt-ink': k.ink, '--mvt-line': k.line,
          '--mvt-label': k.soft, '--mvt-accent': k.mac, '--mvt-confetti': k.conf
        };
        for (var p in P) r.style.setProperty(p, P[p]);
        var tc = document.querySelector('meta[name="theme-color"]');
        if (tc) tc.setAttribute('content', k.paper);
        var l = document.createElement('link');
        l.rel = 'stylesheet';
        l.href = 'https://fonts.googleapis.com/css2?family=' + k.gf + '&family=Space+Mono:wght@400;700&display=swap';
        document.head.appendChild(l);
        window.__LAB = { id: id, ink: k.ink, spec: k.spec };
      })();
    </script>
  </head>
