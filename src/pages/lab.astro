    <style is:inline>
      /* the V3.2 theme block — the ONLY place literal color may live.
         --accent is the door patterns' second voice, tuned per paper. */
      :root {
        --paper: #FAFAF7; --ink: #101010;
        --soft: rgba(16,16,16,0.5);      /* secondary text */
        --faint: rgba(16,16,16,0.45);    /* labels, meta   */
        --hair: rgba(0,0,0,0.14);        /* hairlines      */
        --tint: rgba(16,16,16,0.04);     /* image wells    */
        --accent: #9A9A9A;
        --disp: 'Hanken Grotesk', system-ui, sans-serif;
        --mono: 'Space Mono', ui-monospace, monospace;
      }
      html[data-theme="dark"] {
        --paper: #101010; --ink: #FAFAF7;
        --soft: rgba(250,250,247,0.55);
        --faint: rgba(250,250,247,0.45);
        --hair: rgba(255,255,255,0.16);
        --tint: rgba(250,250,247,0.05);
        --accent: rgba(250,250,247,0.45);
      }
      html[data-theme="red"] {
        --paper: #E0301F; --ink: #0A0A0A;
        --soft: rgba(10,10,10,0.6);
        --faint: rgba(10,10,10,0.5);
        --hair: rgba(0,0,0,0.25);
        --tint: rgba(0,0,0,0.06);
        --accent: rgba(10,10,10,0.5);
      }
      html { background: var(--paper); }
      body { color: var(--ink); }
      ::selection { background: var(--ink); color: var(--paper); }

      * { margin: 0; box-sizing: border-box; }
      body { font-family: var(--disp); -webkit-font-smoothing: antialiased; }
      a { color: inherit; text-decoration: none; }

      .back {
        position: fixed; z-index: 10; top: var(--y, 14px); left: 5vw;
        font-family: var(--mono); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase;
        padding: 14px 8px 14px 0;
        transition: transform 140ms cubic-bezier(0.23,1,0.32,1);
      }
      .back:active { transform: scale(0.96); }
      .back:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }
      @media (hover: hover) and (pointer: fine) {
        .back:hover { text-decoration: underline; text-underline-offset: 4px; }
      }

      .hero {
        min-height: 62svh; display: grid; place-content: center; justify-items: center;
        text-align: center; padding: clamp(90px, 16svh, 180px) 5vw 6svh; gap: 14px;
      }
      .spec {
        font-family: var(--mono); font-size: 12px; letter-spacing: 0.12em;
        text-transform: uppercase; color: var(--soft);
      }
      .mark {
        font-weight: 800; font-size: clamp(96px, 23vw, 280px); line-height: 0.9;
        letter-spacing: -0.01em;
      }
      .dot { color: var(--accent); }

      /* ── the hall: one zero-g room ─────────────────────────────────────── */
      /* explicit height — the doors are absolute, and the engine clamps
         bodies inside exactly this box */
      .hall {
        position: relative;
        width: 100%; max-width: 1240px;
        /* floor = the middle column (42 percent apart) clearing a full parked
           door height (391px at the 230px cap) even on short laptops */
        height: max(960px, 96svh);
        margin: 0 auto 10svh;
      }
      @media (max-width: 640px) { .hall { height: 1700px; } }

      /* the [data-zg] element is the physics body: the engine writes its
         inline transform every frame, so it carries no cosmetics. These
         percent homes park each door until boot — and forever under reduced
         motion, when the engine never runs. */
      .door {
        position: absolute;
        left: calc(var(--hx) * 1%); top: calc(var(--hy) * 1%);
        translate: -50% -50%;
        width: clamp(150px, 21vw, 230px);
        aspect-ratio: 10 / 17;
      }
      @media (max-width: 640px) {
        .door { left: calc(var(--hxn) * 1%); top: calc(var(--hyn) * 1%); }
      }
      .sim .door { left: 0; top: 0; translate: none; will-change: transform; }
      .door:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }

      /* every cosmetic transform rides this inner wrapper so it composes
         with the engine's outer transform instead of fighting it */
      .din {
        position: absolute; inset: 0;
        display: flex; flex-direction: column; justify-content: flex-end;
        border: 1px solid var(--ink);
        border-radius: 18px; /* V3.2 rounded rect — the arch is retired */
        background: var(--paper);
        overflow: hidden;
        transition: transform 260ms cubic-bezier(0.23,1,0.32,1);
      }
      .door:active .din { transform: scale(0.96); }
      .win { position: absolute; inset: 0; }
      .win svg {
        display: block; width: 100%; height: 100%;
        opacity: 0.5;
        transition: opacity 300ms cubic-bezier(0.23,1,0.32,1);
      }
      .plate {
        position: relative; display: grid; gap: 5px;
        padding: 14px 14px 18px; text-align: center;
        background: var(--paper);
        border-top: 1px solid var(--hair);
      }
      .name { font-weight: 800; font-size: 19px; line-height: 1.1; }
      .tag {
        font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em; line-height: 1.5;
        text-transform: uppercase; color: var(--soft);
      }
      @media (hover: hover) and (pointer: fine) {
        .door:hover .din { transform: scale(1.035); }
        .door:hover .win svg { opacity: 1; }
        .sim .door { cursor: grab; }
        .sim .door:active { cursor: grabbing; }
      }

      /* entrance: doors rise into place, staggered */
      @media (prefers-reduced-motion: no-preference) {
        .din {
          animation: rise 620ms cubic-bezier(0.23,1,0.32,1) both;
          animation-delay: calc(var(--i, 0) * 70ms);
        }
        @keyframes rise { from { opacity: 0; transform: translateY(22px); } }
      }

      /* ── the living patterns (transform/opacity only) ──────────────────── */
      .sails { animation: pinspin 9s linear infinite; transform-box: view-box; transform-origin: 50% 50%; }
      @keyframes pinspin { to { transform: rotate(360deg); } }

      .drop {
        animation: traydrop 5.2s cubic-bezier(0.23,1,0.32,1) infinite;
        transform-box: fill-box; transform-origin: 50% 100%;
      }
      @keyframes traydrop {
        0%, 8%    { transform: translateY(-104px); opacity: 0; }
        14%       { opacity: 1; }
        32%       { transform: translateY(0) scaleY(1); }
        38%       { transform: translateY(0) scaleY(0.88); }
        46%, 84%  { transform: translateY(0) scaleY(1); opacity: 1; }
        94%, 100% { transform: translateY(0); opacity: 0; }
      }

      .orbit { animation: spin 36s linear infinite; transform-box: view-box; transform-origin: 50% 50%; }
      .orbit2 { animation: spinrev 20s linear infinite; transform-box: view-box; transform-origin: 50% 50%; }
      @keyframes spin { to { transform: rotate(360deg); } }
      @keyframes spinrev { to { transform: rotate(-360deg); } }

      .belt1 { animation: convey 8s linear infinite; }
      .belt2 { animation: convey 8s linear infinite; animation-delay: -4s; }
      @keyframes convey {
        from { transform: translateX(-70px); }
        to { transform: translateX(230px); }
      }

      .dot-p {
        animation: dotpulse 2.6s cubic-bezier(0.23,1,0.32,1) infinite;
        transform-box: fill-box; transform-origin: center;
      }
      @keyframes dotpulse {
        0%, 100% { transform: scale(1); opacity: 0.9; }
        50% { transform: scale(1.7); opacity: 0.45; }
      }

      /* ── info footer ───────────────────────────────────────────────────── */
      .info {
        min-height: 78svh; display: grid; align-content: end; gap: 7svh;
        position: relative; padding: 10svh 5vw 5svh;
        border-top: 1px solid var(--hair);
      }
      .i-cols {
        display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px;
        padding-right: clamp(100px, 24vw, 240px);
        font-family: var(--mono); font-size: 12px; letter-spacing: 0.05em;
        text-transform: uppercase; line-height: 1.9;
      }
      @media (max-width: 640px) { .i-cols { grid-template-columns: 1fr; } }
      .lbl { display: block; color: var(--soft); margin-bottom: 6px; }
      .i-meta {
        display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap;
        border-top: 1px solid var(--hair); padding-top: 16px;
        font-family: var(--mono); font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase;
      }
      @media (hover: hover) and (pointer: fine) {
        .info a:hover { text-decoration: underline; text-underline-offset: 4px; }
      }

      /* reduced motion: everything rests, composed and legible — the parked
         percent homes above are already the whole layout */
      @media (prefers-reduced-motion: reduce) {
        .back, .din, .win svg { transition: none; }
        .back:active { transform: none; }
        .door:active .din, .door:hover .din { transform: none; }
        .win svg * { animation: none !important; }
        .win svg { opacity: 0.6; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal, cover } from '/mv/curtain.js';
      autoReveal();

      /* doors open through the ink — one DOCUMENT-level handler, so the
         engine's element-level click listener runs first and a suppressed
         drag-click arrives here already defaultPrevented. Matches a.door
         only: the WIP span drags and color-cycles but never navigates. */
      let reduce = false;
      try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}
      let leaving = false;
      addEventListener('pageshow', (e) => {
        if (e.persisted) leaving = false; /* bfcache Back restores the latched heap */
      });
      document.addEventListener('click', async (e) => {
        const a = e.target.closest && e.target.closest('a.door');
        if (!a) return;
        if (e.defaultPrevented) return; /* zerog suppressed a drag-click */
        /* modified/aux clicks keep their native meaning (new tab etc.) */
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button > 0) return;
        if (reduce) return; /* plain navigation */
        /* mid-cover: swallow repeat clicks so they can't navigate natively */
        if (leaving) { e.preventDefault(); return; }
        e.preventDefault();
        leaving = true;
        const r = a.getBoundingClientRect();
        const x = e.clientX || r.left + r.width / 2;
        const y = e.clientY || r.top + r.height / 2;
        /* flood with the LIVE ink — a fixed dark cover vanishes on dark paper */
        const ink = getComputedStyle(document.documentElement).getPropertyValue('--ink').trim() || '#101010';
        await cover({ x, y, color: ink });
        /* all six targets autoReveal — the covered flag rides through and
           peels itself on arrival, so it must NOT be cleared here */
        location.href = a.getAttribute('href');
      });
    </script>
    <script is:inline>
      /* back link rides the cursor — the site-wide pattern */
      (function () {
        var reduce = false, fine = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; fine = matchMedia('(hover: hover) and (pointer: fine)').matches; } catch (e) {}
        if (!fine || reduce) return;
        var back = document.getElementById('back');
        var target = null, cur = null, raf = null;
        function frame() {
          cur += (target - cur) * 0.09;
          back.style.setProperty('--y', cur.toFixed(1) + 'px');
          if (Math.abs(target - cur) > 0.4) raf = requestAnimationFrame(frame); else raf = null;
        }
        addEventListener('pointermove', function (e) {
          if (e.pointerType === 'touch') return; /* hybrids: taps must not move it */
          var h = back.offsetHeight;
          target = Math.min(innerHeight - h - 12, Math.max(12, e.clientY - h / 2));
          if (cur === null) cur = target;
          if (!raf) raf = requestAnimationFrame(frame);
        }, { passive: true });
      })();
    </script>
    <script is:inline defer src="/mv/zerog.js"></script>
    <script is:inline defer src="/mv/ticker.js"></script>
  </body>
</html>
