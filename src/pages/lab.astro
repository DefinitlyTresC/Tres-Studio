<script is:inline>
// Subtitle typewriter — mono notation under the title.
(() => {
  const SUB = 'Living sketches and side projects — each one a small investigation. Open one, or step through to another universe.';
  const el = document.getElementById('labSub');
  if (!el) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) { el.textContent = SUB; return; }
  let i = 0;
  (function type() {
    if (i > SUB.length) return;
    el.textContent = SUB.slice(0, i);
    const ch = SUB[i - 1] || '';
    i++;
    setTimeout(type, /[.,—]/.test(ch) ? 120 : 24);
  })();
  setTimeout(type, 520);
})();
</script>
