---
// /me — the tracking control room. Noindex, linked from nowhere; Tres visits
// it once per browser to exclude himself (localStorage rides along on any
// network, so NordVPN on/off doesn't matter — unlike IP rules). Also shows
// this browser's visitor id and lets you set the friendly name Clarity
// displays. Design: docs/specs/2026-07-11-tracking-cleanup-design.md.
//
// Loads /ts.js for the window.TS API but is never tracked itself (ts.js
// skips injection on /me). theme.js must land first — data-theme pre-paint.
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#101010" />
    <title>me — Tres.</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script is:inline src="/theme.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/cursor.css" />
    <script is:inline src="/ts.js"></script>
  </head>
  <body>
    <main>
      <h1>Tracking · this browser</h1>

      <p id="status" aria-live="polite">…</p>

      <p>
        <button id="toggle" type="button">…</button>
      </p>

      <p class="dim">Your visitor id — how this browser shows up in Clarity:</p>
      <p><code id="vid">…</code></p>

      <p class="dim">Friendly name (optional — shows on Clarity recordings,
      e.g. <em>carter-phone</em>):</p>
      <p class="row">
        <input id="name" type="text" maxlength="40" autocomplete="off"
               placeholder="no name set" />
        <button id="save" type="button">save</button>
      </p>

      <p class="dim">The switch lives in this browser's storage, so it works
      on any network — VPN on or off. Visit this page once on each device
      you use (phone, work, home) and flip it. Clearing site data resets it.</p>

      <p><a href="/">← back</a></p>
    </main>

    <script is:inline>
      (function () {
        var TS = window.TS;
        var st = document.getElementById('status');
        var tg = document.getElementById('toggle');
        var nm = document.getElementById('name');
        var sv = document.getElementById('save');
        if (!TS) { st.textContent = 'ts.js failed to load — nothing to control.'; tg.hidden = true; return; }

        document.getElementById('vid').textContent = TS.id;
        nm.value = TS.name || '';

        function paint() {
          st.textContent = TS.off
            ? 'EXCLUDED — this browser records nothing (no Umami, no Clarity, no visit count).'
            : 'TRACKED — this browser counts like any visitor.';
          st.className = TS.off ? 'is-off' : 'is-on';
          tg.textContent = TS.off ? '[ track me again ]' : '[ exclude this browser ]';
        }
        tg.addEventListener('click', function () {
          if (TS.off) TS.include(); else TS.exclude();
          paint();
        });
        sv.addEventListener('click', function () {
          TS.setName(nm.value);
          nm.value = TS.name;
          sv.textContent = 'saved';
          setTimeout(function () { sv.textContent = 'save'; }, 1200);
        });
        paint();
      })();
    </script>

    <style is:inline>
      :root {
        --paper: #FAFAF7; --ink: #101010;
        --soft: rgba(16,16,16,0.5);      /* secondary text */
        --faint: rgba(16,16,16,0.45);    /* labels, meta   */
        --hair: rgba(0,0,0,0.14);        /* hairlines      */
        --tint: rgba(16,16,16,0.04);     /* image wells    */
      }
      html[data-theme="dark"] {
        --paper: #101010; --ink: #FAFAF7;
        --soft: rgba(250,250,247,0.55);
        --faint: rgba(250,250,247,0.45);
        --hair: rgba(255,255,255,0.16);
        --tint: rgba(250,250,247,0.05);
      }
      html[data-theme="red"] {
        --paper: #E0301F; --ink: #0A0A0A;
        --soft: rgba(10,10,10,0.6);
        --faint: rgba(10,10,10,0.5);
        --hair: rgba(0,0,0,0.25);
        --tint: rgba(0,0,0,0.06);
      }
      html { background: var(--paper); }
      body { color: var(--ink); }
      ::selection { background: var(--ink); color: var(--paper); }

      * { margin: 0; box-sizing: border-box; }
      body { font-family: 'Space Mono', ui-monospace, monospace; -webkit-font-smoothing: antialiased; }
      main { max-width: 52ch; margin: 0 auto; padding: 18vh 24px 20vh; }
      h1 { font-size: 15px; text-transform: uppercase; letter-spacing: 0.2em; }
      p { font-size: 13px; line-height: 1.9; margin-top: 1.6em; }
      .dim { opacity: 0.55; margin-bottom: -1.2em; }
      code { font-weight: 700; font-size: 14px; }
      em { font-style: normal; border-bottom: 1px dotted var(--ink); }
      a { color: inherit; }
      a:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }
      .is-off { font-weight: 700; }
      button { font: inherit; font-size: 13px; background: none; border: 1.5px solid var(--ink);
        padding: 10px 16px; min-height: 44px; cursor: pointer; color: inherit; }
      button:hover { background: var(--ink); color: var(--paper); }
      button:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }
      .row { display: flex; gap: 10px; }
      input { font: inherit; font-size: 13px; flex: 1; min-height: 44px; padding: 8px 12px;
        border: 1.5px solid var(--soft); background: none; color: inherit; }
      input:focus { outline: none; border-color: var(--ink); }
    </style>
  </body>
</html>
