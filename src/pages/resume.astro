---
// Resume — the document version of the site (V3.2 spec 7). Names, years,
// locations pull from the sheet at build time (same source as /work); the
// one-line notes compress each row's own description — no invented roles.
// Print contract: white paper, black ink, no site chrome, one page.
import { getCollection } from 'astro:content';

const all = (await getCollection('projects')).map((e) => e.data);

// the five selected, work-page order
const SELECTED = ['ee13', 'z07', 'tucker', 'drome', 'thesis'];
const selected = SELECTED.map((s) => all.find((p) => p.slug === s)).filter(Boolean);

// one line per project, from the sheet row's own facts only
const NOTE = {
  ee13: 'residential — concept through construction documents · chancey architecture',
  z07: 'residential — drawings through construction · chancey architecture',
  tucker: 'neighborhood planning — 45-page guidelines governing architecture, landscape, and site · chancey architecture',
  drome: 'commercial — restaurant design for good friends from auburn',
  thesis: 'undergraduate thesis — a 42,000 sqft additive-manufactured artist residency on kyoto’s kamo river',
};
const meta = (parts) => parts.filter(Boolean).join(' · ');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#101010" />
    <title>Resume — T R E S .</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- theme.js runs before any stylesheet: data-theme must land pre-paint -->
    <script is:inline src="/theme.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;700;800&family=Space+Mono&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/cursor.css" />
    <!-- tracking: one bootstrap for the whole site (Umami + Clarity + visitor id + self-exclusion) - public/ts.js -->
    <script is:inline defer src="/ts.js"></script>
  </head>
  <body>
    <a class="back" id="back" href="/about">← about</a>

    <main class="cv">
      <header class="head">
        <h1 class="name">Tres Carter</h1>
        <p class="role">architectural designer — 30A, florida</p>
        <p class="reach">
          <a href="mailto:tres@tres.studio">tres@tres.studio</a><span class="sep" aria-hidden="true">·</span><a href="https://tres.studio">tres.studio</a><span class="sep" aria-hidden="true">·</span><a href="https://www.linkedin.com/in/tres-carter" target="_blank" rel="noopener">linkedin.com/in/tres-carter</a>
        </p>
      </header>

      <section class="sec" aria-label="Selected work">
        <h2 class="label">selected work</h2>
        {selected.map((p) => (
          <article class="item">
            <p class="i-line">
              <span class="i-name">{p.name}</span>
              <span class="i-meta">{meta([p.year, p.location])}</span>
            </p>
            <p class="i-note">{NOTE[p.slug]}</p>
          </article>
        ))}
      </section>

      <section class="sec" aria-label="Practice">
        <h2 class="label">practice</h2>
        <ul class="lines">
          <li>residential + commercial architectural design along florida&rsquo;s 30A</li>
          <!-- TRES: verify — the /labs/plugins shelf exists but public/plugins/ holds no release yet -->
          <li>revit tooling — Tres.extension, a pyRevit extension, published on this site</li>
          <li>this site — designed + built</li>
        </ul>
      </section>

      <section class="sec" aria-label="Education">
        <h2 class="label">education</h2>
        <p class="line">
          <!-- TRES: verify degree + years (sheet backs auburn school work 2018-2022 + thesis 2022-2023) -->
          <span class="l-main">Auburn University — architecture</span>
          <span class="i-meta">2018 — 2023</span>
        </p>
      </section>

      <section class="sec" aria-label="Tools">
        <h2 class="label">tools</h2>
        <!-- TRES: verify projection mapping — the sheet doesn't state it -->
        <p class="line">revit · pyrevit development · projection mapping · web</p>
      </section>
    </main>

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }

      :root {
        --paper: #FAFAF7; --ink: #101010;
        --soft: rgba(16,16,16,0.5);      /* secondary text */
        --faint: rgba(16,16,16,0.45);    /* labels, meta   */
        --hair: rgba(0,0,0,0.14);        /* hairlines      */
        --tint: rgba(16,16,16,0.04);     /* image wells    */
      }
      html[data-theme="dark"] {
        --paper: #101010; --ink: #FAFAF7;
        --soft: rgba(250,250,247,0.55);
        --faint: rgba(250,250,247,0.45);
        --hair: rgba(255,255,255,0.16);
        --tint: rgba(250,250,247,0.05);
      }
      html[data-theme="red"] {
        --paper: #E0301F; --ink: #0A0A0A;
        --soft: rgba(10,10,10,0.6);
        --faint: rgba(10,10,10,0.5);
        --hair: rgba(0,0,0,0.25);
        --tint: rgba(0,0,0,0.06);
      }
      html { background: var(--paper); }
      body { color: var(--ink); }
      ::selection { background: var(--ink); color: var(--paper); }

      body { font-family: 'Hanken Grotesk', system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
      a { color: inherit; text-decoration: none; }
      a:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }

      .back { position: fixed; z-index: 10; top: var(--y, 14px); left: 6vw; font-family: 'Space Mono', monospace; font-size: 12px; padding: 12px 0; transition: transform 140ms cubic-bezier(0.23,1,0.32,1); }
      .back:active { transform: scale(0.96); }

      /* one column, document measure; top padding clears the fixed chrome */
      .cv { max-width: 64ch; margin: 0 auto; padding: clamp(110px, 18vh, 200px) 6vw 14svh; }

      .name { font-weight: 800; font-size: clamp(38px, 6.5vw, 58px); line-height: 1.02; letter-spacing: -0.01em; }
      .role { font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--soft); margin-top: 16px; }
      .reach { font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.02em; color: var(--soft); margin-top: 10px; }
      /* 44px-ish hit areas without moving anything: pad out, pull back in */
      .reach a { display: inline-block; padding: 12px 0; margin: -12px 0; }
      .sep { margin: 0 10px; color: var(--faint); }

      .sec { border-top: 1px solid var(--hair); margin-top: clamp(38px, 6svh, 58px); padding-top: clamp(18px, 3svh, 26px); }
      .head + .sec { margin-top: clamp(46px, 8svh, 74px); }
      .label { font-family: 'Space Mono', monospace; font-weight: 400; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--faint); }

      .item { margin-top: 20px; }
      .i-line, .line { display: flex; align-items: baseline; justify-content: space-between; gap: 6px 18px; flex-wrap: wrap; }
      .i-name, .l-main { font-weight: 700; font-size: 16px; line-height: 1.3; letter-spacing: -0.01em; }
      .i-meta { font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--faint); }
      .i-note { font-size: 14px; line-height: 1.55; color: var(--soft); margin-top: 5px; max-width: 58ch; }

      .lines { list-style: none; padding: 0; display: grid; gap: 9px; margin-top: 18px; font-size: 15px; line-height: 1.55; }
      .line { margin-top: 18px; font-size: 15px; line-height: 1.55; }

      @media (hover: hover) and (pointer: fine) {
        .back:hover, .reach a:hover { text-decoration: underline; text-underline-offset: 4px; }
      }
      @media (prefers-reduced-motion: reduce) {
        .back { transition: none; }
        .back:active { transform: none; }
      }

      /* print: the actual resume — white paper, black ink, no site chrome,
         plain-text links, one page at default scale (letter and a4) */
      @media print {
        :root, html[data-theme] {
          --paper: #FFFFFF; --ink: #000000;
          --soft: #333333; --faint: #4A4A4A; --hair: #B4B4B4; --tint: transparent;
        }
        @page { margin: 15mm 18mm; }
        #mv-thm { display: none !important; } /* theme.js's toggle */
        .back { display: none; }
        body { -webkit-font-smoothing: auto; }
        .cv { max-width: none; margin: 0; padding: 0; }
        .name { font-size: 26pt; }
        .role { font-size: 8.5pt; margin-top: 7pt; }
        .reach { font-size: 8.5pt; margin-top: 4pt; }
        .reach a { padding: 0; margin: 0; }
        .sec { margin-top: 15pt; padding-top: 9pt; break-inside: avoid; }
        .head + .sec { margin-top: 17pt; }
        .label { font-size: 7.5pt; }
        .item { margin-top: 9pt; }
        .i-name, .l-main { font-size: 10.5pt; }
        .i-meta { font-size: 8pt; }
        .i-note { font-size: 9pt; line-height: 1.5; margin-top: 2pt; max-width: none; }
        .lines { gap: 4pt; margin-top: 8pt; font-size: 9.5pt; line-height: 1.5; }
        .line { margin-top: 8pt; font-size: 9.5pt; line-height: 1.5; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
    </script>
    <script is:inline>
      (function () {
        var reduce = false, fine = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; fine = matchMedia('(hover: hover) and (pointer: fine)').matches; } catch (e) {}
        if (!fine || reduce) return;
        var back = document.getElementById('back');
        var target = null, cur = null, raf = null;
        function frame() {
          cur += (target - cur) * 0.09;
          back.style.setProperty('--y', cur.toFixed(1) + 'px');
          if (Math.abs(target - cur) > 0.4) raf = requestAnimationFrame(frame); else raf = null;
        }
        addEventListener('pointermove', function (e) {
          if (e.pointerType === 'touch') return; /* hybrids: taps must not move it */
          var h = back.offsetHeight;
          target = Math.min(innerHeight - h - 12, Math.max(12, e.clientY - h / 2));
          if (cur === null) cur = target;
          if (!raf) raf = requestAnimationFrame(frame);
        }, { passive: true });
      })();
    </script>
  </body>
</html>
