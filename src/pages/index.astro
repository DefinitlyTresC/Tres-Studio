---
// The front door — "the floating one." Zero gravity: every letter and menu
// word is a physics body — grab, throw, collide, bounce, jello home. The
// hand-rolled engine lives in /public/mv/zerog.js (one rAF loop, transforms
// only) and scans for [data-zg] bodies inside [data-zg-room] containers. Two
// rooms: the letter field (screen 1) and the centered menu (screen 2); bodies
// never cross into other sections.
//
// V3.0 (2026-07-20): this universe (the multiverse's site 2) became THE site.
// The dice roll, the refresh-roll, and the dot map are gone; the quirks stay
// (color cycle on click, reshuffle on scroll re-entry, ink curtain into /lab,
// the ticker).
//
// V3.1 (2026-07-20): the menu drops Archive (folded into /work) — three words
// now. And the Work word plays hard to get: the first three clicks pop
// drifting project portals (EE-13 first, then two drawn at random from the
// selected five) instead of navigating; click four is a plain link again.
// The blobs are bubbles: they never overlap each other, they shove the
// letters and menu words around (the zero-g __zg kick surface), and after
// ~20s afloat they pop away on their own. Session-scoped — see WORK POP
// PORTALS (CSS + script) below.
import { getCollection } from 'astro:content';
import { joinUrl } from '../lib/cloudinary';

// Percent-based homes recompute from viewport size. x/y = wide screens,
// xn/yn = narrow (<=640px). s = glyph scale factor.
// Arrangement per Tres's sketch (2026-07-20): a two-row bounce — T up,
// R dropped low beneath it, E up, S dropped low, the period trailing at
// S's lower right. Still reads T R E S . left-to-right.
// Narrow (V3.1): glyphs sized up (21vw clamp in the <=640px block) and homes
// spread down the full screen — the bounce steepens into a waterfall so the
// mark carries a phone; same left-to-right read.
const LETTERS = [
  { g: 'T', x: 26, y: 33, xn: 22, yn: 12, s: 1.0 },
  { g: 'R', x: 31, y: 72, xn: 32, yn: 38, s: 0.78 },
  { g: 'E', x: 55, y: 33, xn: 58, yn: 22, s: 0.9 },
  { g: 'S', x: 65, y: 68, xn: 70, yn: 52, s: 1.22 },
  { g: '.', x: 76, y: 82, xn: 84, yn: 64, s: 1.12 },
];
const MENU = [
  { label: 'Work', href: '/work', y: 25 },
  { label: 'Lab', href: '/lab', y: 50 },
  { label: 'About', href: '/about', y: 75 },
];

// Pop portal payload — the five selected projects, EE-13 first (the client
// always pops it first, then draws the rest at random). Hero URLs resolve at
// build time; w_900 covers the ~280px blob at 2x without hero-page weight.
const all = (await getCollection('projects')).map((e) => e.data);
const POPS = ['ee13', 'z07', 'tucker', 'drome', 'thesis']
  .map((s) => all.find((p) => p.slug === s))
  .filter(Boolean)
  .map((p) => ({ slug: p.slug, name: p.name, hero: joinUrl(p.heroImage, 'w_900', 'image') }));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content="Tres Carter — architecture, art, and code from 30A, Florida." />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FAFAF7" />
    <title>T R E S .</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;700;800&family=Space+Mono&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/cursor.css" />
    <!-- tracking: one bootstrap for the whole site (Umami + Clarity + visitor id + self-exclusion) - public/ts.js -->
    <script is:inline defer src="/ts.js"></script>
  </head>
  <body>
    <header class="space" id="field" aria-label="Tres" data-zg-room>
      {LETTERS.map((l) => (
        <span
          class="body glyph"
          data-zg
          data-zg-color
          data-home-x={l.x}
          data-home-y={l.y}
          data-home-xn={l.xn}
          data-home-yn={l.yn}
          style={`--hx:${l.x}; --hy:${l.y}; --hxn:${l.xn}; --hyn:${l.yn}; --s:${l.s};`}
          aria-hidden="true"
        ><span class="tx">{l.g}</span></span>
      ))}
      <p class="cue">scroll</p>
    </header>

    <nav class="menu" id="menuField" aria-label="Sections" data-zg-room>
      {MENU.map((m) => (
        <a class="body mword" id={m.href === '/work' ? 'menuWork' : null} href={m.href} draggable="false" data-zg data-home-x="50" data-home-y={m.y} style={`--hx:50; --hy:${m.y};`}>
          <span class="tx">{m.label}</span>
        </a>
      ))}
    </nav>

    <footer class="info">
      <div class="i-cols">
        <div class="i-col">
          <span class="lbl">Location</span>
          Seagrove · 30A<br />Florida, USA
        </div>
        <div class="i-col">
          <span class="lbl">Contact</span>
          <a href="mailto:tres@tres.studio">tres@tres.studio</a><br />
          <a href="https://instagram.com/tres.studio" target="_blank" rel="noopener">IG</a><br />
          <a href="https://www.linkedin.com/in/tres-carter" target="_blank" rel="noopener">LinkedIn</a>
        </div>
        <div class="i-col">
          <span class="lbl">Sections</span>
          <a href="/work">Work</a><br />
          <a href="/lab">Lab</a><br />
          <a href="/about">About</a><br />
          <a href="/resume.pdf">Resume</a><br />
          <a href="/portfolio.pdf">Portfolio</a><br />
          <a href="/labs/plugins">Plugins</a>
        </div>
      </div>
      <div class="i-meta">
        <span>© 2026 Tres Carter</span>
        <span id="mv-ticker-slot"></span>
        <a href="/privacy">Privacy</a>
      </div>
    </footer>

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }
      html, body { overflow-x: hidden; }
      html { background: #FAFAF7; }
      body { font-family: 'Hanken Grotesk', system-ui, sans-serif; color: #101010; -webkit-font-smoothing: antialiased; }
      ::selection { background: #101010; color: #FAFAF7; }
      a { color: inherit; text-decoration: none; }

      .space { position: relative; height: 100svh; }
      .menu { position: relative; height: 100svh; }

      /* Physics bodies. Static fallback: parked at percent homes, centered.
         When the sim boots (.sim), JS owns position via transform only.
         z-index 2: type must paint over the pop portals (z 1) — the holes sit
         between the paper and every text layer. */
      .body {
        position: absolute;
        left: calc(var(--hx) * 1%); top: calc(var(--hy) * 1%);
        translate: -50% -50%;
        display: inline-grid; place-items: center;
        min-width: 44px; min-height: 44px;
        z-index: 2;
        user-select: none; -webkit-user-select: none;
        -webkit-touch-callout: none;
        touch-action: none;
      }
      .sim .body { left: 0; top: 0; translate: none; will-change: transform; }

      .glyph {
        font-weight: 800; line-height: 1;
        font-size: calc(clamp(64px, 12vw, 176px) * var(--s));
      }
      @media (max-width: 640px) {
        .glyph {
          font-size: calc(clamp(78px, 21vw, 130px) * var(--s));
          left: calc(var(--hxn) * 1%); top: calc(var(--hyn) * 1%);
        }
      }

      .mword {
        font-weight: 800; line-height: 1; letter-spacing: -0.01em;
        font-size: clamp(38px, 6.8vw, 88px);
      }
      .mword:focus-visible { outline: 2px solid #101010; outline-offset: 8px; }

      .tx { display: block; }
      @media (hover: hover) and (pointer: fine) {
        .sim .body { cursor: grab; }
        .sim .body:active { cursor: grabbing; }
        .mword .tx { transition-property: transform; transition-duration: 260ms; transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1); }
        .mword:hover .tx { transform: scale(1.05); }
      }
      /* Pressable feedback when the sim is off (reduced motion / no JS). */
      .menu:not(.sim) .mword:active .tx { transform: scale(0.96); }

      .cue {
        position: absolute; bottom: 6svh; left: 50%; translate: -50% 0; z-index: 2;
        font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
        color: rgba(16, 16, 16, 0.45);
      }

      .info { min-height: 70svh; display: grid; align-content: end; gap: 7svh; position: relative; padding: 10svh 6vw 4svh; }
      .i-cols {
        position: relative; z-index: 2; /* above the pop portals (z 1) */
        display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px;
        padding-right: clamp(100px, 24vw, 240px);
        font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.05em;
        text-transform: uppercase; line-height: 1.9;
      }
      @media (max-width: 640px) { .i-cols { grid-template-columns: 1fr; } }
      .lbl { display: block; color: rgba(16,16,16,0.45); margin-bottom: 6px; }
      .i-meta {
        position: relative; z-index: 2; /* above the pop portals (z 1) */
        display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap;
        border-top: 1px solid rgba(0,0,0,0.14); padding-top: 16px;
        font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase;
      }
      @media (hover: hover) and (pointer: fine) {
        .info a:hover { text-decoration: underline; text-underline-offset: 4px; }
      }

      /* WORK POP PORTALS — drifting blob-holes the menu Work word spawns (the
         script below builds them; nothing here is server-rendered). z-index 1
         = a hole in the paper: every text layer sits at z 2, so type paints
         over the heroes. NOT [data-zg] — the zero-g engine never owns these;
         the drift is our own rAF loop, so transforms on .pop are safe. */
      .pop {
        position: fixed; left: 0; top: 0; z-index: 1;
        width: clamp(150px, 24vw, 280px); height: clamp(150px, 24vw, 280px);
        display: block; border: none; will-change: transform;
      }
      .pop:focus-visible { outline: 2px solid #101010; outline-offset: 3px; }
      /* springy pop-in; the 1.56 overshoot supplies the 1.04 bump */
      .pin { display: block; width: 100%; height: 100%; animation: pop-in 600ms cubic-bezier(0.34, 1.56, 0.64, 1); }
      .pskin {
        display: block; width: 100%; height: 100%;
        background-size: cover; background-position: center;
        border-radius: 58% 42% 39% 61% / 53% 44% 56% 47%;
        animation: pop-morph 9s ease-in-out infinite;
        /* inset hairline keeps the edge crisp on light heroes */
        box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.08);
      }
      .pname {
        position: absolute; left: 50%; top: 50%; translate: -50% -50%;
        font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.12em;
        text-transform: uppercase; white-space: nowrap;
        color: #101010; background: #FAFAF7;
        border: 1px solid rgba(0, 0, 0, 0.14); border-radius: 999px; padding: 6px 10px;
        opacity: 0; pointer-events: none; transition: opacity 200ms ease;
      }
      .pop:focus-visible .pname { opacity: 1; }
      @keyframes pop-in { from { transform: scale(0.2); } to { transform: scale(1); } }
      @keyframes pop-morph {
        0%, 100% { border-radius: 58% 42% 39% 61% / 53% 44% 56% 47%; }
        33% { border-radius: 39% 61% 55% 45% / 46% 59% 41% 54%; }
        66% { border-radius: 55% 45% 62% 38% / 58% 43% 47% 60%; }
      }
      @media (hover: hover) and (pointer: fine) {
        .pin { transition: transform 260ms cubic-bezier(0.22, 1, 0.36, 1); }
        .pop:hover .pin { transform: scale(1.04); }
        .pop:hover .pname { opacity: 1; }
      }
      /* the swallow: .go freezes the drift (JS inlines the current box),
         grows the hole to the viewport, and lifts above everything. Must sit
         after the hover block — .go's transform:none has equal specificity
         and wins on source order. */
      .pop.go { z-index: 999; pointer-events: none; transition: left 700ms cubic-bezier(0.22, 1, 0.36, 1), top 700ms cubic-bezier(0.22, 1, 0.36, 1), width 700ms cubic-bezier(0.22, 1, 0.36, 1), height 700ms cubic-bezier(0.22, 1, 0.36, 1); }
      .pop.go .pin { animation: none; transform: none; }
      .pop.go .pskin { animation: none; transition: border-radius 340ms ease-in-out; }
      .pop.go .pname { opacity: 0; }
      /* the bubble bursts: a breath outward, then gone (lifetime expiry) */
      .pop.bye { pointer-events: none; }
      .pop.bye .pin { animation: pop-bye 460ms cubic-bezier(0.45, 0, 0.55, 0.2) forwards; }
      @keyframes pop-bye {
        0% { transform: scale(1); opacity: 1; }
        32% { transform: scale(1.12); opacity: 1; }
        100% { transform: scale(0); opacity: 0; }
      }

      @media (prefers-reduced-motion: reduce) {
        .mword .tx { transition-duration: 1ms; }
        /* pop portals never spawn under PRM (the script bails first) —
           these kills are belt-and-suspenders */
        .pin, .pskin, .pname { animation: none; transition: none; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
      import('/mv/lab-takeover.js');
    </script>

    <script is:inline set:html={`const POPS = ${JSON.stringify(POPS)};`}></script>
    <script is:inline>
      /* WORK POP PORTALS — the menu Work word plays hard to get. The first
         THREE clicks each pop a project blob instead of navigating: EE-13
         always first, then two drawn at random from the selected five.
         Click four is a plain link again. The blobs are bubbles:
           - they never overlap each other (circle collision + clean spawns);
           - they SHOVE the letters and menu words (zero-g's __zg surface —
             the blob deflects, the word gets kicked loose and springs home);
           - they live ~20s afloat, then burst and are gone. No respawn on
             later visits — only the popped list persists (mv:work-popped).
         Constraints: intercept at DOCUMENT level and bail on defaultPrevented
         (zero-g preventDefaults drag-release clicks at element level, and its
         listener must run first); only #menuWork — the footer Work link stays
         plain. The pops are NOT [data-zg]: they run their own drift loop, the
         engine never touches them. PRM: no choreography, Work is a plain
         link. Entering a blob does NOT set mv:covered — the arrival hero
         carries the continuity, not the curtain. */
      (function () {
        var reduce = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}
        if (reduce || typeof POPS === 'undefined' || !POPS.length) return;

        var MAX = Math.min(3, POPS.length);
        var LIFE = 20000; /* ms afloat before the burst (+ per-blob jitter) */
        var KEY = 'mv:work-popped';
        function getPopped() {
          try {
            var v = JSON.parse(sessionStorage.getItem(KEY) || '[]');
            if (Object.prototype.toString.call(v) === '[object Array]') return v.slice(0, MAX);
          } catch (e) {}
          return [];
        }
        function setPopped(list) { try { sessionStorage.setItem(KEY, JSON.stringify(list)); } catch (e) {} }
        /* EE-13 leads; the rest of the run is dealt at random, no repeats */
        function nextPick(popped) {
          if (!popped.length) return POPS[0];
          var pool = [];
          for (var i = 0; i < POPS.length; i++) {
            if (popped.indexOf(POPS[i].slug) === -1) pool.push(POPS[i]);
          }
          return pool.length ? pool[Math.floor(Math.random() * pool.length)] : null;
        }

        var pops = [], raf = null, last = 0, leaving = false;

        function place(s) { s.el.style.transform = 'translate3d(' + s.x.toFixed(1) + 'px,' + s.y.toFixed(1) + 'px,0)'; }
        function cx(s) { return s.x + s.w / 2; }
        function cy(s) { return s.y + s.h / 2; }
        /* the morph keeps the shape inside ~92% of the box */
        function rad(s) { return s.w * 0.46; }

        function spawn(data, i) {
          var a = document.createElement('a');
          a.className = 'pop';
          a.href = '/project/' + data.slug;
          a.setAttribute('aria-label', data.name + ' — open project');
          var pin = document.createElement('span');
          pin.className = 'pin';
          var skin = document.createElement('span');
          skin.className = 'pskin';
          if (data.hero) skin.style.backgroundImage = 'url("' + data.hero + '")';
          /* desync the morphs: siblings never share duration or phase */
          skin.style.animationDuration = (8.6 + i * 2.7).toFixed(1) + 's';
          skin.style.animationDelay = (-0.6 - i * 3.1).toFixed(1) + 's';
          var chip = document.createElement('span');
          chip.className = 'pname';
          chip.textContent = data.name;
          pin.appendChild(skin);
          a.appendChild(pin);
          a.appendChild(chip);
          document.body.appendChild(a);

          var r = a.getBoundingClientRect();
          var padX = innerWidth * 0.12, padY = innerHeight * 0.12;
          var s = {
            el: a, skin: skin,
            w: r.width, h: r.height,
            x: 0, y: 0,
            ang: Math.random() * Math.PI * 2,
            speed: 14 + Math.random() * 10,
            phase: Math.random() * Math.PI * 2,
            freq: 0.25 + Math.random() * 0.3,
            die: performance.now() + LIFE + Math.random() * 5000,
            hitT: {}
          };
          /* clean spawn: try for a spot clear of the other bubbles */
          for (var t = 0; t < 24; t++) {
            s.x = padX + Math.random() * Math.max(1, innerWidth - s.w - padX * 2);
            s.y = padY + Math.random() * Math.max(1, innerHeight - s.h - padY * 2);
            var clear = true;
            for (var j = 0; j < pops.length; j++) {
              var o = pops[j];
              var dx = cx(s) - cx(o), dy = cy(s) - cy(o);
              if (Math.sqrt(dx * dx + dy * dy) < rad(s) + rad(o) + 14) { clear = false; break; }
            }
            if (clear) break;
          }
          place(s);
          /* true click (not a suppressed drag-release) = enter through the
             dot; Enter on the focused anchor lands here too */
          a.addEventListener('click', function (e) {
            if (e.defaultPrevented) return;
            if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button > 0) return;
            e.preventDefault();
            swallow(s);
          });
          pops.push(s);
          start();
        }

        /* the burst: a breath outward, then gone */
        function expire(s) {
          var i = pops.indexOf(s);
          if (i > -1) pops.splice(i, 1);
          s.el.classList.add('bye');
          setTimeout(function () {
            if (s.el.parentNode) s.el.parentNode.removeChild(s.el);
          }, 500);
        }

        /* reflect a blob's heading off normal (nx,ny) if it's approaching */
        function deflect(s, nx, ny) {
          var vx = Math.cos(s.ang), vy = Math.sin(s.ang);
          var d = vx * nx + vy * ny;
          if (d >= 0) return; /* already leaving */
          vx -= 2 * d * nx; vy -= 2 * d * ny;
          s.ang = Math.atan2(vy, vx);
        }

        /* drift + bubble physics. dt-clamped so a background tab never
           teleports a blob. */
        function tick(now) {
          raf = null;
          var dt = Math.min(0.05, (now - last) / 1000);
          last = now;
          var t = now / 1000;
          var i, j, s, o, dx, dy, d, nx, ny;

          for (i = pops.length - 1; i >= 0; i--) {
            s = pops[i];
            /* lifetime — but never mid-hover (rude) or mid-swallow */
            if (now > s.die) {
              var hov = false;
              try { hov = s.el.matches(':hover'); } catch (e) {}
              if (hov) { s.die = now + 2000; }
              else { expire(s); continue; }
            }
            s.ang += Math.sin(t * s.freq * 6.283 + s.phase) * 0.5 * dt;
            s.x += Math.cos(s.ang) * s.speed * dt;
            s.y += Math.sin(s.ang) * s.speed * dt;
            var maxX = Math.max(8, innerWidth - s.w - 8);
            var maxY = Math.max(8, innerHeight - s.h - 8);
            if (s.x < 8) { s.x = 8; s.ang = Math.PI - s.ang; }
            else if (s.x > maxX) { s.x = maxX; s.ang = Math.PI - s.ang; }
            if (s.y < 8) { s.y = 8; s.ang = -s.ang; }
            else if (s.y > maxY) { s.y = maxY; s.ang = -s.ang; }
          }

          /* bubbles never overlap: separate along the normal, deflect both */
          for (i = 0; i < pops.length; i++) {
            for (j = i + 1; j < pops.length; j++) {
              s = pops[i]; o = pops[j];
              dx = cx(o) - cx(s); dy = cy(o) - cy(s);
              d = Math.sqrt(dx * dx + dy * dy) || 1;
              var need = rad(s) + rad(o) + 6;
              if (d >= need) continue;
              nx = dx / d; ny = dy / d;
              var push = (need - d) / 2;
              s.x -= nx * push; s.y -= ny * push;
              o.x += nx * push; o.y += ny * push;
              deflect(s, -nx, -ny);
              deflect(o, nx, ny);
            }
          }

          /* the bubbles shove the words: blob deflects, word gets kicked
             loose (zero-g brings it home). 300ms per-pair cooldown so a
             grazing pass reads as one bump, not a rattle. */
          if (window.__zg) {
            window.__zg.each(function (bi, bx, by, br) {
              for (var k = 0; k < pops.length; k++) {
                var p = pops[k];
                var ddx = bx - cx(p), ddy = by - cy(p);
                var dd = Math.sqrt(ddx * ddx + ddy * ddy) || 1;
                if (dd >= rad(p) + br) continue;
                if (p.hitT[bi] && now - p.hitT[bi] < 300) continue;
                p.hitT[bi] = now;
                var kx = ddx / dd, ky = ddy / dd;
                var mag = 200 + p.speed * 6;
                window.__zg.kick(bi, kx * mag, ky * mag);
                deflect(p, -kx, -ky);
              }
            });
          }

          for (i = 0; i < pops.length; i++) place(pops[i]);
          if (pops.length) raf = requestAnimationFrame(tick);
        }
        function start() {
          if (raf || document.hidden || !pops.length) return;
          last = performance.now();
          raf = requestAnimationFrame(tick);
        }
        document.addEventListener('visibilitychange', function () {
          if (document.hidden) { if (raf) { cancelAnimationFrame(raf); raf = null; } }
          else start();
        });
        addEventListener('resize', function () {
          for (var i = 0; i < pops.length; i++) {
            var s = pops[i], r = s.el.getBoundingClientRect();
            s.w = r.width; s.h = r.height;
            s.x = Math.min(Math.max(8, s.x), Math.max(8, innerWidth - s.w - 8));
            s.y = Math.min(Math.max(8, s.y), Math.max(8, innerHeight - s.h - 8));
            place(s);
          }
        });

        /* enter through the dot: freeze the drift, grow the hole to the
           viewport (left/top/width/height stay smooth — no transform fight),
           radius 24% then 0, and go. NOT the curtain: mv:covered stays
           unset — the arrival hero carries the continuity. */
        function swallow(s) {
          if (leaving) return;
          leaving = true;
          var i = pops.indexOf(s);
          if (i > -1) pops.splice(i, 1);
          var r = s.el.getBoundingClientRect();
          s.el.style.transform = 'none';
          s.el.style.left = r.left + 'px';
          s.el.style.top = r.top + 'px';
          s.el.style.width = r.width + 'px';
          s.el.style.height = r.height + 'px';
          void s.el.offsetWidth; /* commit the frozen box before transitioning */
          s.el.classList.add('go');
          s.el.style.left = '0px';
          s.el.style.top = '0px';
          s.el.style.width = innerWidth + 'px';
          s.el.style.height = innerHeight + 'px';
          s.skin.style.animation = 'none';
          s.skin.style.borderRadius = '24%';
          setTimeout(function () { s.skin.style.borderRadius = '0%'; }, 340);
          var href = s.el.getAttribute('href');
          setTimeout(function () { location.href = href; }, 700);
        }

        document.addEventListener('click', function (e) {
          var a = e.target && e.target.closest && e.target.closest('#menuWork');
          if (!a) return;
          if (e.defaultPrevented) return; /* zero-g suppressed a drag's trailing click */
          /* modified/aux clicks keep their native meaning (new tab etc.) */
          if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button > 0) return;
          if (leaving) { e.preventDefault(); return; }
          var popped = getPopped();
          if (popped.length >= MAX) return; /* click four: a link again */
          var pick = nextPick(popped);
          if (!pick) return;
          e.preventDefault();
          spawn(pick, popped.length);
          popped.push(pick.slug);
          setPopped(popped);
        });

        /* bfcache return (possibly mid-swallow): tear down — the bubbles
           burst offstage; only the popped list persists */
        addEventListener('pageshow', function (e) {
          if (!e.persisted) return;
          leaving = false;
          if (raf) { cancelAnimationFrame(raf); raf = null; }
          pops.length = 0;
          var strays = document.querySelectorAll('a.pop');
          for (var i = strays.length - 1; i >= 0; i--) {
            if (strays[i].parentNode) strays[i].parentNode.removeChild(strays[i]);
          }
        });
      })();
    </script>

    <script is:inline defer src="/mv/zerog.js"></script>
    <script is:inline defer src="/mv/ticker.js"></script>
  </body>
</html>
