---
// FRONT-DOOR FALLBACK â€” client-side dice roll.
//
// In production "/" never serves this file: the edge function
// (netlify/edge-functions/roll.js) rewrites "/" to a random universe before
// the request reaches the CDN. This page exists for everywhere the edge
// doesn't run â€” `astro dev`, `astro preview`, direct hits on /index.html
// (old bookmarks or hand-typed URLs), and as a graceful fallback if the
// edge function ever fails in prod.
//
// It mirrors roll.js semantics exactly: honors ?u=N, never repeats the
// mv_last cookie's universe, writes mv_last back. Keep SITE COUNT in sync
// with src/lib/multiverse.ts + roll.js.
//
// The old pre-multiverse homepage that used to live here was unreachable
// since the 2026-07-03 cutover; it lives on in git history (and REBRAND.md).
import { SITES } from '../lib/multiverse';
const COUNT = SITES.length;
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tres.</title>
<meta name="description" content="Tres Carter â€” architecture, art, and code from 30A, Florida." />
<meta name="robots" content="noindex" />
<meta name="theme-color" content="#080808" />
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%23080808'/%3E%3Ccircle cx='16' cy='16' r='6' fill='%23ff5a1f'/%3E%3C/svg%3E" />
<script is:inline define:vars={{ COUNT }}>
(function(){
  var u=0; try{u=parseInt(new URLSearchParams(location.search).get('u'),10)||0;}catch(e){}
  var n=(u>=1&&u<=COUNT)?u:0;
  if(!n){
    // never the same door twice in a row (same rule as the edge function)
    var m=document.cookie.match(/(?:^|;\s*)mv_last=(\d+)/), last=m?+m[1]:0;
    if(last>=1&&last<=COUNT){ n=1+Math.floor(Math.random()*(COUNT-1)); if(n>=last)n++; }
    else n=1+Math.floor(Math.random()*COUNT);
  }
  try{document.cookie='mv_last='+n+';path=/;max-age=2592000;samesite=lax';}catch(e){}
  // carry non-u params (utm_* etc.) + hash through to the universe page
  var r=''; try{var q=new URLSearchParams(location.search);q.delete('u');r=q.toString();}catch(e){}
  location.replace('/'+n+'/'+(r?'?'+r:'')+location.hash);
})();
</script>
<style>
  body{background:#080808;color:#f4f4f3;font:14px/1.6 'Space Mono',ui-monospace,monospace;
    display:flex;align-items:center;justify-content:center;min-height:100vh;margin:0}
  a{color:#ff5a1f}
  ul{list-style:none;padding:0;display:flex;gap:1.5em}
</style>
</head>
<body>
<noscript>
  <div>
    <p>tres. â€” six doors, pick one:</p>
    <ul>
      {SITES.map((s) => <li><a href={`/${s.id}/`}>{String(s.id).padStart(2, '0')}</a></li>)}
    </ul>
  </div>
</noscript>
</body>
</html>
