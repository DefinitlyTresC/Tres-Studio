---
// The front door — "the floating one." Zero gravity: every letter and menu
// word is a physics body — grab, throw, collide, bounce, jello home. The
// engine lives in /public/mv/zerog.js (one rAF loop, transforms only) and
// scans for [data-zg] bodies inside [data-zg-room] containers. Two rooms:
// the letter field (screen 1) and the centered menu (screen 2); bodies
// never cross into other sections.
//
// V3.2 (2026-07-21, dark water): the work bubbles are gone — Work is a
// plain link again, exiting under an ink side-swipe (sessionStorage
// mv:swipe; /work slides the panel out on arrival). The menu words are
// navigation, so they're tied down hardest (data-zg-tight: no wander,
// stiff rubberband, capped throws). The TRES letters keep the full float —
// the last free bodies on the site. Theme via /theme.js: dark is home;
// this page defines the var block and consumes vars, nothing more. The
// quirks stay (color cycle on click, reshuffle on scroll re-entry, ink
// curtain into /lab, the ticker).

// Percent-based homes recompute from viewport size. x/y = wide screens,
// xn/yn = narrow (<=640px). s = glyph scale factor.
// Arrangement per Tres's sketch (2026-07-20): a two-row bounce — T up,
// R dropped low beneath it, E up, S dropped low, the period trailing at
// S's lower right. Still reads T R E S . left-to-right.
// Narrow: glyphs sized up (21vw clamp in the <=640px block) and homes
// spread down the full screen — the bounce steepens into a waterfall so
// the mark carries a phone; same left-to-right read.
const LETTERS = [
  { g: 'T', x: 26, y: 33, xn: 22, yn: 12, s: 1.0 },
  { g: 'R', x: 31, y: 72, xn: 32, yn: 38, s: 0.78 },
  { g: 'E', x: 55, y: 33, xn: 58, yn: 22, s: 0.9 },
  { g: 'S', x: 65, y: 68, xn: 70, yn: 52, s: 1.22 },
  { g: '.', x: 76, y: 82, xn: 84, yn: 64, s: 1.12 },
];
const MENU = [
  { label: 'Work', href: '/work', y: 25 },
  { label: 'Lab', href: '/lab', y: 50 },
  { label: 'About', href: '/about', y: 75 },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content="Tres Carter — architecture, art, and code from 30A, Florida." />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#101010" />
    <title>T R E S .</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- theme.js must beat every stylesheet: it sets data-theme pre-paint -->
    <script is:inline src="/theme.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;700;800&family=Space+Mono&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/cursor.css" />
    <link rel="stylesheet" href="/glass.css" />
    <!-- tracking: one bootstrap for the whole site (Umami + Clarity + visitor id + self-exclusion) - public/ts.js -->
    <script is:inline defer src="/ts.js"></script>
  </head>
  <body>
    <header class="space" id="field" aria-label="Tres" data-zg-room>
      {LETTERS.map((l, li) => (
        <span
          class="body glyph"
          data-zg
          data-zg-color
          data-home-x={l.x}
          data-home-y={l.y}
          data-home-xn={l.xn}
          data-home-yn={l.yn}
          style={`--hx:${l.x}; --hy:${l.y}; --hxn:${l.xn}; --hyn:${l.yn}; --s:${l.s}; --li:${li};`}
          aria-hidden="true"
        ><span class="tx glass">{l.g}</span></span>
      ))}
      <p class="cue">scroll</p>
    </header>

    <nav class="menu" id="menuField" aria-label="Sections" data-zg-room>
      {MENU.map((m) => (
        <a class="body mword" href={m.href} draggable="false" data-zg data-zg-tight data-home-x="50" data-home-y={m.y} style={`--hx:50; --hy:${m.y};`}>
          <span class="tx glass">{m.label}</span>
        </a>
      ))}
    </nav>

    <footer class="info">
      <div class="i-cols">
        <div class="i-col">
          <span class="lbl">Location</span>
          Seagrove · 30A<br />Florida, USA
        </div>
        <div class="i-col">
          <span class="lbl">Contact</span>
          <a href="mailto:tres@tres.studio">tres@tres.studio</a><br />
          <a href="https://instagram.com/tres.studio" target="_blank" rel="noopener">IG</a><br />
          <a href="https://www.linkedin.com/in/tres-carter" target="_blank" rel="noopener">LinkedIn</a>
        </div>
        <div class="i-col">
          <span class="lbl">Sections</span>
          <a href="/work">Work</a><br />
          <a href="/lab">Lab</a><br />
          <a href="/about">About</a><br />
          <a href="/resume">Resume</a><br />
          <a href="/labs/plugins">Plugins</a>
        </div>
      </div>
      <div class="i-meta">
        <span>© 2026 Tres Carter</span>
        <span id="mv-ticker-slot"></span>
        <a href="/privacy">Privacy</a>
      </div>
    </footer>

    <style is:inline>
      :root {
        --paper: #FAFAF7; --ink: #101010;
        --soft: rgba(16,16,16,0.66);      /* secondary text */
        --faint: rgba(16,16,16,0.62);    /* labels, meta   */
        --hair: rgba(0,0,0,0.14);        /* hairlines      */
        --tint: rgba(16,16,16,0.04);     /* image wells    */
      }
      html[data-theme="dark"] {
        --paper: #101010; --ink: #FAFAF7;
        --soft: rgba(250,250,247,0.62);
        --faint: rgba(250,250,247,0.55);
        --hair: rgba(255,255,255,0.16);
        --tint: rgba(250,250,247,0.05);
      }
      html[data-theme="red"] {
        --paper: #E0301F; --ink: #0A0A0A;
        --soft: rgba(10,10,10,0.78);
        --faint: rgba(10,10,10,0.72);
        --hair: rgba(0,0,0,0.25);
        --tint: rgba(0,0,0,0.06);
      }
      html { background: var(--paper); }
      body { color: var(--ink); }
      ::selection { background: var(--ink); color: var(--paper); }

      * { margin: 0; box-sizing: border-box; }
      html, body { overflow-x: hidden; }
      body { font-family: 'Hanken Grotesk', system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
      a { color: inherit; text-decoration: none; }

      .space { position: relative; height: 100svh; }
      .menu { position: relative; height: 100svh; }

      /* Physics bodies. Static fallback: parked at percent homes, centered.
         When the sim boots (.sim), JS owns position via transform only. */
      .body {
        position: absolute;
        left: calc(var(--hx) * 1%); top: calc(var(--hy) * 1%);
        translate: -50% -50%;
        display: inline-grid; place-items: center;
        min-width: 44px; min-height: 44px;
      }
      /* interaction blockers only once the sim owns the bodies — the static
         fallback (PRM / no-JS) must scroll and select like plain text */
      .sim .body {
        left: 0; top: 0; translate: none; will-change: transform;
        user-select: none; -webkit-user-select: none;
        -webkit-touch-callout: none;
        touch-action: none;
      }

      .glyph {
        font-weight: 800; line-height: 1;
        font-size: calc(clamp(64px, 12vw, 176px) * var(--s));
      }
      @media (max-width: 640px) {
        .glyph {
          font-size: calc(clamp(78px, 21vw, 130px) * var(--s));
          left: calc(var(--hxn) * 1%); top: calc(var(--hyn) * 1%);
        }
      }

      .mword {
        font-weight: 800; line-height: 1; letter-spacing: -0.01em;
        font-size: clamp(38px, 6.8vw, 88px);
      }
      .mword:focus-visible { outline: 2px solid var(--ink); outline-offset: 8px; }

      .tx { display: block; }
      @media (hover: hover) and (pointer: fine) {
        .sim .body { cursor: grab; }
        .sim .body:active { cursor: grabbing; }
        .mword .tx { transition-property: transform; transition-duration: 260ms; transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1); }
        .mword:hover .tx { transform: scale(1.05); }
      }
      /* Pressable feedback when the sim is off (reduced motion / no JS). */
      .menu:not(.sim) .mword:active .tx { transform: scale(0.96); }

      .cue {
        position: absolute; bottom: 6svh; left: 50%; translate: -50% 0;
        font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
        color: var(--faint);
      }

      .info { min-height: 70svh; display: grid; align-content: end; gap: 7svh; position: relative; padding: 10svh 6vw 4svh; }
      .i-cols {
        display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px;
        padding-right: clamp(100px, 24vw, 240px);
        font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.05em;
        text-transform: uppercase; line-height: 1.9;
      }
      @media (max-width: 640px) { .i-cols { grid-template-columns: 1fr; } }
      .lbl { display: block; color: var(--faint); margin-bottom: 6px; }
      .i-meta {
        display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap;
        border-top: 1px solid var(--hair); padding-top: 16px;
        font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase;
      }
      @media (hover: hover) and (pointer: fine) {
        .info a:hover { text-decoration: underline; text-underline-offset: 4px; }
      }

      /* The work exit: an ink panel slides in from the right; /work slides
         it out leftward on arrival. Above the theme toggle (z 90) for the
         beat it covers the screen; blocks pointer events while in flight. */
      .swipe {
        position: fixed; inset: 0; z-index: 999;
        background: var(--ink);
        transform: translateX(100%);
        transition: transform 380ms cubic-bezier(0.22, 1, 0.36, 1);
      }
      .swipe.in { transform: translateX(0); }

      /* the load: solid paper, then the letters float in off the left,
         one after another. Inner .tx only — the engine owns the outer
         transform. bfcache restores skip it (animations don't re-run). */
      @media (prefers-reduced-motion: no-preference) {
        .glyph .tx {
          animation: drift-in 880ms cubic-bezier(0.22, 1, 0.36, 1) both;
          animation-delay: calc(120ms + var(--li, 0) * 110ms);
        }
        @keyframes drift-in {
          from { transform: translateX(-75vw); opacity: 0; }
          38% { opacity: 1; }
          to { transform: none; opacity: 1; }
        }
        .cue { opacity: 0; animation: cue-in 500ms ease 1400ms both; }
        @keyframes cue-in { to { opacity: 1; } }
      }
      @media (prefers-reduced-motion: reduce) {
        .mword .tx { transition-duration: 1ms; }
        /* the swipe never spawns under PRM (the script bails first) —
           this kill is belt-and-suspenders */
        .swipe { transition: none; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
      import('/mv/lab-takeover.js');
    </script>

    <script is:inline>
      /* WORK SIDE-SWIPE — the menu Work word leaves under an ink panel that
         slides in from the right (~380ms), then navigates; /work slides it
         out leftward on arrival (sessionStorage mv:swipe — the work page
         checks + clears it). Document-level listener on purpose: zero-g's
         element-level click handler must run first, so a drag-release
         (suppressed, defaultPrevented) never swipes. Modified/aux clicks
         keep their native meaning (new tab etc.); only the menu word — the
         footer Work link stays plain. PRM / no JS: plain navigation. */
      (function () {
        var reduce = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}

        /* one exit at a time */
        var leaving = false;
        addEventListener('pageshow', function (e) {
          if (!e.persisted) return; /* bfcache Back: reset, drop a stranded panel */
          leaving = false;
          var p = document.getElementById('mv-swipe');
          if (p && p.parentNode) p.parentNode.removeChild(p);
        });

        document.addEventListener('click', function (e) {
          var a = e.target && e.target.closest && e.target.closest('.menu a[href="/work"]');
          if (!a) return;
          if (e.defaultPrevented) return; /* zero-g suppressed a drag's trailing click */
          if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button > 0) return;
          if (reduce) return; /* plain navigation */
          if (leaving) { e.preventDefault(); return; }
          leaving = true;
          e.preventDefault();
          var p = document.createElement('div');
          p.id = 'mv-swipe';
          p.className = 'swipe';
          p.setAttribute('aria-hidden', 'true');
          document.body.appendChild(p);
          var gone = false;
          function go() {
            if (gone) return;
            gone = true;
            try {
              sessionStorage.setItem('mv:swipe', '1');
              /* a raced lab cover must not ghost-peel /work */
              sessionStorage.removeItem('mv:covered');
            } catch (err) {}
            location.href = a.getAttribute('href');
            /* an aborted navigation must not strand the page under the
               panel — sweep it and unlatch if we are still here */
            setTimeout(function () {
              if (document.hidden) return;
              leaving = false;
              try { sessionStorage.removeItem('mv:swipe'); } catch (err) {}
              if (p.parentNode) p.parentNode.removeChild(p);
            }, 3500);
          }
          p.addEventListener('transitionend', go);
          setTimeout(go, 520); /* a starved transition must never strand the exit */
          /* commit the offstage transform before sliding in */
          requestAnimationFrame(function () {
            requestAnimationFrame(function () { p.classList.add('in'); });
          });
        });
      })();
    </script>

    <script is:inline defer src="/mv/zerog.js"></script>
    <script is:inline defer src="/mv/glass.js"></script>
    <script is:inline defer src="/mv/ticker.js"></script>
  </body>
</html>
