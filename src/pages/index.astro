---
// The front door — "the floating one." Zero gravity: every letter and menu
// word is a physics body — grab, throw, collide, bounce, jello home. The
// hand-rolled engine lives in /public/mv/zerog.js (one rAF loop, transforms
// only) and scans for [data-zg] bodies inside [data-zg-room] containers. Two
// rooms: the letter field (screen 1) and the centered menu (screen 2); bodies
// never cross into other sections.
//
// V3.0 (2026-07-20): this universe (the multiverse's site 2) became THE site.
// The dice roll, the refresh-roll, and the dot map are gone; the quirks stay
// (color cycle on click, reshuffle on scroll re-entry, ink curtain into /lab,
// the ticker).

// Percent-based homes recompute from viewport size. x/y = wide screens,
// xn/yn = narrow (<=640px). s = glyph scale factor.
// Arrangement per Tres's sketch (2026-07-20): a two-row bounce — T up,
// R dropped low beneath it, E up, S dropped low, the period trailing at
// S's lower right. Still reads T R E S . left-to-right.
const LETTERS = [
  { g: 'T', x: 26, y: 33, xn: 22, yn: 18, s: 1.0 },
  { g: 'R', x: 31, y: 72, xn: 30, yn: 38, s: 0.78 },
  { g: 'E', x: 55, y: 33, xn: 58, yn: 18, s: 0.9 },
  { g: 'S', x: 65, y: 68, xn: 68, yn: 34, s: 1.22 },
  { g: '.', x: 76, y: 82, xn: 84, yn: 44, s: 1.12 },
];
const MENU = [
  { label: 'Work', href: '/work', y: 20 },
  { label: 'Archive', href: '/archive', y: 40 },
  { label: 'Lab', href: '/lab', y: 60 },
  { label: 'About', href: '/about', y: 80 },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content="Tres Carter — architecture, art, and code from 30A, Florida." />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FAFAF7" />
    <title>T R E S .</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;700;800&family=Space+Mono&display=swap" rel="stylesheet" />
    <!-- tracking: one bootstrap for the whole site (Umami + Clarity + visitor id + self-exclusion) - public/ts.js -->
    <script is:inline defer src="/ts.js"></script>
  </head>
  <body>
    <header class="space" id="field" aria-label="Tres" data-zg-room>
      {LETTERS.map((l) => (
        <span
          class="body glyph"
          data-zg
          data-zg-color
          data-home-x={l.x}
          data-home-y={l.y}
          data-home-xn={l.xn}
          data-home-yn={l.yn}
          style={`--hx:${l.x}; --hy:${l.y}; --hxn:${l.xn}; --hyn:${l.yn}; --s:${l.s};`}
          aria-hidden="true"
        ><span class="tx">{l.g}</span></span>
      ))}
      <p class="cue">scroll</p>
    </header>

    <nav class="menu" id="menuField" aria-label="Sections" data-zg-room>
      {MENU.map((m) => (
        <a class="body mword" href={m.href} draggable="false" data-zg data-home-x="50" data-home-y={m.y} style={`--hx:50; --hy:${m.y};`}>
          <span class="tx">{m.label}</span>
        </a>
      ))}
    </nav>

    <footer class="info">
      <div class="i-cols">
        <div class="i-col">
          <span class="lbl">Location</span>
          Seagrove · 30A<br />Florida, USA
        </div>
        <div class="i-col">
          <span class="lbl">Contact</span>
          <a href="mailto:tres@tres.studio">tres@tres.studio</a><br />
          <a href="https://instagram.com/tres.studio" target="_blank" rel="noopener">IG</a><br />
          <a href="https://www.linkedin.com/in/tres-carter" target="_blank" rel="noopener">LinkedIn</a>
        </div>
        <div class="i-col">
          <span class="lbl">Sections</span>
          <a href="/work">Work</a><br />
          <a href="/archive">Archive</a><br />
          <a href="/lab">Lab</a><br />
          <a href="/about">About</a><br />
          <a href="/resume.pdf">Resume</a><br />
          <a href="/portfolio.pdf">Portfolio</a><br />
          <a href="/labs/plugins">Plugins</a>
        </div>
      </div>
      <div class="i-meta">
        <span>© 2026 Tres Carter</span>
        <span id="mv-ticker-slot"></span>
        <a href="/privacy">Privacy</a>
      </div>
    </footer>

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }
      html, body { overflow-x: hidden; }
      html { background: #FAFAF7; }
      body { font-family: 'Hanken Grotesk', system-ui, sans-serif; color: #101010; -webkit-font-smoothing: antialiased; }
      ::selection { background: #101010; color: #FAFAF7; }
      a { color: inherit; text-decoration: none; }

      .space { position: relative; height: 100svh; }
      .menu { position: relative; height: 100svh; }

      /* Physics bodies. Static fallback: parked at percent homes, centered.
         When the sim boots (.sim), JS owns position via transform only. */
      .body {
        position: absolute;
        left: calc(var(--hx) * 1%); top: calc(var(--hy) * 1%);
        translate: -50% -50%;
        display: inline-grid; place-items: center;
        min-width: 44px; min-height: 44px;
        user-select: none; -webkit-user-select: none;
        -webkit-touch-callout: none;
        touch-action: none;
      }
      .sim .body { left: 0; top: 0; translate: none; will-change: transform; }

      .glyph {
        font-weight: 800; line-height: 1;
        font-size: calc(clamp(64px, 12vw, 176px) * var(--s));
      }
      @media (max-width: 640px) {
        .glyph { left: calc(var(--hxn) * 1%); top: calc(var(--hyn) * 1%); }
      }

      .mword {
        font-weight: 800; line-height: 1; letter-spacing: -0.01em;
        font-size: clamp(38px, 6.8vw, 88px);
      }
      .mword:focus-visible { outline: 2px solid #101010; outline-offset: 8px; }

      .tx { display: block; }
      @media (hover: hover) and (pointer: fine) {
        .sim .body { cursor: grab; }
        .sim .body:active { cursor: grabbing; }
        .mword .tx { transition-property: transform; transition-duration: 260ms; transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1); }
        .mword:hover .tx { transform: scale(1.05); }
      }
      /* Pressable feedback when the sim is off (reduced motion / no JS). */
      .menu:not(.sim) .mword:active .tx { transform: scale(0.96); }

      .cue {
        position: absolute; bottom: 6svh; left: 50%; translate: -50% 0;
        font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
        color: rgba(16, 16, 16, 0.45);
      }

      .info { min-height: 70svh; display: grid; align-content: end; gap: 7svh; position: relative; padding: 10svh 6vw 4svh; }
      .i-cols {
        display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px;
        padding-right: clamp(100px, 24vw, 240px);
        font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.05em;
        text-transform: uppercase; line-height: 1.9;
      }
      @media (max-width: 640px) { .i-cols { grid-template-columns: 1fr; } }
      .lbl { display: block; color: rgba(16,16,16,0.45); margin-bottom: 6px; }
      .i-meta {
        display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap;
        border-top: 1px solid rgba(0,0,0,0.14); padding-top: 16px;
        font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase;
      }
      @media (hover: hover) and (pointer: fine) {
        .info a:hover { text-decoration: underline; text-underline-offset: 4px; }
      }

      @media (prefers-reduced-motion: reduce) {
        .mword .tx { transition-duration: 1ms; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
      import('/mv/lab-takeover.js');
    </script>

    <script is:inline defer src="/mv/zerog.js"></script>
    <script is:inline defer src="/mv/ticker.js"></script>
  </body>
</html>
