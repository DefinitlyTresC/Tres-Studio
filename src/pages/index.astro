---
// HOMEPAGE — port of root index.html.
//
// This page is DELIBERATELY standalone: it does NOT use Base.astro. index.html
// ships its own self-contained <head>, its own inline <style> (whose token set
// drifts slightly from style.css — e.g. --sage/--bone/--fh/--th here differ
// from global.css), and its own inline behavior scripts. Porting it through
// Base would fight that. So the full <html> shell lives here and the original
// <style> is kept verbatim in a <style is:inline> block so Astro does NOT scope
// or rewrite its selectors (the inline behavior scripts + counter.js depend on
// those exact class names).
//
// WHAT CHANGED FROM index.html (the client fetch chain is GONE):
//   index.html loaded PapaParse + config.js + data.js at runtime ONLY to fill
//   the architecture/personal genre counts via DATA.getProjects(). That whole
//   chain is removed. The counts are now computed HERE at build time from the
//   baked 'projects' content collection and rendered into the .gcount spans.
//   RESULT: the built page makes ZERO requests to Google Sheets and never loads
//   PapaParse/config.js/data.js. The Lab count ("07 experiments") and Downloads
//   ("Soon") were already static in index.html and stay static.
//
// Genre-index links point at the clean category paths (/architecture,
// /personal, /lab); Downloads stays the mailto it is today. The visitor counter
// still loads /counter.js, which injects into .footer-base (kept on this page).
import { getCollection } from 'astro:content';

// Build-time genre counts — parity port of index.html's client-side counter:
//   arch = projects.filter(p => p.category === 'architecture').length
//   pers = projects.filter(p => p.category === 'personal').length
// (category is already lowercased/trimmed by sheet.ts, matching data.js.)
const projects = (await getCollection('projects')).map((e) => e.data);
const pad2 = (n: number) => String(n).padStart(2, '0');
const archCount = projects.filter((p) => p.category === 'architecture').length;
const persCount = projects.filter((p) => p.category === 'personal').length;
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
