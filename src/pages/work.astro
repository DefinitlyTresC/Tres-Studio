---
// Work — TV rows (V3.2, docs/specs/2026-07-21-v32-design.md §3). Three
// horizontal snap shelves: selected / past / personal. The page is fully
// STATIC — no [data-zg], no zerog.js. Personal = photography + personalart
// + lightboard + mystuff (photography/personalart also stay on /about).
// Theme via /theme.js + the var block — vars only, no literal colors below
// the block. V3.2.1: shelves loop seamlessly (whole-cycle clones + a
// band-wrapped scrollLeft, hairline seam at each joint) and drift slowly
// when idle on fine pointers — persistent pause toggle bottom right
// (WCAG 2.2.2). PRM / no-JS keep the finite static shelves.
import { getCollection } from 'astro:content';
import { joinUrl } from '../lib/cloudinary';

const all = (await getCollection('projects')).map((e) => e.data);

// Curated orders — fixed by hand, not by sheet order.
const SELECTED = ['ee13', 'z07', 'tucker', 'flatwood', 'drome', 'thesis'];
const PERSONAL = ['photography', 'personalart', 'lightboard', 'mystuff'];
const pick = (slugs) => slugs.map((s) => all.find((p) => p.slug === s)).filter(Boolean);

// Past = the architecture run, reverse-chronological (first 4-digit number
// in the year string; sheet order breaks ties).
const chosen = new Set(SELECTED);
const yearOf = (p) => {
  const m = /\d{4}/.exec(p.year || '');
  return m ? parseInt(m[0], 10) : 0;
};
const arch = all
  .filter((p) => p.category === 'architecture' && !chosen.has(p.slug))
  .sort((a, b) => yearOf(b) - yearOf(a) || a.order - b.order);

const rows = [
  { label: 'selected', items: pick(SELECTED) },
  { label: 'past', items: arch },
  { label: 'personal', items: pick(PERSONAL) },
];

// Card heroes: w_700 covers the ≤360px tiles at 2x.
const hero = (p) => joinUrl(p.heroImage, 'w_700', 'image');
// Per-hero crop anchors. Default (50% 70%, in CSS) favors the lower band
// where the renders live; portrait covers with the subject up top override.
const CROP = { thesis: '50% 0%' };
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#101010" />
    <title>Work — T R E S .</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- theme.js must run before any stylesheet: data-theme lands pre-paint -->
    <script is:inline src="/theme.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/cursor.css" />
    <!-- tracking: one bootstrap for the whole site (Umami + Clarity + visitor id + self-exclusion) - public/ts.js -->
    <script is:inline defer src="/ts.js"></script>
    <script is:inline>
      /* html.js gates the hidden-at-rest styles: no JS (or PRM) = fully drawn */
      (function () {
        var reduce = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}
        if (!reduce) document.documentElement.classList.add('js');
      })();
    </script>
  </head>
  <body>
    <script is:inline>
      /* Arrival swipe: the landing menu covered its exit with an ink panel
         sliding in from the right; this page starts covered and slides the
         panel out LEFT. JS-created only — a direct visit (no flag) or PRM
         never sees a panel, and the flag dies on read either way. */
      (function () {
        var go = false;
        try {
          go = sessionStorage.getItem('mv:swipe') === '1';
          sessionStorage.removeItem('mv:swipe');
        } catch (e) {}
        var reduce = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}
        if (!go || reduce) return;
        var p = document.createElement('div');
        p.setAttribute('aria-hidden', 'true');
        p.style.cssText = 'position:fixed;inset:0;z-index:1200;pointer-events:none;background:var(--ink);' +
          'transform:translateX(0);transition:transform 380ms cubic-bezier(0.23,1,0.32,1)';
        document.body.appendChild(p);
        function gone() { if (p.parentNode) p.parentNode.removeChild(p); }
        p.addEventListener('transitionend', gone);
        setTimeout(gone, 700); /* a starved transition must never hold the cover */
        requestAnimationFrame(function () {
          requestAnimationFrame(function () { p.style.transform = 'translateX(-101%)'; });
        });
      })();
    </script>

    <a class="back" id="back" href="/">← index</a>

    <main class="arch">
      <header class="head">
        <h1 class="name">W o r k</h1>
      </header>

      {rows.map((r, ri) => (
        <section class={ri === 0 ? 'row big' : 'row'}>
          <h2 class="r-lab rev">{r.label}</h2>
          <div class="shelf">
            <div class="strip">
              {r.items.map((p, i) => (
                <a class="card rev" href={`/project/${p.slug}`} style={`--d:${(i % 8) * 50}ms`}>
                  <span class="ph">
                    <img
                      src={hero(p)}
                      alt=""
                      width="700"
                      height="438"
                      decoding="async"
                      loading={ri === 0 && i === 0 ? undefined : 'lazy'}
                      fetchpriority={ri === 0 && i === 0 ? 'high' : undefined}
                      draggable="false"
                      style={CROP[p.slug] ? `object-position:${CROP[p.slug]}` : undefined}
                    />
                  </span>
                  <span class="c-tx">
                    <span class="c-name">{p.name}</span>
                    {p.year && <span class="c-year">{p.year}</span>}
                  </span>
                </a>
              ))}
            </div>
            <button class="nud l" type="button" aria-label={`${r.label} — back`}>‹</button>
            <button class="nud r" type="button" aria-label={`${r.label} — forward`}>›</button>
          </div>
        </section>
      ))}
    </main>

    <footer class="foot">
      <span>© 2026 Tres Carter</span>
      <a href="/privacy">Privacy</a>
    </footer>

    <button class="drift-toggle" id="drift-toggle" type="button" aria-label="Pause automatic scrolling">pause</button>

    <style is:inline>
      :root {
        --paper: #FAFAF7; --ink: #101010;
        --soft: rgba(16,16,16,0.66);      /* secondary text */
        --faint: rgba(16,16,16,0.62);    /* labels, meta   */
        --hair: rgba(0,0,0,0.14);        /* hairlines      */
        --tint: rgba(16,16,16,0.04);     /* image wells    */
      }
      html[data-theme="dark"] {
        --paper: #101010; --ink: #FAFAF7;
        --soft: rgba(250,250,247,0.62);
        --faint: rgba(250,250,247,0.55);
        --hair: rgba(255,255,255,0.16);
        --tint: rgba(250,250,247,0.05);
      }
      html[data-theme="red"] {
        --paper: #E0301F; --ink: #0A0A0A;
        --soft: rgba(10,10,10,0.78);
        --faint: rgba(10,10,10,0.72);
        --hair: rgba(0,0,0,0.25);
        --tint: rgba(0,0,0,0.06);
      }
      html { background: var(--paper); }
      body { color: var(--ink); }
      ::selection { background: var(--ink); color: var(--paper); }

      * { margin: 0; box-sizing: border-box; }
      body { font-family: 'Space Mono', ui-monospace, monospace; -webkit-font-smoothing: antialiased; }
      a { color: inherit; text-decoration: none; }
      img { max-width: 100%; }
      .back { position: fixed; z-index: 10; top: var(--y, 14px); left: 6vw; font-family: 'Space Mono', monospace; font-size: 12px; padding: 12px 0; transition: transform 140ms cubic-bezier(0.23,1,0.32,1); }
      .back:active { transform: scale(0.96); }
      @media (hover: hover) and (pointer: fine) { .back:hover { text-decoration: underline; text-underline-offset: 4px; } }
      .back:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }

      .arch { padding: 0 6vw 12svh; }
      .head { padding: clamp(110px, 22vh, 260px) 0 clamp(48px, 8svh, 110px); }
      .name { font-weight: 700; font-size: clamp(44px, 9vw, 110px); line-height: 1; }

      /* TV rows: the page scrolls down, each shelf side-scrolls. Shelves run
         full-bleed (negative gutter margins) so cards slide under the page
         edge — .strip's own overflow contains them, the body never grows
         sideways. Vertical wheel is never touched. */
      .row + .row { margin-top: clamp(60px, 11svh, 140px); }
      .r-lab { font-family: 'Space Mono', monospace; font-size: 11px; font-weight: 400; letter-spacing: 0.2em; text-transform: uppercase; color: var(--faint); padding-bottom: 16px; }
      .shelf { position: relative; margin: 0 -6vw; }
      .strip {
        display: flex; gap: clamp(14px, 2.2vw, 24px);
        overflow-x: auto; overscroll-behavior-x: contain;
        scroll-snap-type: x mandatory; scroll-padding-inline: 6vw;
        padding: 6px 6vw; /* the 6px gives focus outlines room inside the clip */
        scrollbar-width: none;
      }
      .strip::-webkit-scrollbar { display: none; }

      .card { flex: 0 0 clamp(200px, 34vw, 320px); scroll-snap-align: start; display: grid; gap: 10px; align-content: start; }
      .row.big .card { flex-basis: clamp(220px, 38vw, 360px); }
      .ph { display: block; aspect-ratio: 16 / 10; overflow: hidden; border-radius: 14px; border: 1px solid var(--hair); background: var(--tint); }
      .ph img { display: block; width: 100%; height: 100%; object-fit: cover; object-position: 50% 70%; }
      .c-tx { display: grid; gap: 4px; padding: 0 2px; }
      .c-name { font-weight: 700; font-size: clamp(15px, 1.8vw, 18px); line-height: 1.2; letter-spacing: -0.01em; }
      .row.big .c-name { font-size: clamp(16px, 2vw, 20px); }
      .c-year { font-family: 'Space Mono', monospace; font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--faint); }
      .card:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }

      /* Desktop affordances only: edge fades + hover chevrons. Coarse
         pointers keep bare native scroll — the chevrons stay display:none
         and unwired. */
      .nud { display: none; }
      @media (hover: hover) and (pointer: fine) {
        .strip {
          mask-image: linear-gradient(90deg, transparent 0, #000 5vw, #000 calc(100% - 5vw), transparent 100%);
          -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 5vw, #000 calc(100% - 5vw), transparent 100%);
        }
        .nud {
          position: absolute; z-index: 2; top: calc(50% - 42px); /* centers on the image band, not the text */
          display: grid; place-items: center; width: 40px; height: 40px; padding: 0;
          border: 1px solid var(--hair); border-radius: 999px;
          background: var(--paper); color: var(--ink);
          font: 700 18px/1 'Space Mono', ui-monospace, monospace;
          cursor: pointer; opacity: 0;
          transition: opacity 160ms ease, transform 140ms cubic-bezier(0.23,1,0.32,1);
        }
        .nud.l { left: clamp(8px, 2vw, 26px); }
        .nud.r { right: clamp(8px, 2vw, 26px); }
        .shelf:hover .nud:not(.off), .nud:focus-visible:not(.off) { opacity: 1; }
        .nud:hover { transform: scale(1.06); }
        .nud:active { transform: scale(0.94); }
        .nud.off { pointer-events: none; }
        .nud:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }

        .ph img { transition: transform 500ms cubic-bezier(0.23,1,0.32,1); }
        .c-name { transition: letter-spacing 300ms cubic-bezier(0.23,1,0.32,1); }
        .card:hover .ph img { transform: scale(1.02); }
        .card:hover .c-name { letter-spacing: 0.02em; }
      }

      .foot { display: flex; justify-content: space-between; padding: 3svh 6vw 4svh; border-top: 1px solid var(--hair); font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; }

      /* Loop seam — the line at the joint of each shelf's cycle. JS-created,
         so PRM / no-JS strips never carry one. */
      .loop-seam { flex: 0 0 1px; align-self: stretch; background: var(--hair); }

      /* Persistent pause for the auto-drift (WCAG 2.2.2) — shown only while
         the drift exists (html.drift = fine pointer + motion allowed). */
      .drift-toggle { display: none; }
      html.drift .drift-toggle { display: block; position: fixed; z-index: 10; right: 6vw; bottom: calc(12px + env(safe-area-inset-bottom, 0px)); padding: 15px 0 15px 15px; background: var(--paper); border: none; cursor: pointer; font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--faint); transition: color 140ms cubic-bezier(0.23,1,0.32,1), transform 140ms cubic-bezier(0.23,1,0.32,1); }
      html.drift .drift-toggle:active { transform: scale(0.96); }
      @media (hover: hover) and (pointer: fine) {
        html.drift .drift-toggle:hover { color: var(--ink); text-decoration: underline; text-underline-offset: 4px; }
      }
      .drift-toggle:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }
    </style>

    <style is:inline>
      /* Scroll reveal: hidden-at-rest lives ONLY under html.js + no-preference
         — PRM and no-JS both land on the complete page with zero motion. */
      @media (prefers-reduced-motion: no-preference) {
        html.js .rev { opacity: 0; transform: translateY(14px); transition: opacity 600ms ease var(--d, 0ms), transform 600ms cubic-bezier(0.23,1,0.32,1) var(--d, 0ms); }
        html.js .rev.on { opacity: 1; transform: none; }
      }
      @media (prefers-reduced-motion: reduce) {
        .back, .ph img, .c-name, .nud, .drift-toggle { transition: none; }
        .back:active, .nud:hover, .nud:active, .drift-toggle:active { transform: none; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
    </script>
    <script is:inline>
      (function () {
        var reduce = false, fine = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; fine = matchMedia('(hover: hover) and (pointer: fine)').matches; } catch (e) {}
        if (!fine || reduce) return;
        var back = document.getElementById('back');
        var target = null, cur = null, raf = null;
        function frame() {
          cur += (target - cur) * 0.09;
          back.style.setProperty('--y', cur.toFixed(1) + 'px');
          if (Math.abs(target - cur) > 0.4) raf = requestAnimationFrame(frame); else raf = null;
        }
        addEventListener('pointermove', function (e) {
          if (e.pointerType === 'touch') return; /* hybrids: taps must not move it */
          var h = back.offsetHeight;
          target = Math.min(innerHeight - h - 12, Math.max(12, e.clientY - h / 2));
          if (cur === null) cur = target;
          if (!raf) raf = requestAnimationFrame(frame);
        }, { passive: true });
      })();
    </script>
    <script is:inline>
      (function () {
        if (!document.documentElement.classList.contains('js')) return;
        /* Rect-check, not IntersectionObserver — the failure mode reveals
           immediately instead of never (roadmap.astro carries the full why).
           Horizontal strip scroll never moves an element's top, so window
           scroll + resize are the only triggers needed. */
        var left = [];
        var els = document.querySelectorAll('.rev');
        for (var i = 0; i < els.length; i++) left.push(els[i]);
        var raf = null;
        function check() {
          raf = null;
          var limit = innerHeight * 0.92;
          for (var i = left.length - 1; i >= 0; i--) {
            if (left[i].getBoundingClientRect().top < limit) {
              left[i].classList.add('on');
              left.splice(i, 1);
            }
          }
          if (!left.length) {
            removeEventListener('scroll', queue);
            removeEventListener('resize', queue);
          }
        }
        function queue() { if (!raf) raf = requestAnimationFrame(check); }
        addEventListener('scroll', queue, { passive: true });
        addEventListener('resize', queue, { passive: true });
        check();
      })();
    </script>
    <script is:inline>
      (function () {
        /* Chevron nudges — fine pointers only (coarse: display:none, no
           wiring). One card per click; .off marks a spent edge. Wheel and
           touch stay native. */
        var fine = false, reduce = false;
        try { fine = matchMedia('(hover: hover) and (pointer: fine)').matches; reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}
        if (!fine) return;
        var shelves = document.querySelectorAll('.shelf');
        for (var i = 0; i < shelves.length; i++) (function (shelf) {
          var strip = shelf.querySelector('.strip');
          var l = shelf.querySelector('.nud.l'), r = shelf.querySelector('.nud.r');
          function step() {
            var c = strip.querySelector('.card');
            var g = parseFloat(getComputedStyle(strip).columnGap) || 0;
            return c ? c.getBoundingClientRect().width + g : strip.clientWidth * 0.8;
          }
          function go(dir) { strip.scrollBy({ left: dir * step(), behavior: reduce ? 'auto' : 'smooth' }); }
          function sync() {
            var max = strip.scrollWidth - strip.clientWidth;
            l.classList.toggle('off', strip.scrollLeft < 4);
            r.classList.toggle('off', strip.scrollLeft > max - 4);
          }
          l.addEventListener('click', function () { go(-1); });
          r.addEventListener('click', function () { go(1); });
          strip.addEventListener('scroll', sync, { passive: true });
          addEventListener('resize', sync, { passive: true });
          sync();
        })(shelves[i]);
      })();
    </script>
    <script is:inline>
      /* Shelf loop + drift (V3.2.1). Each strip gets a hairline seam
         appended, then whole-cycle clones until the wrap band always has
         content; scrollLeft teleports ±W (one cycle) at the band edges —
         the copies are pixel-identical, so the joint is invisible and every
         shelf is endless in both directions. The backward wrap arms only
         after a shelf first crosses half a cycle, so the natural left edge
         holds until you've actually looped. On idle (fine pointers) a slow
         drift (~24 px/s) eases in and carries each shelf; real input stops
         it dead, hovering a shelf holds just that shelf, and the
         bottom-right toggle pauses everything persistently (WCAG 2.2.2).
         Scroll-snap is parked while a shelf drifts and handed back the
         moment the visitor takes over. Gate: html.js = motion allowed, so
         PRM / no-JS keep the finite static shelves; flipping Reduce Motion
         on mid-session tears the whole thing down. */
      (function () {
        var doc = document.documentElement;
        if (!doc.classList.contains('js')) return;

        var coarse = false, fine = false;
        try {
          coarse = matchMedia('(pointer: coarse)').matches;
          fine = matchMedia('(hover: hover) and (pointer: fine)').matches;
        } catch (e) {}

        var dead = false, rafId = null, shelves = [];

        function buildShelf(el) {
          var strip = el.querySelector('.strip');
          if (!strip || !strip.querySelector('.card')) return null;
          var st = { el: el, strip: strip, W: 0, copies: 1, added: [], armed: false, hovered: false, v: 0, pos: null, snapOff: false, ro: null };

          var seam = document.createElement('div');
          seam.className = 'loop-seam';
          seam.setAttribute('aria-hidden', 'true');
          strip.appendChild(seam);
          st.added.push(seam);
          var unit = Array.prototype.slice.call(strip.children); /* cards + seam = one cycle */

          function addCopy() {
            for (var i = 0; i < unit.length; i++) {
              var c = unit[i].cloneNode(true);
              c.setAttribute('aria-hidden', 'true'); /* SR + keyboard get one copy; mouse can still click */
              c.classList.add('on'); /* the reveal rect-check ran before us */
              if (c.tagName === 'A') c.setAttribute('tabindex', '-1');
              strip.appendChild(c);
              st.added.push(c);
            }
            st.copies++;
          }
          addCopy();

          function measure() {
            st.W = strip.children[unit.length].offsetLeft - strip.children[0].offsetLeft;
            /* the wrap band plus a viewport must always be covered */
            var guard = 0;
            while (st.W > 0 && st.copies * st.W < 1.5 * st.W + strip.clientWidth && guard++ < 8) addCopy();
          }
          measure();
          if ('ResizeObserver' in window) { st.ro = new ResizeObserver(measure); st.ro.observe(strip); }

          function kbIn() {
            /* teleporting while a focus ring is visible in this shelf would
               strand it offscreen (clone links are tabindex=-1) */
            var ae = document.activeElement;
            if (!ae || !el.contains(ae)) return false;
            try { return ae.matches(':focus-visible'); } catch (e) { return true; }
          }
          st.wrap = function () {
            if (dead || !st.W) return;
            var x = strip.scrollLeft;
            if (x >= 0.5 * st.W) st.armed = true;
            if (kbIn()) return;
            if (x > 1.25 * st.W) strip.scrollLeft = x - st.W;
            else if (st.armed && x < 0.25 * st.W) strip.scrollLeft = x + st.W;
          };

          /* touch momentum dies if we teleport mid-fling — wrap on settle,
             plus an emergency wrap only near the strip's true edges */
          if (coarse && 'onscrollend' in window) {
            strip.addEventListener('scrollend', st.wrap, { passive: true });
            strip.addEventListener('scroll', function () {
              if (dead || !st.W) return;
              var x = strip.scrollLeft, max = strip.scrollWidth - strip.clientWidth;
              if (x < 60 || x > max - 60) st.wrap();
            }, { passive: true });
          } else {
            strip.addEventListener('scroll', st.wrap, { passive: true });
          }

          el.addEventListener('pointerenter', function (e) { if (e.pointerType !== 'touch') st.hovered = true; });
          el.addEventListener('pointerleave', function () { st.hovered = false; });
          return st;
        }

        var els = document.querySelectorAll('.shelf');
        for (var i = 0; i < els.length; i++) {
          var st = buildShelf(els[i]);
          if (st) shelves.push(st);
        }
        if (!shelves.length) return;

        /* mid-session Reduce Motion must actually stop everything */
        function teardown() {
          if (dead) return;
          dead = true;
          if (rafId) cancelAnimationFrame(rafId);
          doc.classList.remove('drift');
          for (var i = 0; i < shelves.length; i++) {
            var s = shelves[i];
            if (s.ro) s.ro.disconnect();
            if (s.W) s.strip.scrollLeft = s.strip.scrollLeft % s.W;
            for (var j = 0; j < s.added.length; j++) {
              if (s.added[j].parentNode) s.added[j].parentNode.removeChild(s.added[j]);
            }
            s.strip.style.scrollSnapType = '';
          }
        }
        try {
          var prmq = matchMedia('(prefers-reduced-motion: reduce)');
          if (prmq.addEventListener) prmq.addEventListener('change', function (ev) { if (ev.matches) teardown(); });
        } catch (e) {}

        if (!fine) return; /* drift is a spectator-mode desktop luxury */

        var SPEED = 24; /* px/s cruise — about one card per ~14s */
        var paused = false;
        try { paused = sessionStorage.getItem('workDriftPaused') === '1'; } catch (e) {}
        var resumeAt = performance.now() + 3500, last = null;
        function hold(ms) { resumeAt = Math.max(resumeAt, performance.now() + ms); }
        /* real input takes over instantly — no coast-out fighting the user */
        function interrupt(e) {
          hold(3000);
          for (var i = 0; i < shelves.length; i++) {
            var s = shelves[i];
            s.v = 0; s.pos = null;
            if (s.snapOff && e && e.target && s.el.contains(e.target)) {
              s.strip.style.scrollSnapType = '';
              s.snapOff = false;
            }
          }
        }
        addEventListener('wheel', interrupt, { passive: true });
        addEventListener('touchstart', interrupt, { passive: true });
        addEventListener('pointerdown', interrupt, { passive: true });
        addEventListener('keydown', interrupt);
        addEventListener('blur', function () {
          for (var i = 0; i < shelves.length; i++) shelves[i].hovered = false;
        });

        /* WCAG 2.2.2: a persistent, keyboard-reachable stop for the motion */
        var toggle = document.getElementById('drift-toggle');
        function paint() {
          if (!toggle) return;
          toggle.textContent = paused ? 'drift' : 'pause';
          toggle.setAttribute('aria-label', paused ? 'Resume automatic scrolling' : 'Pause automatic scrolling');
        }
        if (toggle) {
          toggle.addEventListener('click', function () {
            paused = !paused;
            try { sessionStorage.setItem('workDriftPaused', paused ? '1' : '0'); } catch (e) {}
            if (!paused) resumeAt = performance.now() + 800;
            paint();
          });
        }
        paint();
        doc.classList.add('drift');

        function frame(t) {
          if (dead) return;
          rafId = requestAnimationFrame(frame);
          if (last === null) { last = t; return; }
          var dt = Math.min((t - last) / 1000, 0.05);
          last = t;
          for (var i = 0; i < shelves.length; i++) {
            var s = shelves[i];
            var want = (!paused && !s.hovered && t >= resumeAt) ? SPEED : 0;
            s.v += (want - s.v) * Math.min(1, dt * 1.6); /* gentle ease-in on resume */
            if (s.v < 0.5) { s.pos = null; continue; }
            if (!s.snapOff) { s.strip.style.scrollSnapType = 'none'; s.snapOff = true; }
            if (s.pos === null) s.pos = s.strip.scrollLeft;
            s.pos += s.v * dt;
            s.strip.scrollLeft = s.pos;
            s.wrap();
            /* wrap teleported us, or the visitor scrolled: follow reality */
            if (Math.abs(s.strip.scrollLeft - s.pos) > 2) s.pos = s.strip.scrollLeft;
          }
        }
        rafId = requestAnimationFrame(frame);
      })();
    </script>
  </body>
</html>
