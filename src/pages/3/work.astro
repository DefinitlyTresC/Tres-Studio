---
// Site 3 — work.
import { MV_CLIENT } from '../../lib/multiverse';
import { getCollection } from 'astro:content';
const WORK = ['z07', 'ee13', 'flatwood', 'tucker', 'thesis'];
const all = (await getCollection('projects')).map((e) => e.data);
const rows = WORK.map((s) => all.find((p) => p.slug === s)).filter(Boolean);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FFFFFF" />
    <title>work — TRES [ascii]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Anybody:wdth,wght@150,900&family=JetBrains+Mono:wght@400;600;700&family=Space+Mono&display=swap" rel="stylesheet" />
    <script is:inline set:html={MV_CLIENT(3)} />
    <!-- Umami analytics — data-domains scopes tracking to the real site so
         previews/branch URLs don't pollute stats. Clarity below is guarded
         to the production host for the same reason. -->
    <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="96e73988-106a-415e-bf80-5e10ffaec0dc" data-domains="tres.studio"></script>
    <script is:inline type="text/javascript">
      if (location.hostname === 'tres.studio') {
        (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "xang6oq7f9");
      }
    </script>
  </head>
  <body>
    <a class="back" id="back" href="/3/">&lt;- index</a>
    <main class="arch">
      <header class="head">
        <p class="spec">/work · {String(rows.length).padStart(2, '0')} entries</p>
        <h1 class="name">selected_work</h1>
      </header>
      <div class="list">
        {rows.map((p, i) => (
          <a class="row" href={`/3/project/${p.slug}`}>
            <span class="r-no">[{String(i + 1).padStart(2, '0')}]</span>
            <span class="r-name">{p.name.toLowerCase()}</span>
            <span class="r-meta">{p.year}</span>
          </a>
        ))}
      </div>
    </main>
    <footer class="foot"><span>© 2026 tres carter</span><a href="/privacy">privacy</a></footer>

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }
      html { background: #fff; }
      body { font-family: 'JetBrains Mono', ui-monospace, monospace; color: #141414; -webkit-font-smoothing: antialiased; }
      ::selection { background: #141414; color: #fff; }
      a { color: inherit; text-decoration: none; }
      .back { position: fixed; z-index: 10; top: var(--y, 14px); left: 6vw; font-size: 12px; padding: 12px 0; transition: transform 140ms cubic-bezier(0.23,1,0.32,1); }
      .back:active { transform: scale(0.96); }
      @media (hover: hover) and (pointer: fine) { .back:hover { text-decoration: underline; text-underline-offset: 4px; } }
      .back:focus-visible { outline: 2px solid #141414; outline-offset: 3px; }
      .arch { max-width: 900px; margin: 0 auto; padding: 0 6vw 12svh; }
      .head { padding: clamp(110px, 22vh, 260px) 0 7svh; }
      .spec { font-size: 12px; letter-spacing: 0.12em; color: rgba(20,20,20,0.45); }
      .name { font-family: 'Anybody', 'Arial Black', sans-serif; font-weight: 900; font-stretch: 150%; font-size: clamp(24px, 4.6vw, 54px); line-height: 1; margin-top: 12px; }
      .list { border-top: 1px dashed rgba(0,0,0,0.25); }
      .row { display: flex; align-items: baseline; gap: 16px; padding: 24px 0; border-bottom: 1px dashed rgba(0,0,0,0.25); }
      .r-no, .r-meta { font-size: 12px; color: rgba(20,20,20,0.45); }
      .r-meta { margin-left: auto; }
      .r-name { font-weight: 700; font-size: clamp(20px, 3.6vw, 36px); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      @media (hover: hover) and (pointer: fine) {
        .r-name { transition: letter-spacing 260ms cubic-bezier(0.23,1,0.32,1); }
        .row:hover .r-name { letter-spacing: 0.08em; }
      }
      .foot { display: flex; justify-content: space-between; max-width: 900px; margin: 0 auto; padding: 3svh 6vw 4svh; border-top: 1px dashed rgba(0,0,0,0.25); font-size: 10px; letter-spacing: 0.06em; }
      @media (prefers-reduced-motion: reduce) {
        .back, .r-name { transition: none; }
        .back:active { transform: none; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
    </script>
    <script is:inline>
      (function () {
        var reduce = false, fine = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; fine = matchMedia('(hover: hover) and (pointer: fine)').matches; } catch (e) {}
        if (!fine || reduce) return;
        var back = document.getElementById('back');
        var target = null, cur = null, raf = null;
        function frame() {
          cur += (target - cur) * 0.09;
          back.style.setProperty('--y', cur.toFixed(1) + 'px');
          if (Math.abs(target - cur) > 0.4) raf = requestAnimationFrame(frame); else raf = null;
        }
        addEventListener('pointermove', function (e) {
          if (e.pointerType === 'touch') return; /* hybrids: taps must not move it */
          var h = back.offsetHeight;
          target = Math.min(innerHeight - h - 12, Math.max(12, e.clientY - h / 2));
          if (cur === null) cur = target;
          if (!raf) raf = requestAnimationFrame(frame);
        }, { passive: true });
      })();
    </script>
  </body>
</html>
