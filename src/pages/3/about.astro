---
// Site 3 — about.
import { MV_CLIENT } from '../../lib/multiverse';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FFFFFF" />
    <title>about — TRES [ascii]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Space+Mono&display=swap" rel="stylesheet" />
    <script is:inline set:html={MV_CLIENT(3)} />
  </head>
  <body>
    <a class="back" id="back" href="/3/">&lt;- index</a>
    <main class="about">
      <h1 class="sr-only">Tres Carter — architectural designer, 30A, Florida</h1>
      <pre class="fig" aria-hidden="true">
+----------------------+
|  tres carter         |
|  architectural       |
|  designer            |
|  30a, florida        |
+----------------------+</pre>
      <div class="acts">
        <a href="mailto:tres@tres.studio">tres@tres.studio</a>
        <a href="https://instagram.com/tres.studio" target="_blank" rel="noopener">ig</a>
      </div>
    </main>

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }
      html { background: #fff; }
      body { font-family: 'JetBrains Mono', ui-monospace, monospace; color: #141414; -webkit-font-smoothing: antialiased; }
      ::selection { background: #141414; color: #fff; }
      a { color: inherit; text-decoration: none; }
      .back { position: fixed; z-index: 10; top: var(--y, 14px); left: 6vw; font-size: 12px; padding: 12px 0; transition: transform 140ms cubic-bezier(0.23,1,0.32,1); }
      .back:active { transform: scale(0.96); }
      @media (hover: hover) and (pointer: fine) { .back:hover { text-decoration: underline; text-underline-offset: 4px; } }
      .back:focus-visible { outline: 2px solid #141414; outline-offset: 3px; }
      .about { max-width: 900px; margin: 0 auto; padding: clamp(140px, 28vh, 340px) 6vw 16svh; }
      .sr-only { position: absolute; width: 1px; height: 1px; margin: -1px; padding: 0; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0; }
      .fig { font-family: inherit; font-weight: 600; font-size: clamp(16px, 3.4vw, 30px); line-height: 1.4; }
      .acts { display: flex; gap: 28px; margin-top: 44px; font-size: 13px; }
      /* 44px hit areas without moving anything: pad out, pull back in */
      .acts a { display: inline-block; padding: 14px; margin: -14px; }
      @media (hover: hover) and (pointer: fine) { a:hover { text-decoration: underline; text-underline-offset: 4px; } }
      .acts a:focus-visible { outline: 2px solid #141414; outline-offset: 3px; }
      @media (prefers-reduced-motion: reduce) {
        .back { transition: none; }
        .back:active { transform: none; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
    </script>
    <script is:inline>
      (function () {
        var reduce = false, fine = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; fine = matchMedia('(hover: hover) and (pointer: fine)').matches; } catch (e) {}
        if (!fine || reduce) return;
        var back = document.getElementById('back');
        var target = null, cur = null, raf = null;
        function frame() {
          cur += (target - cur) * 0.09;
          back.style.setProperty('--y', cur.toFixed(1) + 'px');
          if (Math.abs(target - cur) > 0.4) raf = requestAnimationFrame(frame); else raf = null;
        }
        addEventListener('pointermove', function (e) {
          if (e.pointerType === 'touch') return; /* hybrids: taps must not move it */
          var h = back.offsetHeight;
          target = Math.min(innerHeight - h - 12, Math.max(12, e.clientY - h / 2));
          if (cur === null) cur = target;
          if (!raf) raf = requestAnimationFrame(frame);
        }, { passive: true });
      })();
    </script>
  </body>
</html>
