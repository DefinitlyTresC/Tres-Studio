---
// Site 3 — "the terminal one." TRES built from characters: a whirlwind of
// glyphs spins in and settles into ASCII letterforms, shimmering alive.
// Everything on this site speaks monospace.
import { MV_CLIENT } from '../../lib/multiverse';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#FFFFFF" />
    <title>TRES [ascii]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Space+Mono&display=swap" rel="stylesheet" />
    <script is:inline set:html={MV_CLIENT(3)} />
  </head>
  <body>
    <header class="scene">
      <canvas id="ascii" aria-label="TRES"></canvas>
      <p class="cue">[ scroll ]</p>
    </header>

    <nav class="menu" aria-label="Sections">
      <a href="/3/work"><span class="pre">01 ──</span> work</a>
      <a href="/3/archive"><span class="pre">02 ──</span> archive</a>
      <a href="/lab"><span class="pre">03 ──</span> lab</a>
      <a href="/3/about"><span class="pre">04 ──</span> about</a>
    </nav>

    <footer id="mv-info" class="info">
      <div class="i-cols">
        <div class="i-col">
          <span class="lbl">location</span>
          seagrove · 30a<br />florida, usa
        </div>
        <div class="i-col">
          <span class="lbl">contact</span>
          <a href="mailto:tres@tres.studio">tres@tres.studio</a><br />
          <a href="https://instagram.com/tres.studio" target="_blank" rel="noopener">ig</a><br />
          <a href="https://www.linkedin.com/in/tres-carter" target="_blank" rel="noopener">linkedin</a>
        </div>
        <div class="i-col">
          <span class="lbl">sections</span>
          <a href="/3/work">work</a><br />
          <a href="/3/archive">archive</a><br />
          <a href="/lab">lab</a><br />
          <a href="/3/about">about</a><br />
          <a href="/resume.pdf">resume</a><br />
          <a href="/portfolio.pdf">portfolio</a><br />
          <span style="color:rgba(20,20,20,0.45)">plugins — soon</span>
        </div>
      </div>
      <div class="i-meta">
        <span>© 2026 tres carter</span>
        <span id="mv-ticker-slot"></span>
        <a href="/privacy">privacy</a>
      </div>
    </footer>

    <style is:inline>
      :root {
        --mvt-card: #ffffff; --mvt-ink: #141414; --mvt-line: rgba(0,0,0,0.3);
        --mvt-label: rgba(0,0,0,0.5); --mvt-accent: #141414; --mvt-confetti: #141414,#6a6a6a,#ffffff;
      }
      * { margin: 0; box-sizing: border-box; }
      html, body { overflow-x: hidden; }
      html { background: #fff; }
      body { font-family: 'IBM Plex Mono', ui-monospace, monospace; color: #141414; -webkit-font-smoothing: antialiased; }
      ::selection { background: #141414; color: #fff; }
      a { color: inherit; text-decoration: none; }

      .scene { position: relative; height: 100svh; }
      #ascii { display: block; width: 100%; height: 100%; }
      .cue { position: absolute; bottom: 4svh; left: 50%; translate: -50% 0; font-size: 11px; letter-spacing: 0.18em; color: rgba(20,20,20,0.4); }

      .menu { min-height: 90svh; display: grid; align-content: center; gap: 0; max-width: 900px; margin: 0 auto; padding: 0 6vw; }
      .menu a {
        display: flex; align-items: baseline; gap: 14px;
        padding: 4.4svh 0; border-bottom: 1px dashed rgba(0,0,0,0.25);
        font-weight: 600; font-size: clamp(26px, 5.4vw, 58px); letter-spacing: 0.02em;
      }
      .menu a:first-child { border-top: 1px dashed rgba(0,0,0,0.25); }
      .menu .pre { font-weight: 400; font-size: 12px; color: rgba(20,20,20,0.45); letter-spacing: 0; }
      @media (hover: hover) and (pointer: fine) {
        .menu a { transition: letter-spacing 260ms cubic-bezier(0.23,1,0.32,1); }
        .menu a:hover { letter-spacing: 0.1em; }
      }

      .info { min-height: 70svh; display: grid; align-content: end; gap: 7svh; position: relative; padding: 10svh 6vw 4svh; }
      .i-cols {
        display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px;
        padding-right: clamp(100px, 24vw, 240px);
        font-size: 12px; letter-spacing: 0.05em; line-height: 1.9;
      }
      @media (max-width: 640px) { .i-cols { grid-template-columns: 1fr; } }
      .lbl { display: block; color: rgba(20,20,20,0.45); margin-bottom: 6px; }
      .i-meta {
        display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap;
        border-top: 1px dashed rgba(0,0,0,0.25); padding-top: 16px;
        font-size: 10px; letter-spacing: 0.06em;
      }
      @media (hover: hover) and (pointer: fine) {
        .info a:hover { text-decoration: underline; text-underline-offset: 4px; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
      import('/mv/ring.js');
    </script>

    <script is:inline>
      (function () {
        'use strict';
        var reduce = false, fine = false;
        try {
          reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
          fine = matchMedia('(hover: hover) and (pointer: fine)').matches;
        } catch (e) {}

        var cv = document.getElementById('ascii');
        var ctx = cv.getContext('2d');
        var dpr = Math.min(2, devicePixelRatio || 1);
        var RAMP = ' .,:;-=+*#%@';
        var cells = [], CW = 0, CH = 0, cols = 0, rows = 0;
        var t0 = null, mx = -1e4, my = -1e4;

        function build() {
          var small = innerWidth < 700;
          var fs = small ? 11 : 13;          /* cell font */
          CW = fs * 0.62; CH = fs * 1.18;
          cols = Math.floor(innerWidth / CW);
          rows = Math.floor(innerHeight / CH);
          cv.width = innerWidth * dpr; cv.height = innerHeight * dpr;
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          ctx.font = '600 ' + fs + 'px "IBM Plex Mono", monospace';
          ctx.textBaseline = 'top';

          /* rasterize TRES to a density map */
          var off = document.createElement('canvas');
          off.width = cols; off.height = rows;
          var o = off.getContext('2d');
          o.fillStyle = '#000';
          var word = 'TRES';
          var size = rows * (small ? 0.34 : 0.42);
          o.font = '900 ' + size + 'px Arial, sans-serif';
          o.textAlign = 'center'; o.textBaseline = 'middle';
          /* squeeze horizontally so the word fills the grid's aspect */
          o.save();
          o.translate(cols / 2, rows / 2);
          var tw = o.measureText(word).width;
          o.scale(Math.min(1, (cols * 0.86) / tw), 0.62);
          o.fillText(word, 0, 0);
          o.restore();
          var data = o.getImageData(0, 0, cols, rows).data;

          cells = [];
          var cx = innerWidth / 2, cy = innerHeight / 2;
          for (var r = 0; r < rows; r++) {
            for (var c = 0; c < cols; c++) {
              var a = data[(r * cols + c) * 4 + 3] / 255;
              var isBg = a < 0.12;
              /* sparse background texture, like the poster */
              if (isBg && Math.random() > 0.055) continue;
              var x = c * CW, y = r * CH;
              cells.push({
                x: x, y: y,
                ch: isBg
                  ? ',.\'`'[Math.floor(Math.random() * 4)]
                  : RAMP[Math.max(2, Math.floor(a * (RAMP.length - 1)))],
                bg: isBg,
                d: Math.hypot(x - cx, y - cy),           /* delay seed */
                ang: Math.atan2(y - cy, x - cx),
                seed: Math.random() * 6.2832,
              });
            }
          }
        }

        function draw(now) {
          if (t0 === null) t0 = now;
          var T = (now - t0) / 1000;
          ctx.clearRect(0, 0, innerWidth, innerHeight);
          var maxD = Math.hypot(innerWidth, innerHeight) / 2;

          for (var i = 0; i < cells.length; i++) {
            var s = cells[i];
            /* whirl-in: each cell spirals to its seat, outer cells later */
            var p = Math.min(1, Math.max(0, (T - s.d / maxD * 0.9) / 1.1));
            var e = 1 - Math.pow(1 - p, 3);
            var x = s.x, y = s.y, alpha = e;
            if (e < 1) {
              var rr = (1 - e) * maxD * 0.5;
              var aa = s.ang + (1 - e) * 4.2;
              x += Math.cos(aa) * rr;
              y += Math.sin(aa) * rr;
            } else {
              /* idle: breathe + pointer vortex */
              var wob = Math.sin(T * 0.7 + s.seed) * 1.2;
              y += wob;
              if (fine) {
                var dx = x - mx, dy = y - my;
                var dd = Math.hypot(dx, dy);
                if (dd < 110 && dd > 0.1) {
                  var f = (110 - dd) / 110;
                  var va = Math.atan2(dy, dx) + 1.5708;
                  x += Math.cos(va) * f * 14;
                  y += Math.sin(va) * f * 14;
                }
              }
            }
            ctx.fillStyle = s.bg
              ? 'rgba(20,20,20,' + (0.2 * alpha).toFixed(2) + ')'
              : 'rgba(20,20,20,' + alpha.toFixed(2) + ')';
            ctx.fillText(s.ch, x, y);
            /* shimmer: letter cells occasionally tick a neighbor glyph */
            if (!s.bg && Math.random() < 0.0015) {
              var idx = RAMP.indexOf(s.ch);
              s.ch = RAMP[Math.min(RAMP.length - 1, Math.max(2, idx + (Math.random() < 0.5 ? -1 : 1)))];
            }
          }
          requestAnimationFrame(draw);
        }

        function staticDraw() {
          ctx.clearRect(0, 0, innerWidth, innerHeight);
          for (var i = 0; i < cells.length; i++) {
            var s = cells[i];
            ctx.fillStyle = s.bg ? 'rgba(20,20,20,0.2)' : '#141414';
            ctx.fillText(s.ch, s.x, s.y);
          }
        }

        build();
        addEventListener('resize', function () { build(); if (reduce) staticDraw(); }, { passive: true });
        if (reduce) staticDraw();
        else {
          addEventListener('pointermove', function (e) { mx = e.clientX; my = e.clientY; }, { passive: true });
          requestAnimationFrame(draw);
        }
      })();
    </script>
    <script is:inline defer src="/mv/ticker.js"></script>
  </body>
</html>
