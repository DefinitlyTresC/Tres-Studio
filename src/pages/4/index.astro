---
// Site 4 — "the warning one." Hot orange field, a giant beige 04 cropped by
// the viewport (no TRES on this landing), a warning-strip header. Scrolling
// slides the menu in from the right, item by item; keep scrolling and the
// whole scene sweeps off to the left, leaving you at the info screen.
// Replaces the rejected grid/plank concept entirely.
import { MV_CLIENT } from '../../lib/multiverse';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#EC5B13" />
    <title>04 — TRES CARTER</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@700;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <script is:inline set:html={MV_CLIENT(4)} />
  </head>
  <body>
    <header class="strip">
      <span class="tri" aria-hidden="true">⚠</span>
      <span>04 — TRES CARTER · ARCHITECTURE / ART / CODE · 30A</span>
    </header>

    <section class="pin-wrap" id="pinWrap">
      <div class="pin">
        <div class="scene" id="scene">
          <div class="num" id="num" aria-hidden="true">04</div>
          <nav class="stack" aria-label="Sections">
            <a class="it" href="/4/work" style="--i:0">WORK</a>
            <a class="it" href="/4/archive" style="--i:1">ARCHIVE</a>
            <a class="it" href="/lab" style="--i:2">LAB</a>
            <a class="it" href="/4/about" style="--i:3">ABOUT</a>
            <div class="it small" style="--i:4">
              <a href="/resume.pdf">RESUME</a>
              <a href="/portfolio.pdf">PORTFOLIO</a>
              <span class="soon">PLUGINS — SOON</span>
            </div>
          </nav>
        </div>
        <p class="cue" aria-hidden="true">SCROLL</p>
      </div>
    </section>

    <footer id="mv-info" class="info">
      <div class="i-cols">
        <div class="i-col">
          <span class="lbl">LOCATION</span>
          SEAGROVE · 30A<br />FLORIDA, USA
        </div>
        <div class="i-col">
          <span class="lbl">CONTACT</span>
          <a href="mailto:tres@tres.studio">TRES@TRES.STUDIO</a><br />
          <a href="https://instagram.com/tres.studio" target="_blank" rel="noopener">IG</a><br />
          <a href="https://www.linkedin.com/in/tres-carter" target="_blank" rel="noopener">LINKEDIN</a>
        </div>
        <div class="i-col">
          <span class="lbl">SECTIONS</span>
          <a href="/4/work">WORK</a><br />
          <a href="/4/archive">ARCHIVE</a><br />
          <a href="/lab">LAB</a><br />
          <a href="/4/about">ABOUT</a><br />
          <a href="/resume.pdf">RESUME</a><br />
          <a href="/portfolio.pdf">PORTFOLIO</a><br />
          <span class="soon">PLUGINS — SOON</span>
        </div>
      </div>
      <div class="i-meta">
        <span>© 2026 TRES CARTER</span>
        <span id="mv-ticker-slot"></span>
        <a href="/privacy">PRIVACY</a>
      </div>
    </footer>

    <style is:inline>
      :root {
        --org: #EC5B13; --ink: #141210; --num: #E8DCC6;
        --mvt-card: #ffffff; --mvt-ink: #141210; --mvt-line: rgba(0,0,0,0.35);
        --mvt-label: rgba(20,18,16,0.6); --mvt-accent: #141210; --mvt-confetti: #E8DCC6,#141210,#ffffff;
      }
      * { margin: 0; box-sizing: border-box; }
      /* NOTE: no overflow-x:hidden on html/body — it breaks position:sticky.
         Everything that bleeds lives inside .pin, which clips itself. */
      html { background: var(--org); }
      body { font-family: 'Inter Tight', system-ui, sans-serif; color: var(--ink); -webkit-font-smoothing: antialiased; }
      ::selection { background: var(--ink); color: var(--org); }
      a { color: inherit; text-decoration: none; }

      .strip {
        position: fixed; inset: 0 0 auto 0; z-index: 10;
        display: flex; align-items: center; gap: 10px; justify-content: center;
        padding: 12px 16px;
        font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.18em;
        border-bottom: 1.5px solid var(--ink);
        background: var(--org);
      }
      .tri { font-size: 12px; letter-spacing: 0; }

      .pin-wrap { height: 300svh; }
      .pin { position: sticky; top: 0; height: 100svh; overflow: hidden; }
      .scene { position: absolute; inset: 0; transform: translateX(var(--sx, 0px)); will-change: transform; }
      .num {
        position: absolute; right: -2vw; bottom: -10svh;
        font-weight: 900; font-size: min(88svh, 46vw); line-height: 0.8;
        letter-spacing: -0.04em; color: var(--num);
        transform: translateX(var(--nx, 0px));
        user-select: none;
      }
      .stack {
        position: absolute; right: max(24px, 5vw); top: 50%; translate: 0 -50%;
        display: grid; justify-items: end; gap: 2.6svh;
        text-align: right;
      }
      .it {
        font-weight: 900; font-size: clamp(40px, 8.4vw, 104px); line-height: 0.95;
        letter-spacing: -0.01em;
        transform: translateX(var(--x, 0));
        will-change: transform;
      }
      .it.small { display: flex; gap: 20px; font-family: 'Space Mono', monospace; font-weight: 400; font-size: 12px; letter-spacing: 0.1em; }
      .soon { color: rgba(20,18,16,0.55); }
      @media (hover: hover) and (pointer: fine) {
        a.it, .it.small a { transition: color 160ms ease; }
        a.it:hover, .it.small a:hover { color: var(--num); }
      }
      .cue {
        position: absolute; bottom: 3.4svh; left: 50%; translate: -50% 0;
        font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 0.22em;
        color: rgba(20,18,16,0.55);
        transition: opacity 400ms ease;
      }
      .cue.off { opacity: 0; }

      .info { min-height: 88svh; display: grid; align-content: center; gap: 8svh; position: relative; padding: 12svh 5vw 6svh; border-top: 1.5px solid var(--ink); }
      .i-cols {
        display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px;
        padding-right: clamp(100px, 24vw, 240px);
        font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.05em; line-height: 1.9;
      }
      @media (max-width: 640px) { .i-cols { grid-template-columns: 1fr; } }
      .lbl { display: block; color: rgba(20,18,16,0.55); margin-bottom: 6px; }
      .i-meta {
        display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap;
        border-top: 1.5px solid var(--ink); padding-top: 16px;
        font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.06em;
      }
      @media (hover: hover) and (pointer: fine) {
        .info a:hover { text-decoration: underline; text-underline-offset: 4px; }
      }

      /* no-JS / reduced motion: everything simply rests in place */
      @media (prefers-reduced-motion: reduce) {
        .pin-wrap { height: auto; }
        .pin { position: static; height: 100svh; }
      }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
      import('/mv/ring.js');
    </script>
    <script is:inline>
      (function () {
        'use strict';
        var reduce = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}
        if (reduce) return;

        var wrap = document.getElementById('pinWrap');
        var scene = document.getElementById('scene');
        var num = document.getElementById('num');
        var items = Array.prototype.slice.call(document.querySelectorAll('.it'));
        var ticking = false;

        function ease(t) { return 1 - Math.pow(1 - t, 3); }
        function place() {
          ticking = false;
          var r = wrap.getBoundingClientRect();
          var total = r.height - innerHeight;
          var p = Math.min(1, Math.max(0, -r.top / total));

          /* phase 1 (0 → .62): the menu arrives from the right, one by one */
          for (var i = 0; i < items.length; i++) {
            var start = 0.04 + i * 0.1;
            var t = Math.min(1, Math.max(0, (p - start) / 0.14));
            items[i].style.setProperty('--x', ((1 - ease(t)) * 120) + 'vw');
          }
          /* the 04 drifts as you dig; the cue bows out once you're moving */
          num.style.setProperty('--nx', (-p * 7) + 'vw');
          document.querySelector('.cue').classList.toggle('off', p > 0.08);

          /* phase 2 (.8 → 1): everything sweeps off to the left */
          var s = Math.min(1, Math.max(0, (p - 0.8) / 0.2));
          scene.style.setProperty('--sx', (-ease(s) * 108) + 'vw');
        }
        addEventListener('scroll', function () {
          if (!ticking) { ticking = true; requestAnimationFrame(place); }
        }, { passive: true });
        addEventListener('resize', place, { passive: true });
        place();
      })();
    </script>
    <script is:inline defer src="/mv/ticker.js"></script>
  </body>
</html>
