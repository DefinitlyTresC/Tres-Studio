---
// Site 4 — work.
import { MV_CLIENT } from '../../lib/multiverse';
import { getCollection } from 'astro:content';
const WORK = ['z07', 'ee13', 'flatwood', 'tucker', 'thesis'];
const all = (await getCollection('projects')).map((e) => e.data);
const rows = WORK.map((s) => all.find((p) => p.slug === s)).filter(Boolean);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#0B0B0C" />
    <title>WORK — TRESCARTER</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Space+Mono&display=swap" rel="stylesheet" />
    <script is:inline set:html={MV_CLIENT(4)} />
  </head>
  <body>
    <a class="back" id="back" href="/4/">← INDEX</a>
    <main class="arch">
      <header class="head">
        <p class="spec">WORK / 05</p>
        <h1 class="name">SELECTED WORK</h1>
      </header>
      <div class="list">
        {rows.map((p, i) => (
          <a class="row" href={`/4/project/${p.slug}`}>
            <span class="r-no">{String(i + 1).padStart(2, '0')}</span>
            <span class="r-name">{p.name.toUpperCase()}</span>
            <span class="r-meta">{p.year}</span>
          </a>
        ))}
      </div>
    </main>
    <footer class="foot"><span>© 2026 TRES CARTER</span><a href="/privacy">PRIVACY</a></footer>

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }
      html { background: #0B0B0C; }
      body {
        font-family: 'Space Grotesk', system-ui, sans-serif; color: #F2F2F2; -webkit-font-smoothing: antialiased;
        background:
          linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
        background-size: 52px 52px;
      }
      ::selection { background: #F2F2F2; color: #0B0B0C; }
      a { color: inherit; text-decoration: none; }
      .back { position: fixed; z-index: 10; top: var(--y, 14px); left: 18px; font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 0.16em; padding: 12px 0; transition: transform 140ms cubic-bezier(0.23,1,0.32,1); }
      .back:active { transform: scale(0.96); }
      @media (hover: hover) and (pointer: fine) { .back:hover { text-decoration: underline; text-underline-offset: 4px; } }
      .arch { max-width: 1000px; margin: 0 auto; padding: 0 6vw 12svh; }
      .head { padding: clamp(110px, 22vh, 260px) 0 7svh; }
      .spec { font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 0.2em; color: rgba(242,242,242,0.45); }
      .name { font-weight: 700; font-size: clamp(38px, 8vw, 92px); line-height: 1; margin-top: 12px; }
      .list { border-top: 1px solid rgba(255,255,255,0.18); }
      .row { display: flex; align-items: baseline; gap: 16px; padding: 26px 0; border-bottom: 1px solid rgba(255,255,255,0.18); }
      .r-no, .r-meta { font-family: 'Space Mono', monospace; font-size: 12px; color: rgba(242,242,242,0.45); }
      .r-meta { margin-left: auto; }
      .r-name { font-weight: 700; font-size: clamp(22px, 4vw, 44px); line-height: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      @media (hover: hover) and (pointer: fine) {
        .r-name { transition: translate 220ms cubic-bezier(0.23,1,0.32,1); }
        .row:hover .r-name { translate: 10px 0; }
      }
      .foot { display: flex; justify-content: space-between; max-width: 1000px; margin: 0 auto; padding: 3svh 6vw 4svh; border-top: 1px solid rgba(255,255,255,0.18); font-family: 'Space Mono', monospace; font-size: 10px; letter-spacing: 0.06em; }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
    </script>
    <script is:inline>
      (function () {
        var reduce = false, fine = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; fine = matchMedia('(hover: hover) and (pointer: fine)').matches; } catch (e) {}
        if (!fine || reduce) return;
        var back = document.getElementById('back');
        var target = null, cur = null, raf = null;
        function frame() {
          cur += (target - cur) * 0.09;
          back.style.setProperty('--y', cur.toFixed(1) + 'px');
          if (Math.abs(target - cur) > 0.4) raf = requestAnimationFrame(frame); else raf = null;
        }
        addEventListener('pointermove', function (e) {
          var h = back.offsetHeight;
          target = Math.min(innerHeight - h - 12, Math.max(12, e.clientY - h / 2));
          if (cur === null) cur = target;
          if (!raf) raf = requestAnimationFrame(frame);
        }, { passive: true });
      })();
    </script>
  </body>
</html>
