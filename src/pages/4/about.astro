---
// Site 4 — about.
import { MV_CLIENT } from '../../lib/multiverse';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#0B0B0C" />
    <title>ABOUT — TRESCARTER</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Space+Mono&display=swap" rel="stylesheet" />
    <script is:inline set:html={MV_CLIENT(4)} />
  </head>
  <body>
    <a class="back" id="back" href="/4/">← INDEX</a>
    <main class="about">
      <div class="card">
        <h1 class="name">TRES CARTER</h1>
        <p class="lede">ARCHITECTURAL DESIGNER / 30A, FLORIDA</p>
      </div>
      <div class="acts">
        <a href="mailto:tres@tres.studio">TRES@TRES.STUDIO</a>
        <a href="https://instagram.com/tres.studio" target="_blank" rel="noopener">IG</a>
      </div>
    </main>

    <style is:inline>
      * { margin: 0; box-sizing: border-box; }
      html { background: #0B0B0C; }
      body {
        font-family: 'Space Grotesk', system-ui, sans-serif; color: #F2F2F2; -webkit-font-smoothing: antialiased;
        background:
          linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
        background-size: 52px 52px;
      }
      ::selection { background: #F2F2F2; color: #0B0B0C; }
      a { color: inherit; text-decoration: none; }
      .back { position: fixed; z-index: 10; top: var(--y, 14px); left: 18px; font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 0.16em; padding: 12px 0; transition: transform 140ms cubic-bezier(0.23,1,0.32,1); }
      .back:active { transform: scale(0.96); }
      @media (hover: hover) and (pointer: fine) { .back:hover { text-decoration: underline; text-underline-offset: 4px; } }
      .about { min-height: 100svh; display: grid; align-content: center; gap: 5svh; padding: 0 6vw; }
      .card { background: #F2F2F2; color: #0B0B0C; width: fit-content; padding: clamp(20px, 4vw, 44px) clamp(24px, 5vw, 56px); transform: rotate(-4deg); }
      .name { font-weight: 700; font-size: clamp(38px, 8vw, 96px); line-height: 1; }
      .lede { font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.14em; margin-top: 12px; }
      .acts { display: flex; gap: 28px; font-family: 'Space Mono', monospace; font-size: 12px; letter-spacing: 0.1em; }
      @media (hover: hover) and (pointer: fine) { .acts a:hover { text-decoration: underline; text-underline-offset: 4px; } }
    </style>

    <script is:inline type="module">
      import { autoReveal } from '/mv/curtain.js';
      autoReveal();
    </script>
    <script is:inline>
      (function () {
        var reduce = false, fine = false;
        try { reduce = matchMedia('(prefers-reduced-motion: reduce)').matches; fine = matchMedia('(hover: hover) and (pointer: fine)').matches; } catch (e) {}
        if (!fine || reduce) return;
        var back = document.getElementById('back');
        var target = null, cur = null, raf = null;
        function frame() {
          cur += (target - cur) * 0.09;
          back.style.setProperty('--y', cur.toFixed(1) + 'px');
          if (Math.abs(target - cur) > 0.4) raf = requestAnimationFrame(frame); else raf = null;
        }
        addEventListener('pointermove', function (e) {
          var h = back.offsetHeight;
          target = Math.min(innerHeight - h - 12, Math.max(12, e.clientY - h / 2));
          if (cur === null) cur = target;
          if (!raf) raf = requestAnimationFrame(frame);
        }, { passive: true });
      })();
    </script>
  </body>
</html>
